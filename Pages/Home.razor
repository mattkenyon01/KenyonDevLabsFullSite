<PageTitle>Kenyon Dev Labs</PageTitle>

<HeadContent>
    <meta name="description" content="Official site of Kenyon Dev Labs. Explore our apps and games, read updates, and get download links." />
    <link rel="canonical" href="https://kenyondevlabs.com/" />
</HeadContent>

<HomeHeader />

<!-- HERO: Background Image with Overlay Text -->
<div class="project-hero-bg">
    <div class="project-hero-overlay">
        <h1>Kenyon Dev Labs</h1>
        <p class="subtext">
            An indie lab brewing games, apps, and bold ideas.
        </p>


    </div>
</div>
<style>
    /* PREVENT HORIZONTAL SCROLL */
    html, body {
        max-width: 100%;
        overflow-x: hidden;
    }

    /* GLOBAL BACKGROUND COLOR */
    body {
        background: #291824;
        color: #fff;
    }

    .project-hero-bg {
        width: 100vw;
        aspect-ratio: 32 / 9;
        background-image: url("images/Middle.png");
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        margin-left: calc(50% - 50vw);
        margin-right: calc(50% - 50vw);
    }

    @@media (max-width: 1920px) {
        .project-hero-bg {
            aspect-ratio: 16 / 9;
        }
    }

        /* Dark gradient overlay */
        .project-hero-bg::before {
            content: "";
            position: absolute;
            inset: 0;
            z-index: 0;
        }

    .project-hero-overlay {
        position: relative;
        z-index: 1;
        text-align: left;
        padding-top: 0;
        padding-left: 8vw;
        padding-right: 5vw;
        padding-bottom: 0;
        width: auto;
        transform: translate(-275px, -225px);
    }

        /* Heading size scales with viewport height too */
        .project-hero-overlay h1 {
            margin: 0 0 0.5rem;
            font-size: 6vh; /* tied to viewport height */
            line-height: 1.05;
            color: white;
            white-space: nowrap;
        }

        /* Subtext scales from the same unit */
        .project-hero-overlay .subtext {
            margin: 0 0 1.5rem;
            color: white;
            font-size: 2.4vh; /* 6vh : 2.4vh ≈ 2.5:1 ratio */
            line-height: 1.7;
        }



    .hero-button {
        display: inline-block;
        padding: 0.9rem 1.8rem;
        border-radius: 999px;
        border: 1px solid #fff;
        background: #fff;
        color: #000;
        text-decoration: none;
        cursor: pointer;
        font-size: 1.1rem;
    }

        .hero-button:hover {
            opacity: 0.9;
        }
    /* ========================= */
    /* 📱 MOBILE RESPONSIVE TEXT */
    /* ========================= */
    @@media (max-width: 700px) {
        .project-hero-overlay h1

    {
        font-size: 4vh; /* smaller heading on phones */
    }

    .project-hero-overlay .subtext {
        font-size: 1.8vh; /* smaller supporting text */
    }

    .project-hero-overlay {
        padding-bottom: 14vh; /* prevents text rising too high */
    }

    }

    .hero-button {
        display: inline-block;
        padding: 0.9rem 1.8rem;
        border-radius: 999px;
        border: 1px solid #fff;
        background: #fff;
        color: #000;
        text-decoration: none;
        cursor: pointer;
        font-size: 1.1rem;
    }

        .hero-button:hover {
            opacity: 0.9;
        }
</style>


<!-- CUSTOM SECTION: Title + Text Left → Image Right -->
<div class="custom-section">
    <div class="custom-left">
        <h2 class="custom-section-title">Welcome to my site</h2>

        <p>
            Kenyon Dev Labs is my personal indie studio, where I create unique games and apps with heart and enthusiasm.
            As a solo developer, I pour myself into every detail to craft experiences that feel thoughtful, polished, and fun.
        </p>
    </div>

    <div class="custom-image">
        <img src="images/portfolio/Games Cover.png" alt="Example Project Image" />
    </div>
</div>

<div class="kd-separator diamond">
    <span class="line"></span>
    <span class="diamond"></span>
    <span class="line"></span>
</div>

<style>
    /* CLEAN LEFT-TEXT / RIGHT-IMAGE SECTION */
    .custom-section {
        max-width: 1100px;
        margin: 3rem auto;
        padding: 1.5rem 2rem;
        background: #280a16;
        border-radius: 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 2rem;
    }

    .custom-left {
        flex: 1;
        color: #fff;
    }

    .custom-section-title {
        margin: 0 0 1.25rem;
        font-size: 3rem; /* was 2.5rem */
    }

    .custom-left p {
        margin: 0 0 1.5rem;
        color: #ddd;
        font-size: 1.3rem; /* was 1.1rem */
        line-height: 1.6;
        max-width: 32rem;
    }

    .custom-image {
        flex: 0 0 45%;
        aspect-ratio: 16 / 9;
        border-radius: 1rem;
        overflow: hidden;
    }

        .custom-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    /* MOBILE */
    @@media (max-width: 768px) {
        .custom-section {
            flex-direction: column;
            align-items: center; /* center the whole stack */
            text-align: center; /* center text inside */
        }

        .custom-left {
            text-align: center; /* center title + paragraph */
        }

            .custom-left p {
                margin-left: auto; /* keep nice readable width */
                margin-right: auto;
            }

        .custom-image {
            width: 100%;
        }
    }

</style>

