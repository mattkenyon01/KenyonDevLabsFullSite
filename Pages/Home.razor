<!-- LATEST UPDATES -->
<section class="news-home-section section-bg-b">
    <div class="news-home-header">
        <span class="section-eyebrow">From the lab</span>
        <h2 class="section-title">Latest Updates</h2>
        <p>Recent news, releases, and progress across my projects.</p>
    </div>

    @if (latestNews.Count == 0)
    {
        <p class="news-home-empty">No updates yet - check back soon.</p>
    }
    else
    {
        <div class="news-home-grid">
            @foreach (var item in latestNews)
            {
                <article class="news-home-card">
                    <div class="news-home-body">
                        <div class="news-home-title-row">
                            <div class="news-home-title-left">
                                @if (!string.IsNullOrWhiteSpace(item.IconUrl))
                                {
                                    <img class="news-home-icon" src="@item.IconUrl" alt="" />
                                }
                                <h3>@item.Title</h3>
                            </div>
                            <div class="news-home-date"
                                 style="background: linear-gradient(135deg, @GetNewsTop(item), @GetNewsBottom(item)); color: @GetNewsDateText(item);">
                                <span class="day">@item.Date.ToString("dd")</span>
                                <span class="mon">@item.Date.ToString("MMM")</span>
                            </div>
                        </div>
                        <p>@TruncateSummary(item.Summary)</p>
                    </div>
                </article>
            }
        </div>
    }

    <div class="news-home-actions">
        <a class="secondary-button news-home-button" href="/News">View all news</a>
    </div>
</section>

