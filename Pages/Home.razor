@page "/"

@using System.Globalization
@using KenyonDevLabs.Models
@using KenyonDevLabs.Services
@inject NewsFileService NewsData
@inject IJSRuntime JS

<PageTitle>Kenyon Dev Labs</PageTitle>

<HeadContent>
    <meta name="description" content="Official site of Kenyon Dev Labs. Explore our apps and games, read updates, and get download links." />
    <link rel="canonical" href="https://kenyondevlabs.com/" />
</HeadContent>

<HomeHeader />

<!-- Welcome section: text left, hero image right -->
<section class="welcome-section">
    <div class="welcome-content">
        <span class="welcome-eyebrow">About the studio</span>
        <h2 class="welcome-title">Welcome to my site</h2>
        <p>
            Kenyon Dev Labs is my personal indie studio, where I create unique games and apps with heart and enthusiasm.
            As a solo developer, I pour myself into every detail to craft experiences that feel thoughtful, polished, and fun.
        </p>
    </div>

    <div class="welcome-visual" aria-hidden="true"></div>
</section>

<style>
html, body {
    margin: 0;
    padding: 0;
    max-width: 100%;
    overflow-x: hidden;
}

    body {
        background: #291824;
        color: #fff;
        font-family: var(--font-sans, 'Plus Jakarta Sans', system-ui, sans-serif);
    }

    /* Welcome section — full-width split layout */
    .welcome-section {
        width: 100vw;
        min-height: 32vh;
        margin: 0;
        margin-left: calc(50% - 50vw);
        margin-right: calc(50% - 50vw);
        display: flex;
        flex-direction: row;
        align-items: stretch;
        overflow: hidden;
        background: #280a16;
        border-bottom: 1px solid rgba(231, 87, 29, 0.12);
    }

    .welcome-content {
        flex: 1 1 50%;
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 3.5rem 4rem;
        background: #280a16;
        color: #fff;
    }

    .welcome-eyebrow {
        display: inline-block;
        margin-bottom: 0.85rem;
        font-size: 0.8rem;
        font-weight: 600;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: #e7571d;
    }

    .welcome-title {
        margin: 0 0 1.25rem;
        font-size: clamp(2rem, 4vw, 3rem);
        font-weight: 700;
        letter-spacing: -0.03em;
        line-height: 1.1;
    }

    .welcome-title::after {
        content: "";
        display: block;
        width: 3.5rem;
        height: 3px;
        margin-top: 1rem;
        background: #e7571d;
        border-radius: 999px;
    }

    .welcome-content p {
        margin: 0;
        max-width: 34rem;
        color: rgba(255, 255, 255, 0.82);
        font-size: 1.15rem;
        line-height: 1.75;
    }

    .welcome-visual {
        flex: 1 1 50%;
        min-height: 32vh;
        background-image: url("images/Middle.png");
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
    }

    @@media (max-width: 768px) {
        .welcome-section {
            flex-direction: column;
        }

        .welcome-content {
            order: 2;
            padding: 2.5rem 1.75rem;
            text-align: center;
            align-items: center;
        }

        .welcome-visual {
            order: 1;
            min-height: 24vh;
        }

        .welcome-title::after {
            margin-left: auto;
            margin-right: auto;
        }

        .welcome-content p {
            max-width: none;
        }
    }
</style>

<section class="dev-section">
    <div class="dev-header">
        <span class="section-eyebrow">What I've built</span>
        <h2 class="section-title">My Apps & Games</h2>
        <p>
            Apps and games I've shipped on the App Store. Discover them below and try them out.
        </p>
    </div>

    <div class="dev-grid">
        <article class="dev-card">
            <div class="dev-card-visual bucket-connect-visual" aria-hidden="true"></div>
            <div class="dev-card-body">
                <div class="dev-card-title-row">
                    <img class="dev-card-icon" src="images/Bucket Connect/icons/The Bucket List Icon NB.png" alt="" />
                    <h3>Bucket Connect</h3>
                </div>
                <p>Bucket Connect is the best way for you to track and chase your dreams.</p>
                <a class="secondary-button dev-card-button" href="/BucketConnect">View Project</a>
            </div>
        </article>

        <article class="dev-card">
            <div class="dev-card-visual girls-who-connect-visual" aria-hidden="true"></div>
            <div class="dev-card-body">
                <div class="dev-card-title-row">
                    <img class="dev-card-icon" src="images/Girls Who Connect/icons/Girls Who Connect Logo NB.png" alt="" />
                    <h3>Girls Who Connect</h3>
                </div>
                <p>Stay up to date with community walks in your area.</p>
                <a class="secondary-button dev-card-button" href="/GirlsWhoConnect">View Project</a>
            </div>
        </article>

        <article class="dev-card">
            <div class="dev-card-visual castle-climbers-dev-visual" aria-hidden="true"></div>
            <div class="dev-card-body">
                <div class="dev-card-title-row">
                    <img class="dev-card-icon" src="images/castle_climbers/icons/3.0 CC.png" alt="" />
                    <h3>Castle Climbers</h3>
                </div>
                <p>A vertical 2D adventure with procedural environments, custom characters, and competitive challenges.</p>
                <a class="secondary-button dev-card-button" href="/Games/CastleClimbers">View Project</a>
            </div>
        </article>
    </div>
</section>

<!-- LATEST UPDATES -->
<section class="news-home-section">
    <div class="news-home-header">
        <span class="section-eyebrow">From the lab</span>
        <h2 class="section-title">Latest Updates</h2>
        <p>Recent news, releases, and progress across my projects.</p>
    </div>

    @if (latestNews.Count == 0)
    {
        <p class="news-home-empty">No updates yet — check back soon.</p>
    }
    else
    {
        <div class="news-home-grid">
            @foreach (var item in latestNews)
            {
                <article class="news-home-card">
                    <div class="news-home-date"
                         style="background: linear-gradient(180deg, @GetNewsTop(item), @GetNewsBottom(item)); color: @GetNewsDateText(item);">
                        <span class="day">@item.Date.ToString("dd")</span>
                        <span class="mon">@item.Date.ToString("MMM")</span>
                    </div>
                    <div class="news-home-body">
                        <div class="news-home-title-row">
                            @if (!string.IsNullOrWhiteSpace(item.IconUrl))
                            {
                                <img class="news-home-icon" src="@item.IconUrl" alt="" />
                            }
                            <h3>@item.Title</h3>
                        </div>
                        <p>@TruncateSummary(item.Summary)</p>
                    </div>
                </article>
            }
        </div>
    }

    <div class="news-home-actions">
        <a class="secondary-button news-home-button" href="/News">View all news</a>
    </div>
</section>

<!-- IN DEVELOPMENT -->
<section class="dev-section">
    <div class="dev-header">
        <span class="section-eyebrow">Coming soon</span>
        <h2 class="section-title">In Development</h2>
        <p>Games and experiments I'm actively building between app releases.</p>
    </div>

    <div class="dev-grid">
        <article class="dev-card">
            <div class="dev-card-visual isles-apart-dev-visual" aria-hidden="true"></div>
            <div class="dev-card-body">
                <h3>Isles Apart</h3>
                <p>An island adventure game in early development. Follow along on the news page for the latest milestones and previews.</p>
                <a class="secondary-button dev-card-button" href="/News">Follow updates</a>
            </div>
        </article>
    </div>
</section>

<!-- OTHER PROJECTS -->
<section class="other-projects-section">
    <div class="other-projects-visual" aria-hidden="true"></div>
    <div class="other-projects-content">
        <span class="section-eyebrow">Archive</span>
        <h2 class="other-projects-title">Other Projects</h2>
        <p>
            A broader look at everything I've built — released apps, shipped games, prototypes,
            and university projects that show the range of my work.
        </p>

        <a class="secondary-button other-projects-button" href="/OtherProjects">Browse other projects</a>
    </div>
</section>

<!-- GET IN TOUCH -->
<section class="contact-section">
    <div class="contact-inner">
        <span class="section-eyebrow">Get in touch</span>
        <h2 class="section-title">Want to work together?</h2>
        <p>
            Whether it's feedback, a collaboration, or a question about my apps —
            I'm always happy to hear from you.
        </p>
        <a class="contact-button" href="mailto:matt@kenyondevlabs.com">matt@kenyondevlabs.com</a>
    </div>
</section>

