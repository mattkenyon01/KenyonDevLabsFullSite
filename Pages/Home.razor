<style>

    .apps-header {
        max-width: 900px;
        margin: 3rem auto 2rem;
        text-align: center;
        padding: 0 1rem;
    }

        .apps-header h2 {
            font-size: 3.2rem; /* large and consistent with section titles */
            margin-bottom: 1rem;
        }

        .apps-header p {
            font-size: 1.35rem; /* matches your upgraded paragraph size */
            color: #ddd;
            line-height: 1.6;
            max-width: 720px;
            margin: 0 auto;
        }

    .project-grid {
        max-width: 1100px;
        margin: 2.5rem auto 0;
        display: grid;
        gap: 1.75rem;
        justify-content: center; /* allows centering */
        grid-auto-columns: 350px; /* lock card width */
        grid-template-columns: repeat(auto-fit, 350px);
    }

      

    /* Individual card */
    .project-card {
        background: #280a16;
        border-radius: 0.75rem; /* less curved */
        padding: 1.5rem 1.5rem 1.75rem;
        display: flex;
        flex-direction: column;
        align-items: center; /* center content */
        text-align: center; /* center text */
        color: #f5f5f5;
    }

    /* Title row */
    .project-title-row {
        display: flex;
        align-items: center;
        justify-content: center; /* center title + icon */
        gap: 0.75rem;
        margin-bottom: 0.9rem;
    }

    .project-title-icon {
        width: 32px;
        height: 32px;
        object-fit: contain;
    }

    .project-title-row h2 {
        margin: 0;
        font-size: 1.8rem; /* was 1.4rem */
    }

    /* Card image */
    .project-card-image {
        width: 100%;
        aspect-ratio: 16 / 9;
        border-radius: 0.5rem; /* tighter corners */
        overflow: hidden;
        margin-bottom: 1.1rem;
    }

        .project-card-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    /* Text + button under image */
    .project-card-text {
        display: flex;
        flex-direction: column;
        align-items: center; /* center button */
        text-align: center;
        width: 100%;
    }

        .project-card-text p {
            margin: 0 0 1.1rem;
            color: #ddd;
            font-size: 1.15rem; /* was 0.98rem */
            line-height: 1.6;
            max-width: 22rem; /* cleaner centered width */
        }

    /* Button reused */
    .secondary-button {
        display: inline-block;
        padding: 0.9rem 1.6rem; /* bigger */
        border-radius: 999px;
        border: 1px solid #fff;
        background: transparent;
        color: #fff;
        text-decoration: none;
        font-size: 1.1rem; /* bigger */
        transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
    }

        .secondary-button:hover {
            background: #fff;
            color: #000;
        }

    /* Border/glow colours */
    .blue-border {
        border: 2px solid #097969;
        box-shadow: 0 0 12px rgba(9, 121, 105, 0.35);
    }

    .purple-border {
        border: 2px solid #efb3c4;
        box-shadow: 0 0 14px rgba(239, 179, 196, 0.45);
    }

    .yellow-border {
        border: 2px solid #40b5e0;
        box-shadow: 0 0 14px rgba(64, 181, 224, 0.45);
    }

    /* Card-specific button hover colours: match outline colours */
    .project-card.blue-border .secondary-button:hover {
        background: #097969;
        border-color: #097969;
        color: #fff;
    }

    .project-card.purple-border .secondary-button:hover {
        background: #efb3c4;
        border-color: #efb3c4;
        color: #000;
    }

    .project-card.yellow-border .secondary-button:hover {
        background: #40b5e0;
        border-color: #40b5e0;
        color: #000;
    }

    /* RESPONSIVE: 2 per row on tablet */
    @@media (max-width: 1024px) {
        .project-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

            .project-grid.center-two {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
    }

    /* RESPONSIVE: 1 per row on mobile */
    @@media (max-width: 768px) {
        .project-grid {
            grid-template-columns: 1fr;
            margin-left: 0;
            margin-right: 0;
            padding: 0 1.25rem;
        }

            .project-grid.center-two {
                grid-template-columns: 1fr;
            }
    }

    .kd-separator.diamond {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        margin: 3rem 0;
    }

        .kd-separator.diamond .line {
            flex: 1;
            height: 2px;
            background: #e7571d;
        }

        .kd-separator.diamond .diamond {
            width: 12px;
            height: 12px;
            background: #e7571d;
            transform: rotate(45deg);
        }

    /* SOCIAL ICON STRIP (centered + slightly smaller) */
    .social-icons {
        margin-top: 1.5rem;
        display: flex;
        gap: 1rem;
        justify-content: center; /* CENTER icons */
        flex-wrap: wrap;
    }

        .social-icons a {
            display: block;
            width: 55px; /* was 70px */
            height: 55px; /* was 70px */
            border-radius: 10px; /* slightly smaller radius to match size */
            overflow: hidden;
            transition: transform 0.15s ease, opacity 0.15s ease;
        }

            .social-icons a:hover {
                transform: scale(1.06);
                opacity: 0.9;
            }

        .social-icons img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    /* MOBILE — stays centered */
    @@media (max-width: 768px) {
        .social-icons {
            justify-content: center;
        }
    }

    /* Centered Social Section */
    .social-center {
        flex-direction: column !important;
        text-align: center;
    }

    .social-content {
        display: flex;
        flex-direction: column;
        align-items: center;
    }

        .social-content p {
            max-width: 600px;
        }

</style>

