<style>
:root {
    --page-bg-a: #291824;
    --page-bg-b: #280a16;
}

.section-bg-a {
    background: var(--page-bg-a);
}

.section-bg-b {
    background: var(--page-bg-b);
}

html, body {
    margin: 0;
    padding: 0;
    max-width: 100%;
    overflow-x: clip;
}

    body {
        background: var(--page-bg-a);
        color: #fff;
        font-family: var(--font-sans, 'Plus Jakarta Sans', system-ui, sans-serif);
    }

    /* Welcome section - full-width hero image (height follows width) */
    .welcome-section {
        position: relative;
        width: 100vw;
        aspect-ratio: 2.5 / 1;
        min-height: unset;
        margin: 0;
        margin-left: calc(50% - 50vw);
        margin-right: calc(50% - 50vw);
        display: flex;
        align-items: flex-start;
        padding: 2.25rem 4rem 3.5rem;
        overflow: hidden;
        background-image: url("images/New Website Image.png");
        background-size: cover;
        background-position: 15% center;
        background-repeat: no-repeat;
        box-sizing: border-box;
    }

    .welcome-section--wide {
        display: none;
    }

    .welcome-inner {
        position: relative;
        z-index: 1;
        width: 100%;
    }

    .welcome-content {
        max-width: 34rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
        color: #fff;
    }

    .welcome-section--default .welcome-content {
        transform: translateY(1.5rem);
    }

    /*
     * Ultra-wide (1800+) - separate layout slot.
     * Currently a placeholder that mirrors the default welcome section.
     * Change .welcome-section--wide markup/CSS below when you want a distinct layout.
     */
    @@media (min-width: 1800px) {
        .welcome-section--default {
            display: none;
        }

        .welcome-section--wide {
            display: flex;
            align-items: flex-start;
            aspect-ratio: 2.2 / 1;
            min-height: unset;
            padding: 2.25rem 4rem 3.5rem;
            background-position: 15% center;
        }

        .welcome-section--wide .welcome-inner {
            width: 100%;
        }

        .welcome-section--wide .welcome-content {
            max-width: 34rem;
            margin: 0 auto;
            transform: translate(-17rem, 1.5rem);
            display: flex;
            flex-direction: column;
            justify-content: center;
            text-align: center;
            align-items: center;
            color: #fff;
        }

        .welcome-section--wide .welcome-title::after {
            margin-left: auto;
            margin-right: auto;
        }
    }

    .welcome-eyebrow {
        display: inline-block;
        margin-bottom: 0.85rem;
        font-size: 0.8rem;
        font-weight: 600;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: #280a16;
        text-shadow: 0 1px 6px rgba(255, 255, 255, 0.35);
    }

    .welcome-title {
        margin: 0 0 1.25rem;
        font-size: clamp(2rem, 4vw, 3rem);
        font-weight: 700;
        letter-spacing: -0.03em;
        line-height: 1.1;
        text-shadow: 0 2px 16px rgba(0, 0, 0, 0.5);
    }

    .welcome-title-break {
        display: none;
    }

    .welcome-title::after {
        content: "";
        display: block;
        width: 3.5rem;
        height: 3px;
        margin-top: 1rem;
        background: #fff;
        border-radius: 999px;
    }

    .welcome-content p {
        margin: 0;
        color: rgba(255, 255, 255, 0.92);
        font-size: 1.15rem;
        line-height: 1.75;
        text-shadow: 0 1px 12px rgba(0, 0, 0, 0.45);
    }

    @@media (max-width: 768px) {
        .welcome-section {
            aspect-ratio: 1.85 / 1;
            min-height: unset;
            padding: 0 1.25rem 1.5rem;
            align-items: flex-start;
            background-size: cover;
            background-position: 52% center;
        }

        .welcome-content {
            max-width: none;
            text-align: left;
            align-items: flex-start;
            transform: translateY(-0.35rem);
        }

        .welcome-title {
            margin-bottom: 0;
            line-height: 1.15;
        }

        .welcome-title-break {
            display: inline;
        }

        .welcome-title::after {
            display: none;
        }

        .welcome-content p {
            display: none;
        }
    }
</style>

