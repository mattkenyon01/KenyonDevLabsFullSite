</HeadContent>

<HomeHeader />

<!-- Welcome section: default (<1800) -->
<section class="welcome-section welcome-section--default">
    <div class="welcome-inner">
        <div class="welcome-content">
            <h2 class="welcome-title">Welcome to <br class="welcome-title-break" />my site</h2>
            <p>
                Kenyon Dev Labs is my personal indie studio, where I create unique games and apps with heart and enthusiasm.
                As a solo developer, I pour myself into every detail to craft experiences that feel thoughtful, polished, and fun.
            </p>
        </div>
    </div>
</section>

<!-- Welcome section: ultra-wide (1800+) - placeholder copy of default for now -->
<section class="welcome-section welcome-section--wide">
    <div class="welcome-inner">
        <div class="welcome-content">
            <h2 class="welcome-title">Welcome to<br class="welcome-title-break" />my site</h2>
            <p>
                Kenyon Dev Labs is my personal indie studio, where I create unique games and apps with heart and enthusiasm.
                As a solo developer, I pour myself into every detail to craft experiences that feel thoughtful, polished, and fun.
            </p>
