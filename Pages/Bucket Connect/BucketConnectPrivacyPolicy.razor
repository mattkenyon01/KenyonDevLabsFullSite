@page "/bucketconnect/privacypolicy"

<PageTitle>Privacy Policy - Bucket Connect</PageTitle>

<BucketConnectHeader />

<div class="bc-page">

    <section class="bc-section bc-hero bc-hero-compact">
        <div class="bc-container bc-hero-grid">
            <div class="bc-hero-copy">
                <span class="bc-eyebrow bc-eyebrow-light">Legal</span>
                <h1>Privacy Policy</h1>
                <p>
                    How Bucket Connect collects, uses, and protects your personal information.
                </p>
                <p class="bc-effective-date">Effective 1 September 2024</p>
            </div>
            <div class="bc-hero-visual">
                <img src="/images/Lock.png" alt="" aria-hidden="true" />
            </div>
        </div>
    </section>

    <section class="bc-section bc-section-muted bc-legal-section" aria-labelledby="policy-title">
        <div class="bc-container">
            <header class="bc-section-head">
                <span class="bc-eyebrow">Legal</span>
                <h2 id="policy-title">Privacy policy</h2>
                <p class="bc-section-lead">@SectionCount section@(SectionCount == 1 ? "" : "s") covered.</p>
            </header>

            <div class="bc-policy-blocks">

                <article class="bc-policy-block" id="consent">
                    <h2>Consent</h2>
                    <p>By using Bucket Connect, you consent to the terms outlined in this Privacy Policy.</p>
                </article>

                <article class="bc-policy-block" id="image-sharing">
                    <h2>Image sharing</h2>
                    <p>
                        Users can upload images from their camera roll to use as profile pictures.
                        Profile pictures are public and visible to all users. Images can also be used
                        as covers for lists and events. When used for personal lists and events,
                        these images are private and accessible only to friends specifically chosen
                        by the user. However, if images are used for covers in the ideas function,
                        they will be visible to all users and cannot be removed once posted.
                    </p>
                    <p>
                        Please make sure images are suitable for public viewing before uploading.
                        If images used for profile pictures, lists, events, or ideas are deemed
                        inappropriate, they will be removed. Inappropriate content includes, but is
                        not limited to, images that are offensive, sexually explicit, violent,
                        defamatory, or violate the rights of others. We reserve the right to determine
                        what constitutes inappropriate content.
                    </p>
                </article>

                <article class="bc-policy-block" id="advertisements">
                    <h2>Advertisements</h2>
                    <p>
                        When you use Bucket Connect, we may collect information through Google AdMob,
                        including:
                    </p>
                    <ul>
                        <li><strong>Personal information:</strong> Device ID, IP address, and other device-specific information.</li>
                        <li><strong>Non-personal information:</strong> Aggregated user data, device type, operating system, and user behaviour data that cannot be used to identify you personally.</li>
                    </ul>
                </article>

                <article class="bc-policy-block" id="collected-information">
                    <h2>How we use collected information</h2>
                    <p>The information collected through Google AdMob is used for:</p>
                    <ul>
                        <li><strong>Serving ads:</strong> Display personalised ads that are relevant to you.</li>
                        <li><strong>Improving ad quality and relevance:</strong> Analyse and understand how ads perform to enhance their quality and relevance.</li>
                        <li><strong>Analytics and reporting:</strong> Provide aggregated reporting to understand ad performance and user engagement.</li>
                    </ul>
                </article>

                <article class="bc-policy-block" id="data-security">
                    <h2>Data security</h2>
                    <p>
                        We employ reasonable measures to protect your information from unauthorised
                        access, use, or disclosure. However, no internet or mobile application can
                        be entirely secure, and we cannot guarantee the absolute security of your
                        information.
                    </p>
                </article>

                <article class="bc-policy-block" id="account-deletion">
                    <h2>Account deletion</h2>
                    <p>
                        If you would like to delete your account and all data linked to it, use the
                        "Delete Account" button in the account menu.
                    </p>
                </article>

                <article class="bc-policy-block" id="updates">
                    <h2>Updates to this policy</h2>
                    <p>
                        We may update this Privacy Policy from time to time. Any changes will be
                        reflected with a new effective date at the top of this document.
                    </p>
                </article>

                <article class="bc-policy-block" id="contact">
                    <h2>Contact</h2>
                    <p>
                        If you have any questions or concerns about our Privacy Policy, please
                        contact us at <a href="mailto:bucketconnectapp@gmail.com">bucketconnectapp@gmail.com</a>.
                    </p>
                    <p>
                        By using Bucket Connect, you acknowledge that you have read and understood
                        this Privacy Policy and agree to its terms.
                    </p>
                </article>

            </div>
        </div>
    </section>

    <footer class="bc-footer">
        <div class="bc-container bc-footer-inner">
            <nav aria-label="Legal">
                <h3>Legal</h3>
                <ul>
                    <li><NavLink href="/BucketConnect/PrivacyPolicy">Privacy Policy</NavLink></li>
                </ul>
            </nav>
            <p class="bc-footer-copy">&copy; @DateTime.Now.Year Kenyon Dev Labs</p>
        </div>
    </footer>

</div>

<style>
    :root {
        --bc-brand: #097969;
        --bc-brand-dark: #065f54;
        --bc-brand-light: #43d8c6;
        --bc-muted: #f0f7f6;
        --bc-text: #1a2e2b;
        --bc-text-soft: #4a6360;
        --bc-max: 1080px;
        --bc-radius: 1rem;
    }

    html, body {
        overflow-x: clip;
        font-family: var(--font-sans, 'Plus Jakarta Sans', system-ui, sans-serif);
    }

    body {
        background: #fff;
        color: var(--bc-text);
    }

    .bc-page { overflow-x: clip; }

    .bc-section {
        width: 100vw;
        margin-left: calc(50% - 50vw);
        margin-right: calc(50% - 50vw);
        padding: 4rem 1.5rem;
        box-sizing: border-box;
        border-top: 1px solid rgba(9, 121, 105, 0.1);
    }

    .bc-section-muted { background: var(--bc-muted); }

    .bc-container {
        max-width: var(--bc-max);
        margin: 0 auto;
    }

    .bc-section-head {
        max-width: 42rem;
        margin: 0 auto 2.5rem;
        text-align: center;
    }

    .bc-section-head h2 {
        margin: 0;
        font-size: clamp(1.6rem, 3vw, 2.1rem);
        font-weight: 800;
        letter-spacing: -0.02em;
        line-height: 1.15;
        color: var(--bc-text);
    }

        .bc-section-head h2::after {
            content: "";
            display: block;
            width: 3rem;
            height: 3px;
            margin: 1rem auto 0;
            background: var(--bc-brand);
            border-radius: 999px;
        }

    .bc-section-lead {
        margin: 1.15rem 0 0;
        color: var(--bc-text-soft);
        font-size: 1.05rem;
        line-height: 1.65;
    }

    .bc-hero {
        border-top: none;
        padding: 3rem 1.5rem 5rem;
        background: linear-gradient(160deg, var(--bc-brand) 0%, var(--bc-brand-dark) 100%);
        position: relative;
        color: #fff;
    }

        .bc-hero::after {
            content: "";
            position: absolute;
            left: 0; right: 0; bottom: -1px;
            height: 64px;
            background: var(--bc-muted);
            clip-path: ellipse(55% 100% at 50% 100%);
        }

    .bc-hero-compact { padding-bottom: 4.5rem; }

    .bc-hero-grid {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 2.5rem;
        flex-wrap: wrap;
        position: relative;
        z-index: 1;
    }

    .bc-hero-copy { flex: 1 1 360px; }

    .bc-eyebrow {
        display: inline-block;
        margin-bottom: 0.75rem;
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--bc-brand);
    }

    .bc-eyebrow-light { color: var(--bc-brand-light); }

    .bc-hero-copy h1 {
        margin: 0 0 0.85rem;
        font-size: clamp(2rem, 4.5vw, 2.75rem);
        font-weight: 800;
        letter-spacing: -0.03em;
        line-height: 1.1;
        color: #fff;
    }

    .bc-hero-copy p {
        margin: 0;
        max-width: 32rem;
        font-size: 1.08rem;
        line-height: 1.65;
        color: rgba(255, 255, 255, 0.9);
    }

    .bc-effective-date {
        display: inline-block;
        margin-top: 1.15rem !important;
        padding: 0.35rem 0.85rem;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.15);
        font-size: 0.88rem !important;
        font-weight: 700;
        color: var(--bc-brand-light) !important;
    }

    .bc-hero-visual {
        flex: 1 1 240px;
        display: flex;
        justify-content: center;
    }

        .bc-hero-visual img {
            width: 100%;
            max-width: 200px;
            filter: drop-shadow(0 16px 32px rgba(0, 0, 0, 0.25));
        }

    .bc-policy-blocks {
        max-width: 48rem;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        gap: 1.15rem;
    }

    .bc-policy-block {
        padding: 1.5rem 1.75rem;
        background: #fff;
        border: 1px solid rgba(9, 121, 105, 0.14);
        border-radius: var(--bc-radius);
        box-shadow: 0 4px 16px rgba(9, 121, 105, 0.06);
    }

        .bc-policy-block h2 {
            margin: 0 0 0.85rem;
            font-size: 1.15rem;
            font-weight: 800;
            padding-bottom: 0.65rem;
            border-bottom: 2px solid rgba(9, 121, 105, 0.15);
            color: var(--bc-text);
        }

        .bc-policy-block p {
            margin: 0 0 0.85rem;
            color: var(--bc-text-soft);
            line-height: 1.7;
            font-size: 1rem;
        }

            .bc-policy-block p:last-child { margin-bottom: 0; }

        .bc-policy-block ul {
            margin: 0;
            padding-left: 1.25rem;
            color: var(--bc-text-soft);
            line-height: 1.65;
        }

        .bc-policy-block li { margin-bottom: 0.4rem; }

        .bc-policy-block a {
            color: var(--bc-brand-dark);
            font-weight: 600;
        }

    .bc-footer {
        width: 100vw;
        margin-left: calc(50% - 50vw);
        margin-right: calc(50% - 50vw);
        background: var(--bc-brand-dark);
        color: #fff;
        padding: 2.5rem 1.5rem;
        text-align: center;
    }

    .bc-footer-inner nav h3 {
        margin: 0 0 0.5rem;
        font-size: 0.85rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        opacity: 0.7;
    }

    .bc-footer-inner ul {
        list-style: none;
        padding: 0;
        margin: 0 0 1.25rem;
    }

        .bc-footer-inner ul a {
            color: #fff;
            text-decoration: none;
            font-weight: 600;
        }

            .bc-footer-inner ul a:hover { opacity: 0.75; }

    .bc-footer-copy {
        margin: 0;
        font-size: 0.92rem;
        opacity: 0.75;
    }

    @@media (max-width: 760px) {
        .bc-section { padding: 3rem 1.25rem; }
        .bc-hero-grid { flex-direction: column; text-align: center; }
        .bc-hero-copy p { margin-left: auto; margin-right: auto; }
        .bc-policy-block { padding: 1.25rem 1.35rem; }
    }
</style>

@code {
    private const int SectionCount = 8;
}
