@page "/BucketConnect"

@using System.Globalization
@using KenyonDevLabs.Models
@using KenyonDevLabs.Services
@inject HttpClient Http
@inject NewsFileService NewsData
@inject NavigationManager Nav

<PageTitle>Bucket Connect</PageTitle>

<BucketConnectHeader />

<div class="bc-page">

    <!-- HERO -->
    <section class="bc-section bc-hero">
        <div class="bc-container bc-hero-grid">
            <div class="bc-hero-copy">
                <span class="bc-eyebrow">Bucket list app</span>
                <h1>Track your dreams.<br />Tick them off.</h1>
                <p>
                    Create bucket lists, share progress with friends, and discover what the
                    community is planning - all in one beautifully simple app.
                </p>
                <a href="https://apps.apple.com/gb/app/bucket-connect/id6503246436"
                   target="_blank"
                   rel="noopener noreferrer"
                   class="bc-appstore-btn">
                    <img src="images/App Store Button.png" alt="Download on the App Store" />
                </a>
            </div>
            <div class="bc-hero-visual">
                <img src="images/Bucket Connect/icons/Icon Wide.png" alt="Bucket Connect app preview" />
            </div>
        </div>
    </section>

    <!-- ABOUT -->
    <section class="bc-section bc-section-white" aria-labelledby="info-title">
        <div class="bc-container">
            <header class="bc-section-head">
                <span class="bc-eyebrow">About the app</span>
                <h2 id="info-title">Dream big, tick things off</h2>
                <p class="bc-section-lead">
                    Bucket Connect helps you organise life's goals - from travel and adventures
                    to personal milestones - and stay motivated every step of the way.
                </p>
            </header>
        </div>
    </section>

    <!-- HOW IT WORKS -->
    <section class="bc-section bc-section-muted" aria-labelledby="about-title">
        <div class="bc-container">
            <header class="bc-section-head">
                <span class="bc-eyebrow">Features</span>
                <h2 id="about-title">How it works</h2>
            </header>

            <div class="bc-feature-stack">
                <article class="bc-feature-card">
                    <div class="bc-feature-media">
                        <img src="images/Bucket Connect/Cover 2.png" alt="Create your bucket list" loading="lazy" />
                    </div>
                    <div class="bc-feature-body">
                        <h3>Create your ultimate bucket list</h3>
                        <p>Follow your dreams and build lists for every goal you want to reach.</p>
                        <ul>
                            <li>Create different lists for different goals</li>
                            <li>Tick off events to show their completion</li>
                            <li>See your progress for each list</li>
                        </ul>
                    </div>
                </article>

                <article class="bc-feature-card bc-feature-card-reverse">
                    <div class="bc-feature-media">
                        <img src="images/portfolio/Bucket Connect Screenshot.png" alt="Share lists with friends" loading="lazy" />
                    </div>
                    <div class="bc-feature-body">
                        <h3>Share with friends</h3>
                        <p>Keep the people who matter involved in your journey.</p>
                        <ul>
                            <li>Share lists with friends and family</li>
                            <li>See what others are working toward</li>
                            <li>Stay motivated together</li>
                        </ul>
                    </div>
                </article>

                <article class="bc-feature-card">
                    <div class="bc-feature-media">
                        <img src="images/Bucket Connect/Cover 3.png" alt="Community inspiration" loading="lazy" />
                    </div>
                    <div class="bc-feature-body">
                        <h3>Get inspired by the community</h3>
                        <p>Discover public bucket lists and find your next big idea.</p>
                        <ul>
                            <li>Browse community lists for inspiration</li>
                            <li>Find new goals you had not thought of</li>
                            <li>See what is popular around the world</li>
                        </ul>
                    </div>
                </article>
            </div>
        </div>
    </section>

    <!-- APP FUNCTIONALITY -->
    <section class="bc-section bc-section-tint" aria-labelledby="features-title">
        <div class="bc-container">
            <header class="bc-section-head">
                <span class="bc-eyebrow">At a glance</span>
                <h2 id="features-title">App functionality</h2>
            </header>

            <div class="bc-icon-grid">
                <article class="bc-icon-card">
                    <div class="bc-icon-circle" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M9 11l3 3L22 4" />
                            <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" />
                        </svg>
                    </div>
                    <h3>Track your goals</h3>
                    <p>Organise bucket list items into lists and mark them complete as you go.</p>
                </article>
                <article class="bc-icon-card">
                    <div class="bc-icon-circle" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
                            <circle cx="9" cy="7" r="4" />
                            <path d="M22 21v-2a4 4 0 0 0-3-3.87" />
                            <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                        </svg>
                    </div>
                    <h3>Connect with friends</h3>
                    <p>Share lists, compare progress, and cheer each other on.</p>
                </article>
                <article class="bc-icon-card">
                    <div class="bc-icon-circle" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <polygon points="12 2 15 10 23 10 17 14 19 22 12 17 5 22 7 14 1 10 9 10 12 2" />
                        </svg>
                    </div>
                    <h3>Earn achievements</h3>
                    <p>Unlock trophies and milestones as you complete items and stay engaged.</p>
                </article>
            </div>
        </div>
    </section>

    <!-- HIGH ACHIEVER -->
    <section class="bc-section bc-section-brand" aria-labelledby="achiever-title">
        <div class="bc-container">
            <header class="bc-section-head bc-section-head-light">
                <span class="bc-eyebrow bc-eyebrow-light">Stay motivated</span>
                <h2 id="achiever-title">Be a high achiever</h2>
                <p class="bc-section-lead bc-section-lead-light">
                    Bucket Connect rewards progress - not just the finish line.
                </p>
            </header>

            <div class="bc-achiever-grid">
                <article class="bc-achiever-card">
                    <div class="bc-achiever-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" width="44" height="44" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M8 21h8M12 17v4M7 4h10v3a5 5 0 0 1-5 5 5 5 0 0 1-5-5V4z" />
                            <path d="M7 7H5a3 3 0 0 0 3 3M17 7h2a3 3 0 0 1-3 3" />
                        </svg>
                    </div>
                    <h3>Trophies &amp; milestones</h3>
                    <p>Unlock trophies for creating lists, completing items, and engaging with friends.</p>
                </article>
                <article class="bc-achiever-card">
                    <div class="bc-achiever-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" width="44" height="44" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M3 3v18h18" />
                            <rect x="6" y="12" width="3" height="6" rx="1" />
                            <rect x="11" y="9" width="3" height="9" rx="1" />
                            <rect x="16" y="6" width="3" height="12" rx="1" />
                        </svg>
                    </div>
                    <h3>See your progress</h3>
                    <p>Track completion by list and overall with simple, motivating visuals.</p>
                </article>
                <article class="bc-achiever-card">
                    <div class="bc-achiever-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" width="44" height="44" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <polygon points="12 2 15 10 23 10 17 14 19 22 12 17 5 22 7 14 1 10 9 10 12 2" />
                        </svg>
                    </div>
                    <h3>Celebrate wins</h3>
                    <p>Share achievements with friends and keep each other motivated.</p>
                </article>
            </div>
        </div>
    </section>

    <!-- PATCH NOTES -->
    <section class="bc-section bc-section-muted bc-news-section" aria-labelledby="news-title">
        <div class="bc-container">
            <header class="bc-section-head">
                <span class="bc-eyebrow">Updates</span>
                <h2 id="news-title">Patch notes</h2>
                <p class="bc-section-lead">Recent releases and fixes for Bucket Connect.</p>
            </header>

            @if (BucketConnectNotes.Count == 0)
            {
                <p class="bc-news-empty">No patch notes yet - check back soon.</p>
            }
            else
            {
                <div class="bc-news-list">
                    @foreach (var item in BucketConnectNotes.Take(3))
                    {
                        <article class="bc-news-card">
                            <div class="bc-news-date"
                                 style="background: linear-gradient(180deg, @item.TopColour, @item.BottomColour); color: @item.DateTextColour;">
                                <span class="day">@item.Date.ToString("dd")</span>
                                <span class="mon">@item.Date.ToString("MMM", CultureInfo.InvariantCulture)</span>
                            </div>
                            <div class="bc-news-body">
                                <div class="bc-news-title-row">
                                    @if (!string.IsNullOrWhiteSpace(item.IconUrl))
                                    {
                                        <img class="bc-news-icon" src="@item.IconUrl" alt="" />
                                    }
                                    <h3>@item.Title</h3>
                                </div>
                                <p>@TruncateSummary(item.Summary)</p>
                            </div>
                        </article>
                    }
                </div>

                <div class="bc-news-actions">
                    <NavLink href="/BucketConnect/PatchNotes" class="bc-news-button">View all patch notes</NavLink>
                </div>
            }
        </div>
    </section>

    <footer class="bc-footer">
        <div class="bc-container bc-footer-inner">
            <nav aria-label="Legal">
                <h3>Legal</h3>
                <ul>
                    <li><NavLink href="/BucketConnect/PrivacyPolicy">Privacy Policy</NavLink></li>
                </ul>
            </nav>
            <p class="bc-footer-copy">&copy; @DateTime.Now.Year Kenyon Dev Labs</p>
        </div>
    </footer>

</div>

<style>
    :root {
        --bc-brand: #097969;
        --bc-brand-dark: #065f54;
        --bc-brand-light: #43d8c6;
        --bc-muted: #f0f7f6;
        --bc-tint: #dff5f0;
        --bc-text: #1a2e2b;
        --bc-text-soft: #4a6360;
        --bc-max: 1080px;
        --bc-radius: 1rem;
        --bc-shadow: 0 8px 32px rgba(6, 95, 84, 0.1);
    }

    html, body {
        overflow-x: clip;
        font-family: var(--font-sans, 'Plus Jakarta Sans', system-ui, sans-serif);
    }

    body {
        background: #fff;
        color: var(--bc-text);
    }

    .bc-page {
        overflow-x: clip;
    }

    /* Full-width section bands */
    .bc-section {
        width: 100vw;
        margin-left: calc(50% - 50vw);
        margin-right: calc(50% - 50vw);
        padding: 4.5rem 1.5rem;
        box-sizing: border-box;
        border-top: 1px solid rgba(9, 121, 105, 0.1);
    }

    .bc-section-white {
        background: #fff;
    }

    .bc-section-muted {
        background: var(--bc-muted);
        border-top-color: rgba(9, 121, 105, 0.14);
    }

    .bc-section-tint {
        background: var(--bc-tint);
        border-top-color: rgba(9, 121, 105, 0.16);
    }

    .bc-section-brand {
        background: linear-gradient(160deg, var(--bc-brand) 0%, var(--bc-brand-dark) 100%);
        border-top: none;
        color: #fff;
    }

    .bc-container {
        max-width: var(--bc-max);
        margin: 0 auto;
    }

    /* Shared section headers */
    .bc-section-head {
        text-align: center;
        max-width: 40rem;
        margin: 0 auto 3rem;
    }

    .bc-section-head-light {
        color: #fff;
    }

    .bc-eyebrow {
        display: inline-block;
        margin-bottom: 0.75rem;
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--bc-brand);
    }

    .bc-eyebrow-light {
        color: var(--bc-brand-light);
    }

    .bc-section-head h2 {
        margin: 0;
        font-size: clamp(1.75rem, 3.5vw, 2.35rem);
        font-weight: 800;
        letter-spacing: -0.03em;
        line-height: 1.15;
        color: var(--bc-text);
    }

    .bc-section-head-light h2 {
        color: #fff;
    }

    .bc-section-head h2::after {
        content: "";
        display: block;
        width: 3rem;
        height: 3px;
        margin: 1rem auto 0;
        background: var(--bc-brand);
        border-radius: 999px;
    }

    .bc-section-head-light h2::after {
        background: var(--bc-brand-light);
    }

    .bc-section-lead {
        margin: 1.25rem 0 0;
        color: var(--bc-text-soft);
        font-size: 1.08rem;
        line-height: 1.7;
    }

    .bc-section-lead-light {
        color: rgba(255, 255, 255, 0.88);
    }

    /* Hero */
    .bc-hero {
        border-top: none;
        padding: 3rem 1.5rem 5.5rem;
        background:
            linear-gradient(135deg, rgba(6, 47, 42, 0.88) 0%, rgba(9, 121, 105, 0.75) 100%),
            url("images/Bucket Connect/Main_Background.jpg") center/cover no-repeat;
        position: relative;
    }

        .bc-hero::after {
            content: "";
            position: absolute;
            left: 0;
            right: 0;
            bottom: -1px;
            height: 64px;
            background: #fff;
            clip-path: ellipse(55% 100% at 50% 100%);
        }

    .bc-hero-grid {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 3rem;
        flex-wrap: wrap;
        position: relative;
        z-index: 1;
    }

    .bc-hero-copy {
        flex: 1 1 380px;
        color: #fff;
    }

        .bc-hero-copy .bc-eyebrow {
            color: var(--bc-brand-light);
        }

        .bc-hero-copy h1 {
            margin: 0 0 1.25rem;
            font-size: clamp(2rem, 4.5vw, 3rem);
            font-weight: 800;
            letter-spacing: -0.03em;
            line-height: 1.1;
        }

        .bc-hero-copy p {
            margin: 0 0 1.75rem;
            max-width: 30rem;
            font-size: 1.1rem;
            line-height: 1.7;
            color: rgba(255, 255, 255, 0.9);
        }

    .bc-appstore-btn {
        display: inline-block;
        transition: transform 0.2s ease;
    }

        .bc-appstore-btn:hover {
            transform: translateY(-2px);
        }

        .bc-appstore-btn img {
            height: 48px;
            width: auto;
            display: block;
        }

    .bc-hero-visual {
        flex: 1 1 380px;
        display: flex;
        justify-content: center;
    }

        .bc-hero-visual img {
            width: 100%;
            max-width: 420px;
            filter: drop-shadow(0 24px 48px rgba(0, 0, 0, 0.35));
        }

    /* Feature cards stack */
    .bc-feature-stack {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .bc-feature-card {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0;
        align-items: stretch;
        background: #fff;
        border-radius: var(--bc-radius);
        border: 1px solid rgba(9, 121, 105, 0.12);
        box-shadow: var(--bc-shadow);
        overflow: hidden;
    }

    .bc-feature-card-reverse {
        direction: rtl;
    }

        .bc-feature-card-reverse > * {
            direction: ltr;
        }

    .bc-feature-media img {
        width: 100%;
        height: 100%;
        min-height: 260px;
        object-fit: cover;
        display: block;
    }

    .bc-feature-body {
        padding: 2rem 2.25rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

        .bc-feature-body h3 {
            margin: 0 0 0.65rem;
            font-size: 1.35rem;
            font-weight: 800;
            color: var(--bc-brand-dark);
        }

        .bc-feature-body p {
            margin: 0 0 1rem;
            color: var(--bc-text-soft);
            line-height: 1.65;
        }

        .bc-feature-body ul {
            margin: 0;
            padding-left: 1.2rem;
            color: var(--bc-text-soft);
        }

            .bc-feature-body li {
                margin: 0.35rem 0;
                line-height: 1.5;
            }

    /* Icon grid */
    .bc-icon-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.25rem;
    }

    .bc-icon-card {
        background: #fff;
        border: 1px solid rgba(9, 121, 105, 0.14);
        border-radius: var(--bc-radius);
        padding: 2rem 1.5rem;
        text-align: center;
        box-shadow: 0 4px 16px rgba(9, 121, 105, 0.06);
        transition: transform 0.18s ease, box-shadow 0.18s ease;
    }

        .bc-icon-card:hover {
            transform: translateY(-4px);
            box-shadow: var(--bc-shadow);
        }

    .bc-icon-circle {
        width: 60px;
        height: 60px;
        margin: 0 auto 1.1rem;
        display: grid;
        place-items: center;
        border-radius: 50%;
        background: rgba(9, 121, 105, 0.1);
        color: var(--bc-brand);
    }

        .bc-icon-circle svg {
            width: 28px;
            height: 28px;
        }

    .bc-icon-card h3 {
        margin: 0 0 0.5rem;
        font-size: 1.1rem;
        font-weight: 800;
        color: var(--bc-brand-dark);
    }

    .bc-icon-card p {
        margin: 0;
        color: var(--bc-text-soft);
        line-height: 1.6;
        font-size: 0.98rem;
    }

    /* Achiever */
    .bc-achiever-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.25rem;
    }

    .bc-achiever-card {
        background: rgba(255, 255, 255, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.22);
        border-radius: var(--bc-radius);
        padding: 2rem 1.5rem;
        text-align: center;
        backdrop-filter: blur(4px);
        transition: background 0.18s ease, transform 0.18s ease;
    }

        .bc-achiever-card:hover {
            background: rgba(255, 255, 255, 0.15);
            transform: translateY(-3px);
        }

    .bc-achiever-icon {
        margin-bottom: 1rem;
        color: var(--bc-brand-light);
    }

    .bc-achiever-card h3 {
        margin: 0 0 0.5rem;
        font-size: 1.1rem;
        font-weight: 800;
    }

    .bc-achiever-card p {
        margin: 0;
        font-size: 0.98rem;
        line-height: 1.6;
        color: rgba(255, 255, 255, 0.88);
    }

    /* News */
    .bc-news-section .bc-section-head {
        margin-bottom: 2rem;
    }

    .bc-news-empty {
        text-align: center;
        color: var(--bc-text-soft);
        margin: 0;
    }

    .bc-news-list {
        max-width: 52rem;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .bc-news-card {
        display: grid;
        grid-template-columns: 5.5rem 1fr;
        align-items: stretch;
        background: #fff;
        border: 1px solid rgba(9, 121, 105, 0.12);
        border-radius: var(--bc-radius);
        box-shadow: 0 4px 16px rgba(9, 121, 105, 0.06);
        overflow: hidden;
        transition: transform 0.18s ease, box-shadow 0.18s ease;
    }

        .bc-news-card:hover {
            transform: translateY(-2px);
            box-shadow: var(--bc-shadow);
        }

    .bc-news-date {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 0.85rem 0.5rem;
        font-weight: 800;
        text-align: center;
    }

        .bc-news-date .day {
            font-size: 1.5rem;
            line-height: 1;
        }

        .bc-news-date .mon {
            font-size: 0.8rem;
            opacity: 0.9;
            letter-spacing: 0.06em;
            text-transform: uppercase;
            margin-top: 0.15rem;
        }

    .bc-news-body {
        padding: 1rem 1.25rem 1.1rem 1.25rem;
        color: var(--bc-text);
    }

    .bc-news-title-row {
        display: flex;
        align-items: center;
        gap: 0.65rem;
        margin-bottom: 0.45rem;
    }

    .bc-news-icon {
        width: 1.75rem;
        height: 1.75rem;
        object-fit: contain;
        flex-shrink: 0;
    }

    .bc-news-title-row h3 {
        margin: 0;
        font-size: 1.05rem;
        font-weight: 700;
        line-height: 1.3;
        color: var(--bc-text);
    }

    .bc-news-body p {
        margin: 0;
        color: var(--bc-text-soft);
        font-size: 0.95rem;
        line-height: 1.6;
    }

    .bc-news-actions {
        margin-top: 2rem;
        text-align: center;
    }

    .bc-news-button {
        display: inline-block;
        padding: 0.85rem 1.5rem;
        border-radius: 999px;
        border: 1px solid var(--bc-brand);
        background: transparent;
        color: var(--bc-brand-dark);
        text-decoration: none;
        font-size: 1rem;
        font-weight: 600;
        transition: background 0.15s ease, color 0.15s ease;
    }

        .bc-news-button:hover {
            background: var(--bc-brand);
            color: #fff;
        }

    /* Footer */
    .bc-footer {
        width: 100vw;
        margin-left: calc(50% - 50vw);
        margin-right: calc(50% - 50vw);
        background: var(--bc-brand-dark);
        color: #fff;
        padding: 2.5rem 1.5rem;
        text-align: center;
    }

    .bc-footer-inner nav h3 {
        margin: 0 0 0.5rem;
        font-size: 0.85rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        opacity: 0.7;
    }

    .bc-footer-inner ul {
        list-style: none;
        padding: 0;
        margin: 0 0 1.25rem;
    }

        .bc-footer-inner ul a {
            color: #fff;
            text-decoration: none;
            font-weight: 600;
        }

            .bc-footer-inner ul a:hover {
                opacity: 0.75;
            }

    .bc-footer-copy {
        margin: 0;
        font-size: 0.9rem;
        opacity: 0.6;
    }

    @@media (max-width: 900px) {
        .bc-icon-grid,
        .bc-achiever-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 768px) {
        .bc-section {
            padding: 3.5rem 1.25rem;
        }

        .bc-hero {
            padding-bottom: 4.5rem;
        }

        .bc-hero-grid {
            flex-direction: column;
            text-align: center;
        }

        .bc-hero-copy p {
            margin-left: auto;
            margin-right: auto;
