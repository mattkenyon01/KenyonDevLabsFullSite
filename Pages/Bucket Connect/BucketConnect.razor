@code {
    private List<NewsItem> BucketConnectNotes = new();

    protected override async Task OnInitializedAsync()
    {
        if (Http.BaseAddress is null)
            Http.BaseAddress = new Uri(Nav.BaseUri);

        var items = await NewsData.GetNewsAsync("BucketConnectPatchNotes.json");
        BucketConnectNotes = items
            .OrderByDescending(n => n.Date)
            .ToList();
    }

    private static string TruncateSummary(string? summary, int maxLength = 140)
    {
        if (string.IsNullOrWhiteSpace(summary))
            return string.Empty;

        var plain = System.Text.RegularExpressions.Regex.Replace(summary, "<.*?>", string.Empty);
        return plain.Length <= maxLength ? plain : $"{plain[..maxLength].TrimEnd()}…";
    }
}
