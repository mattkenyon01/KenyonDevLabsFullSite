@code {
    private List<NewsItem> GirlsWhoWalkNotes = new();

    protected override async Task OnInitializedAsync()
    {
        if (Http.BaseAddress is null)
            Http.BaseAddress = new Uri(Nav.BaseUri);

        var items = await NewsData.GetNewsAsync("BucketConnectPatchNotes.json");
        GirlsWhoWalkNotes = items
            // optional: keep only items tagged correctly
            .Where(n => n.Tags?.Contains("Girls Who Connect") == true)
            .OrderByDescending(n => n.Date)
            .ToList();
    }
}

