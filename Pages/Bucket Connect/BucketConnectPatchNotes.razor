@page "/BucketConnect/PatchNotes"
@using System.Globalization
@using KenyonDevLabs.Models
@using KenyonDevLabs.Services
@inject NewsFileService NewsData

<PageTitle>Patch Notes - Bucket Connect</PageTitle>

<BucketConnectHeader />

<div class="bc-page">

    <section class="bc-section bc-hero bc-hero-compact">
        <div class="bc-container bc-hero-grid">
            <div class="bc-hero-copy">
                <span class="bc-eyebrow bc-eyebrow-light">Bucket Connect</span>
                <h1>Patch notes</h1>
                <p>
                    Every release, improvement, and fix for Bucket Connect -
                    from the original launch through the latest update.
                </p>
            </div>
            <div class="bc-hero-visual">
                <img src="images/Bucket Connect/icons/1.1.png" alt="Bucket Connect app icon" />
            </div>
        </div>
    </section>

    <section class="bc-section bc-section-white bc-news-section" aria-labelledby="news-title">
        <div class="bc-container">
            <header class="bc-section-head">
                <span class="bc-eyebrow">Updates</span>
                <h2 id="news-title">All patch notes</h2>
                <p class="bc-section-lead">@Items.Count release@(Items.Count == 1 ? "" : "s") published.</p>
            </header>

            @if (Items.Count == 0)
            {
                <p class="bc-news-empty">No patch notes yet - check back soon.</p>
            }
            else
            {
                <div class="bc-news-list">
                    @{
                        var lastYear = (int?)null;
                    }
                    @foreach (var item in Items)
                    {
                        var year = item.Date.Year;
                        if (lastYear != year)
                        {
                            <div class="bc-year-divider @(lastYear is null ? "bc-year-divider-first" : "")">
                                <span>@year</span>
                            </div>
                            lastYear = year;
                        }

                        <article class="bc-news-card">
                            <div class="bc-news-body">
                                <div class="bc-news-title-row">
                                    <div class="bc-news-title-left">
                                        @if (!string.IsNullOrWhiteSpace(item.IconUrl))
                                        {
                                            <img class="bc-news-icon" src="@item.IconUrl" alt="" />
                                        }
                                        <h3>@item.Title</h3>
                                    </div>
                                    <div class="bc-news-date"
                                         style="background: linear-gradient(135deg, @GetTop(item), @GetBottom(item)); color: @GetDateText(item);">
                                        <span class="day">@item.Date.ToString("dd")</span>
                                        <span class="mon">@item.Date.ToString("MMM", CultureInfo.InvariantCulture)</span>
                                        <span class="yr">@item.Date.ToString("yyyy")</span>
                                    </div>
                                </div>
                                <p>@((MarkupString)item.Summary)</p>
                            </div>
                        </article>
                    }
                </div>
            }
        </div>
    </section>

    <footer class="bc-footer">
        <div class="bc-container bc-footer-inner">
            <nav aria-label="Legal">
                <h3>Legal</h3>
                <ul>
                    <li><NavLink href="/BucketConnect/PrivacyPolicy">Privacy Policy</NavLink></li>
                </ul>
            </nav>
            <p class="bc-footer-copy">&copy; @DateTime.Now.Year Kenyon Dev Labs</p>
        </div>
    </footer>

</div>

<style>
    :root {
        --bc-brand: #097969;
        --bc-brand-dark: #065f54;
        --bc-brand-light: #43d8c6;
        --bc-muted: #f0f7f6;
        --bc-text: #1a2e2b;
        --bc-text-soft: #4a6360;
        --bc-max: 1080px;
        --bc-radius: 1rem;
        --bc-shadow: 0 8px 32px rgba(6, 95, 84, 0.1);
    }

    html, body {
        overflow-x: clip;
        font-family: var(--font-sans, 'Plus Jakarta Sans', system-ui, sans-serif);
    }

    body {
        background: #fff;
        color: var(--bc-text);
    }

    .bc-page {
        overflow-x: clip;
    }

    .bc-section {
        width: 100vw;
        margin-left: calc(50% - 50vw);
        margin-right: calc(50% - 50vw);
        padding: 4rem 1.5rem;
        box-sizing: border-box;
        border-top: 1px solid rgba(9, 121, 105, 0.1);
    }

    .bc-section-white {
        background: #fff;
    }

    .bc-container {
        max-width: var(--bc-max);
        margin: 0 auto;
    }

    .bc-section-head {
        max-width: 42rem;
        margin: 0 auto 2.5rem;
        text-align: center;
    }

    .bc-eyebrow {
        display: inline-block;
        margin-bottom: 0.75rem;
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--bc-brand);
    }

    .bc-eyebrow-light {
        color: var(--bc-brand-light);
    }

    .bc-section-head h2 {
        margin: 0;
        font-size: clamp(1.6rem, 3vw, 2.1rem);
        font-weight: 800;
        letter-spacing: -0.02em;
        line-height: 1.15;
        color: var(--bc-text);
    }

        .bc-section-head h2::after {
            content: "";
            display: block;
            width: 3rem;
            height: 3px;
            margin: 1rem auto 0;
            background: var(--bc-brand);
            border-radius: 999px;
        }

    .bc-section-lead {
        margin: 1.15rem 0 0;
        color: var(--bc-text-soft);
        font-size: 1.05rem;
        line-height: 1.65;
    }

    .bc-hero {
        border-top: none;
        padding: 3rem 1.5rem 5.5rem;
        background: linear-gradient(160deg, var(--bc-brand) 0%, var(--bc-brand-dark) 100%);
        position: relative;
        color: #fff;
    }

        .bc-hero::after {
            content: "";
            position: absolute;
            left: 0;
            right: 0;
            bottom: -1px;
            height: 64px;
            background: #fff;
            clip-path: ellipse(55% 100% at 50% 100%);
        }

    .bc-section.bc-hero.bc-hero-compact {
        padding-bottom: 1.25rem;
    }

    .bc-hero + .bc-section {
        padding-top: 1.75rem;
    }

    .bc-hero-grid {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 2.5rem;
        flex-wrap: wrap;
        position: relative;
        z-index: 1;
    }

    .bc-hero-copy {
        flex: 1 1 360px;
    }

    .bc-hero-copy h1 {
        margin: 0 0 1rem;
        font-size: clamp(2rem, 4.5vw, 2.75rem);
        font-weight: 800;
        letter-spacing: -0.03em;
        line-height: 1.1;
        color: #fff;
    }

    .bc-hero-copy p {
        margin: 0;
        max-width: 32rem;
        font-size: 1.08rem;
        line-height: 1.65;
        color: rgba(255, 255, 255, 0.9);
    }

    .bc-hero-visual {
        flex: 1 1 280px;
        display: flex;
        justify-content: center;
        align-items: center;
    }

        .bc-hero-visual img {
            width: 100%;
            max-width: 280px;
            height: auto;
            object-fit: contain;
            filter: drop-shadow(0 16px 32px rgba(0, 0, 0, 0.25));
        }

    .bc-news-empty {
        text-align: center;
        color: var(--bc-text-soft);
        margin: 0;
    }

    .bc-news-list {
        max-width: 52rem;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .bc-year-divider {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin: 0.75rem 0 0.25rem;
        font-size: 1.35rem;
        font-weight: 700;
        letter-spacing: 0.04em;
    }

        .bc-year-divider-first {
            margin-top: 0;
        }

        .bc-year-divider::before,
        .bc-year-divider::after {
            content: "";
            flex: 1;
            height: 2px;
            background: rgba(9, 121, 105, 0.35);
            border-radius: 999px;
        }

        .bc-year-divider span {
            flex-shrink: 0;
            padding: 0 0.25rem;
            color: var(--bc-brand-dark);
        }

    .bc-news-card {
        display: block;
        background: #fff;
        border: 1px solid rgba(9, 121, 105, 0.12);
        border-radius: var(--bc-radius);
        box-shadow: 0 4px 16px rgba(9, 121, 105, 0.06);
        overflow: hidden;
        transition: transform 0.18s ease, box-shadow 0.18s ease;
    }

        .bc-news-card:hover {
            transform: translateY(-2px);
            box-shadow: var(--bc-shadow);
        }

    .bc-news-body {
        padding: 1.1rem 1.25rem 1.15rem;
        color: var(--bc-text);
    }

    .bc-news-title-row {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 0.85rem;
        margin-bottom: 0.55rem;
    }

    .bc-news-title-left {
        display: flex;
        align-items: center;
        gap: 0.65rem;
        min-width: 0;
        flex: 1;
    }

    .bc-news-date {
        display: flex;
        flex-direction: row;
        align-items: baseline;
        justify-content: center;
        gap: 0.35rem;
        flex-shrink: 0;
        padding: 0.35rem 0.65rem;
        border-radius: 999px;
        font-weight: 800;
        text-align: center;
        line-height: 1;
    }

        .bc-news-date .day {
            font-size: 0.95rem;
        }

        .bc-news-date .mon {
            font-size: 0.72rem;
            opacity: 0.95;
            letter-spacing: 0.06em;
            text-transform: uppercase;
        }

        .bc-news-date .yr {
            font-size: 0.72rem;
            opacity: 0.9;
        }

    .bc-news-icon {
        width: 1.75rem;
        height: 1.75rem;
        object-fit: contain;
        flex-shrink: 0;
        border-radius: 22%;
    }

    .bc-news-title-row h3 {
        margin: 0;
        font-size: 1.05rem;
        font-weight: 700;
        line-height: 1.3;
        color: var(--bc-text);
    }

    .bc-news-body p {
        margin: 0;
        color: var(--bc-text-soft);
        font-size: 0.95rem;
        line-height: 1.6;
    }

    .bc-footer {
        width: 100vw;
        margin-left: calc(50% - 50vw);
        margin-right: calc(50% - 50vw);
        background: var(--bc-brand-dark);
        color: #fff;
        padding: 2.5rem 1.5rem;
        text-align: center;
    }

    .bc-footer-inner nav h3 {
        margin: 0 0 0.5rem;
        font-size: 0.85rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        opacity: 0.7;
    }

    .bc-footer-inner ul {
        list-style: none;
        padding: 0;
        margin: 0 0 1.25rem;
    }

        .bc-footer-inner ul a {
            color: #fff;
            text-decoration: none;
            font-weight: 600;
        }

            .bc-footer-inner ul a:hover {
                opacity: 0.75;
            }

    .bc-footer-copy {
        margin: 0;
        font-size: 0.92rem;
        opacity: 0.75;
    }

    @@media (max-width: 768px) {
        .bc-section {
            padding: 3rem 1.25rem;
        }

        /* Beat .bc-section padding shorthand so the green band isn't tall under the copy */
        .bc-section.bc-hero {
            padding: 1.75rem 1.25rem 0;
        }

            .bc-section.bc-hero::after {
                height: 10px;
            }

        .bc-hero + .bc-section {
            padding-top: 1rem;
        }

        .bc-hero-grid {
            flex-direction: column-reverse;
            text-align: center;
            gap: 0.5rem;
        }

        .bc-hero-visual {
            margin: 0;
            padding: 0;
            width: min(110px, 28vw);
            height: min(110px, 28vw);
            overflow: hidden;
            flex: 0 0 auto;
            align-self: center;
        }

            .bc-hero-visual img {
                width: 100%;
                max-width: none;
                height: 100%;
                object-fit: contain;
                object-position: center;
            }

        .bc-hero-copy p {
            margin-left: auto;
            margin-right: auto;
        }
    }
</style>

@code {
    private List<NewsItem> Items = new();

    protected override async Task OnInitializedAsync()
    {
        const string file = "BucketConnectPatchNotes.json";

        try
        {
            var items = await NewsData.GetNewsAsync(file);
            Items = (items ?? new List<NewsItem>())
                .OrderByDescending(i => i.Date)
                .ToList();
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"[News] ERROR reading {file}: {ex.Message}");
            Items = new();
        }
    }

    private static string GetTop(NewsItem n)
        => !string.IsNullOrWhiteSpace(n.TopColour) ? n.TopColour! : "#097969";

    private static string GetBottom(NewsItem n)
        => !string.IsNullOrWhiteSpace(n.BottomColour) ? n.BottomColour! : "#43d8c6";

    private static string GetDateText(NewsItem n)
        => !string.IsNullOrWhiteSpace(n.DateTextColour) ? n.DateTextColour! : "#ffffff";
}
