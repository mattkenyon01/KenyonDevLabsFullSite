@page "/CastleClimbers/Characters"
@using System.Net.Http.Json
@using KenyonDevLabs.Models
@inject HttpClient Http
@inject NavigationManager Nav

<CastleClimbersHeader />
<PageTitle>Castle Climbers</PageTitle>

@if (Data is null)
{
    <p style="color:#fff;opacity:.7;padding:1rem">Loading…</p>
}
else
{
    <div class="cc-wrap" aria-label="Castle Climbers Character Groups">
        @foreach (var g in Data.Groups)
        {
            <h2 class="cc-group-title">@g.Group</h2>
            <section class="cc-grid" aria-label="@g.Group">
                @foreach (var c in g.Cards)
                {
                    <article class="cc-card"
                             style="@($"background:{c.Background}; border:10px solid {c.Outline}")">
                        <div class="cc-card-tl" style="color:@c.TextColor">@c.Tl</div>
                        <div class="cc-card-tr" style="color:@c.TextColor">
                            @if (c.IsCoins)
                            {
                                <span>@c.Price</span>
                                <img src="images/castle_climbers/Coin.png" alt="Coin" class="cc-coin-icon" />
                            }
                            else
                            {
                                <span>@c.Price</span>
                            }
                        </div>

                        <!-- MEDIA AREA (fixed height) -->
                        <div class="cc-card-media">
                            <div class="cc-thumb">
                                <img src="@c.Image" alt="@c.ImageAlt">
                            </div>
                        </div>
                    </article>
                }
            </section>
        }
    </div>
}

@code {
    private CCPageData? Data;

    protected override async Task OnInitializedAsync()
    {
        // wwwroot/data/CastleClimbersCharacters.json
        var uri = new Uri(new Uri(Nav.BaseUri), "data/CastleClimbersCharacters.json?v=1");
        Data = await Http.GetFromJsonAsync<CCPageData>(uri);
    }
}

<style>
    html, body {
        background: #380707;
    }

    .cc-wrap {
        width: min(1200px, 95vw);
        margin: 2rem auto;
    }

    .cc-group-title {
        margin: 2.5rem 0 1rem;
        font-weight: 900;
        font-size: clamp(2.6rem, 5vw, 3.6rem);
        line-height: 1.2;
        color: #fff;

        letter-spacing: 1.5px;
    }

    .cc-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.25rem;
        margin-bottom: 2rem;
    }

    .cc-card {
        position: relative;
        border-radius: 16px;
        padding: 1.25rem;
        box-shadow: 0 6px 18px rgba(0,0,0,.25);
        overflow: hidden;
        transition: transform .2s ease, box-shadow .2s ease;
        display: flex;
        flex-direction: column;
    }

        .cc-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 24px rgba(0,0,0,.32);
        }

    /* Corner text labels */
    .cc-card-tl,
    .cc-card-tr {
        position: absolute;
        padding: 0;
        font-size: 1.3rem;
        font-weight: 800;
        border: none;
        background: none;
        backdrop-filter: none;
        display: flex;
        align-items: center;
        gap: 0.35rem; /* space between number and coin icon */
    }

    .cc-card-tl {
        left: .75rem;
        top: .75rem;
    }

    .cc-card-tr {
        right: .75rem;
        bottom: .75rem;
        top: auto;
        text-align: right;
    }

    .cc-coin-icon {
        width: 20px;
        height: 20px;
        object-fit: contain;
    }

    /* Reserved media area */
    .cc-card-media {
        display: grid;
        place-items: center;
        height: 240px;
        margin-top: 1.6rem;
        border-radius: 12px;
        background: transparent;
    }

    .cc-thumb {
        display: grid;
        place-items: center;
        width: 170px;
        height: 130px;
        border-radius: 12px;
        overflow: hidden;
    }

        .cc-thumb img {
            max-width: 90%;
            max-height: 90%;
            object-fit: contain;
            display: block;
        }

    /* Responsive */
    @@media (max-width: 900px) {
        .cc-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .cc-group-title {
            font-size: clamp(2rem, 5vw, 3rem);
        }

        .cc-card-tl, .cc-card-tr {
            font-size: 1.15rem;
        }
    }

    @@media (max-width: 600px) {
        .cc-grid {
            grid-template-columns: 1fr;
        }

        .cc-card-media {
            height: 200px;
        }

        .cc-thumb {
            width: 150px;
            height: 110px;
        }

        .cc-group-title {
            font-size: clamp(1.8rem, 5.5vw, 2.5rem);
        }

        .cc-card-tl, .cc-card-tr {
            font-size: 1.05rem;
        }

        .cc-coin-icon {
            width: 18px;
            height: 18px;
        }
    }
</style>
