        <div class="track-art">
            <img src="images/castle_climbers/audio/Dungeon_Theme_Cover.png" alt="Dungeon Track cover">
        </div>

        <div class="track-body">
            <a class="yt-link" href="https://www.youtube.com/watch?v=lvTTxePR3ac" target="_blank" aria-label="Watch on YouTube">
                <img src="images/Youtube.png" alt="YouTube link">
            </a>

            <h3 class="track-title">Dungeon Track</h3>
            <p class="track-sub">Over - Context Sensitive</p>

            <div class="controls" aria-label="Dungeon Track controls">
