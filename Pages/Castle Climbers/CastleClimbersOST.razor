@page "/CastleClimbers/Soundtrack"

<CastleClimbersHeader />
<PageTitle>Castle Climbers</PageTitle>

<div class="cc-wrap">
    <h2 class="cc-group-title">Soundtrack</h2>

    <!-- Track 1 -->
