            <audio src="audio/Esuna.mp3" preload="metadata"></audio>
        </div>
    </section>

    <!-- Track 5 -->
    <section class="track-row">
        <div class="track-art">
            <img src="images/castle_climbers/audio/Music_Cover.png" alt="Sky Temple Track cover">
        </div>

        <div class="track-body">
            <a class="yt-link" href="https://www.youtube.com/watch?v=QVMhIJrUQsk" target="_blank" aria-label="Watch on YouTube">
                <img src="images/Youtube.png" alt="YouTube link">
            </a>

            <h3 class="track-title">Sky Temple Track</h3>
            <p class="track-sub">Ever Forever - Context Sensitive</p>

            <div class="controls" aria-label="Sky Temple Track controls">
