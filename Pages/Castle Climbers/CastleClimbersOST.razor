</div>


<style>
    html, body {
        background: #380707;
    }

    .cc-wrap {
        width: min(1000px, 95vw);
        margin: 2rem auto;
        color: #fff;
    }

    .cc-group-title {
        margin: 2rem 0 1rem;
        font-weight: 900;
        font-size: clamp(2rem, 5vw, 3rem);
    }

    .track-row {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        background: #4a0a0a;
        border: 4px solid #fff;
        border-radius: 12px;
        padding: 1rem;
        margin-bottom: 1.5rem;
        position: relative;
    }

    .track-art {
        width: 320px;
        aspect-ratio: 16 / 9;
        border-radius: 10px;
        overflow: hidden;
        flex: 0 0 auto;
        background: #000;
    }

        .track-art img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

    .track-body {
        flex: 1;
        min-width: 0;
        text-align: center;
        position: relative;
    }

    .track-title {
        margin: 0;
        font-size: 1.6rem;
        font-weight: 800;
    }

    .track-sub {
        margin: 0.25rem 0 1rem;
        font-size: 1rem;
        opacity: .8;
    }

    /* YouTube icon */
    .yt-link {
        position: absolute;
        top: 0.5rem;
        right: 0.5rem;
        width: 10%;
        height: 30%;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 0 6px rgba(0,0,0,0.4);
        transition: transform 0.2s;
    }

        .yt-link:hover {
            transform: scale(1.1);
        }

        .yt-link img {
            width: 100%;
            height: 100%;
            display: block;
        }

    /* Controls */
    .controls {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        grid-template-rows: auto auto;
        align-items: center;
        justify-items: center;
        gap: .5rem 1rem;
        margin-top: .25rem;
    }

        .controls .time {
            font-variant-numeric: tabular-nums;
            opacity: .95;
        }

            .controls .time.current {
                justify-self: end;
            }

            .controls .time.duration {
                justify-self: start;
            }

    .icon-btn {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        padding: 0;
        border: 2px solid #fff;
        background: #fff;
        color: #380707;
        font-weight: 800;
        line-height: 1;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        user-select: none;
    }

    .seek.thin {
        grid-column: 1 / 4;
        width: 100%;
        -webkit-appearance: none;
        appearance: none;
        height: 4px;
        border-radius: 999px;
        background: rgba(255,255,255,0.25);
        outline: none;
    }

        .seek.thin::-webkit-slider-thumb {
            -webkit-appearance: none;
            appearance: none;
            width: 14px;
            height: 14px;
            border-radius: 50%;
            background: #fff;
            cursor: pointer;
            border: 2px solid #380707;
            box-shadow: 0 0 0 2px rgba(0,0,0,.15);
        }

        .seek.thin::-moz-range-thumb {
            width: 14px;
            height: 14px;
            border-radius: 50%;
            background: #fff;
            cursor: pointer;
            border: 2px solid #380707;
        }

    @@media (max-width: 700px) {
        .track-row {
            flex-direction: column;
            align-items: stretch;
        }

        .track-art {
            width: 100%;
        }
    }
</style>

<script>
    function fmtTime(sec) {
        if (!isFinite(sec)) return "0:00";
        sec = Math.max(0, Math.floor(sec));
        const m = Math.floor(sec / 60);
        const s = sec % 60;
        return m + ":" + String(s).padStart(2, "0");
    }

    function pauseOthers(currentAudio) {
        document.querySelectorAll(".track-row audio").forEach(a => {
            if (a !== currentAudio) {
                a.pause();
                const row = a.closest(".track-row");
                const playBtn = row?.querySelector('[data-role="play"]');
                const seek = row?.querySelector('[data-role="seek"]');
                const current = row?.querySelector('[data-role="current"]');
                if (playBtn) playBtn.textContent = "▶";
                if (seek) seek.value = a.currentTime || 0;
                if (current) current.textContent = fmtTime(a.currentTime || 0);
            }
        });
    }

    function wireRow(row) {
        const audio    = row.querySelector("audio");
        const playBtn  = row.querySelector('[data-role="play"]');
        const seek     = row.querySelector('[data-role="seek"]');
        const currentT = row.querySelector('[data-role="current"]');
        const durationT= row.querySelector('[data-role="duration"]');

        if (!audio || !playBtn || !seek || !currentT || !durationT) return;

        const setDuration = () => {
            durationT.textContent = fmtTime(audio.duration);
            seek.max = isFinite(audio.duration) ? audio.duration : 0;
        };
        if (audio.readyState >= 1) setDuration();
        audio.addEventListener("loadedmetadata", setDuration);

        audio.addEventListener("timeupdate", () => {
            currentT.textContent = fmtTime(audio.currentTime);
            if (!seek.matches(":active")) {
                seek.value = audio.currentTime || 0;
            }
        });

        audio.addEventListener("play", () => {
            playBtn.textContent = "⏸";
            pauseOthers(audio);
        });

        audio.addEventListener("pause", () => {
            if (audio.ended) return;
            playBtn.textContent = "▶";
        });

        audio.addEventListener("ended", () => {
            playBtn.textContent = "▶";
            seek.value = 0;
            currentT.textContent = "0:00";
        });

        playBtn.addEventListener("click", () => {
            if (audio.paused) audio.play();
            else audio.pause();
        });

        let wasPlaying = false;
        const startDrag = () => { wasPlaying = !audio.paused; if (wasPlaying) audio.pause(); };
        const endDrag   = () => { if (wasPlaying) audio.play(); };

        seek.addEventListener("input", () => {
            currentT.textContent = fmtTime(seek.value);
        });
        seek.addEventListener("change", () => {
            audio.currentTime = parseFloat(seek.value || "0");
        });
        seek.addEventListener("mousedown", startDrag);
        seek.addEventListener("touchstart", startDrag, { passive: true });
        seek.addEventListener("mouseup", endDrag);
        seek.addEventListener("touchend", endDrag);
    }

    document.addEventListener("DOMContentLoaded", () => {
        document.querySelectorAll(".track-row").forEach(wireRow);
    });
</script>
