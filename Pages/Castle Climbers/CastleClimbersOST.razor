        <div class="track-art">
            <img src="images/castle_climbers/audio/Menu_Theme_Cover.png" alt="Menu Theme cover">
        </div>

        <div class="track-body">
            <!-- YouTube link -->
            <a class="yt-link" href="https://www.youtube.com/watch?v=5bn3Jmvep1k&list=RD5bn3Jmvep1k&start_radio=1" target="_blank" aria-label="Watch on YouTube">
                <img src="images/Youtube.png" alt="YouTube link">
            </a>

            <h3 class="track-title">Menu Theme</h3>
            <p class="track-sub">Title Theme - xDeviruchi</p>

            <div class="controls" aria-label="Menu Theme controls">
                <div class="time current" data-role="current">0:00</div>
                <button class="btn icon-btn" data-role="play">▶</button>
                <div class="time duration" data-role="duration">0:00</div>
                <input class="seek thin" type="range" value="0" min="0" max="0" step="0.01" data-role="seek">
            </div>

            <audio src="audio/Title Theme.mp3" preload="metadata"></audio>
        </div>
