    <!-- Track 6 -->
    <section class="track-row">
        <div class="track-art">
            <img src="images/castle_climbers/audio/Space_Theme_Cover.png" alt="Space Track cover">
        </div>

        <div class="track-body">
            <a class="yt-link" href="https://www.youtube.com/watch?v=inHWCBXgnWw" target="_blank" aria-label="Watch on YouTube">
                <img src="images/Youtube.png" alt="YouTube link">
            </a>

            <h3 class="track-title">Space Track</h3>
            <p class="track-sub">Adrift - Context Sensitive</p>

            <div class="controls" aria-label="Space Track controls">
