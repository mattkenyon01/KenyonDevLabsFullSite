                <button class="btn icon-btn" data-role="play">▶</button>
                <div class="time duration" data-role="duration">0:00</div>
                <input class="seek thin" type="range" value="0" min="0" max="0" step="0.01" data-role="seek">
            </div>

            <audio src="audio/Over.mp3" preload="metadata"></audio>
        </div>
    </section>

    <!-- Track 3 -->
    <section class="track-row">
        <div class="track-art">
            <img src="images/castle_climbers/audio/Castle_Theme_Cover.png" alt="Castle Track cover">
        </div>

        <div class="track-body">
            <a class="yt-link" href="https://www.youtube.com/watch?v=b9BBWZqD8TY" target="_blank" aria-label="Watch on YouTube">
                <img src="images/Youtube.png" alt="YouTube link">
            </a>

            <h3 class="track-title">Castle Track</h3>
            <p class="track-sub">Travel - Context Sensitive</p>

            <div class="controls" aria-label="Castle Track controls">
                <div class="time current" data-role="current">0:00</div>
                <button class="btn icon-btn" data-role="play">▶</button>
                <div class="time duration" data-role="duration">0:00</div>
                <input class="seek thin" type="range" value="0" min="0" max="0" step="0.01" data-role="seek">
            </div>

            <audio src="audio/Travel.mp3" preload="metadata"></audio>
        </div>
    </section>

    <!-- Track 4 -->
    <section class="track-row">
        <div class="track-art">
            <img src="images/castle_climbers/audio/Clouds_Theme_Cover.png" alt="Clouds Track cover">
        </div>

        <div class="track-body">
            <a class="yt-link" href="https://www.youtube.com/watch?v=x8lJO3QornU" target="_blank" aria-label="Watch on YouTube">
                <img src="images/Youtube.png" alt="YouTube link">
            </a>

            <h3 class="track-title">Clouds Track</h3>
            <p class="track-sub">Esuna - Context Sensitive</p>

            <div class="controls" aria-label="Clouds Track controls">
                <div class="time current" data-role="current">0:00</div>
                <button class="btn icon-btn" data-role="play">▶</button>
                <div class="time duration" data-role="duration">0:00</div>
                <input class="seek thin" type="range" value="0" min="0" max="0" step="0.01" data-role="seek">
