@page "/CastleClimbers/Levels"
@using KenyonDevLabs.Models

<CastleClimbersHeader />
<PageTitle>Castle Climbers — Characters</PageTitle>

<div class="cc-wrap" aria-label="Castle Climbers Character Groups">

    <!-- ===== Group: Heroes ===== -->
    <h2 class="cc-group-title">Levels</h2>

    <section class="char-list" aria-label="Heroes">
        <!-- Row -->
        <article class="char-row" style="--outline:#911f1f;--card:#5b0a0a;">
            <div class="char-media">
                <div class="square">
                    <img src="images/castle_climbers/levels/Dungeon.png" alt="Player hero">
                </div>
            </div>
            <div class="char-body">
                <h3 class="char-title">Dungeon</h3>
                <p class="char-subtitle">0m - 200m</p>
                <p class="char-desc">
                    Dark stone walls close in around you as you climb past flickering torches and hanging chains.
                    The dungeon feels alive with echoes and shadows, testing your courage at every step.
                </p>
            </div>
        </article>

        <!-- Row -->
        <article class="char-row" style="--outline:#911f1f;--card:#5b0a0a;">
            <div class="char-media">
                <div class="square">
                    <img src="images/castle_climbers/levels/Castle.png" alt="Player hero">
                </div>
            </div>
            <div class="char-body">
                <h3 class="char-title">Dungeon</h3>
                <p class="char-subtitle">200m - 500m</p>
                <p class="char-desc">
                    As you climb higher, banners drape from the stone walls and torches flicker in the dark.
                    The dungeon feels vast and unwelcoming, each step carrying you deeper into its shadowed halls.
                </p>
            </div>
        </article>

        <article class="char-row" style="--outline:#911f1f;--card:#5b0a0a;">
            <div class="char-media">
                <div class="square">
                    <img src="images/castle_climbers/levels/Sky.png" alt="Player hero">
                </div>
            </div>
            <div class="char-body">
                <h3 class="char-title">Sky</h3>
                <p class="char-subtitle">500m - 1,000m</p>
                <p class="char-desc">
                    Breaking free from the castle walls, you rise into the open sky. Fresh air rushes past as clouds drift below,
                    and the horizon stretches endlessly ahead - a new sense of freedom with every climb.
                </p>
            </div>
        </article>

        <article class="char-row" style="--outline:#911f1f;--card:#5b0a0a;">
            <div class="char-media">
                <div class="square">
                    <img src="images/castle_climbers/levels/Temple.png" alt="Player hero">
                </div>
            </div>
            <div class="char-body">
                <h3 class="char-title">Sky Ruins</h3>
                <p class="char-subtitle">1,000m - 2,000m</p>
                <p class="char-desc">
                    Among crumbling ruins suspended in the clouds, the sky glows with the colors of sunset.
                    Ancient stone arches and broken towers drift in golden light, painting the climb with both beauty and mystery.
                </p>
            </div>
        </article>

        <article class="char-row" style="--outline:#911f1f;--card:#5b0a0a;">
            <div class="char-media">
                <div class="square">
                    <img src="images/castle_climbers/levels/Space.png" alt="Player hero">
                </div>
            </div>
            <div class="char-body">
                <h3 class="char-title">Space</h3>
                <p class="char-subtitle">2,000m +</p>
                <p class="char-desc">
                    Leaving the skies behind, you return to the familiar darkness.
                    The air grows thin as stars emerge all around, guiding your climb through the endless void.
                </p>
            </div>
        </article>
    </section>
</div>

<style>
    html, body {
        background: #380707;
    }

    .cc-wrap {
        width: min(1200px,95vw);
        margin: 2rem auto 4rem;
    }

    .cc-group-title {
        margin: 2.5rem 0 1rem;
        font-weight: 900;
        font-size: clamp(2.2rem,4.5vw,3.2rem);
        line-height: 1.2;
        color: #fff;
        letter-spacing: 1.2px;
    }

    /* List wrapper just gives spacing between rows */
    .char-list {
        display: grid;
        gap: 1rem;
    }

    /* Each row: left = fixed-width 1:1 media, right = text */
    .char-row {
        display: grid;
        grid-template-columns: 160px 1fr;
        gap: 1.25rem;
        padding: 1rem;
        border-radius: 16px;
        background: var(--card, #1f1f1f);
        border: 8px solid var(--outline, #444);
        box-shadow: 0 8px 20px rgba(0,0,0,.35);
        align-items: center;
        transition: transform .15s ease, box-shadow .15s ease;
    }

        .char-row:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 28px rgba(0,0,0,.45);
        }

    /* 1:1 media container */
    .char-media {
        width: 100%;
        max-width: 160px;
    }

        .char-media img {
            max-width: 90%;
            max-height: 90%;
            object-fit: contain; /* show full image without cropping */
            display: block;
            border-radius: 12px; /* curved edges */
        }

    /* Right side text block */
    .char-body {
        color: #fff;
    }

    .char-title {
        margin: 0;
        font-size: clamp(1.3rem,2.2vw,1.6rem);
        font-weight: 900;
        letter-spacing: .4px;
    }

    .char-subtitle {
        margin: .15rem 0 .5rem;
        font-size: clamp(1rem,1.8vw,1.1rem);
        opacity: .9;
        font-weight: 600;
    }

    .char-desc {
        margin: 0;
        font-size: clamp(.98rem,1.7vw,1.05rem);
        line-height: 1.55;
        opacity: .92;
        max-width: 100ch;
    }

    /* Responsive tweaks */
    @@media (max-width: 900px) {
        .char-row {
            grid-template-columns: 140px 1fr;
        }

        .char-media {
            max-width: 140px;
        }
    }

    @@media (max-width: 640px) {
        .char-row {
            grid-template-columns: 1fr;
            text-align: left;
        }

        .char-media, .char-media .square {
            max-width: 220px;
            margin: 0 auto;
        }

        .char-desc {
            max-width: unset;
        }
    }
</style>
