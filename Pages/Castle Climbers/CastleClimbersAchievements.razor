<style>
    html, body {
        background: #380707;
    }

    .cc-wrap {
        width: min(1200px, 95vw);
        margin: 2rem auto;
    }

    /* Centered hero/title */
    .cc-hero {
        text-align: center;
        margin: 2rem 0;
    }

    .cc-group-title {
        margin: 0;
        font-weight: 900;
        font-size: clamp(2.2rem, 4.5vw, 3.2rem);
        line-height: 1.2;
        color: #fff;
        text-transform: uppercase;
        letter-spacing: 1.5px;
    }

    .cc-subtitle {
        margin-top: 0.5rem;
        font-size: clamp(1rem, 2.5vw, 1.25rem);
        color: #ddd;
        opacity: .85;
    }

    .cc-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.25rem;
        margin-bottom: 2rem;
    }

    .cc-card {
        border-radius: 16px;
        padding: 1.25rem;
        display: flex;
        flex-direction: column;
        background: none;
        border: none;
        color: #fff;
        text-align: center; /* center title block */
        overflow: visible;
    }

    /* Header inside card */
    .cc-card-header {
        margin-bottom: 0.5rem; /* tighter spacing above image */
    }

    .cc-card-title {
        font-size: 1.3rem;
        font-weight: 800;
    }

    .cc-card-subtitle {
        font-size: 1rem;
        opacity: .85;
    }

    /* Media area: medal on left, badges on right */
    .cc-card-media {
        display: grid;
        grid-template-columns: auto 1fr;
        align-items: center;
        gap: 1rem;
        text-align: left; /* for the right column text */
    }

    .cc-thumb {
        width: 170px;
        aspect-ratio: 1 / 1;
        display: grid;
        place-items: center;
        overflow: visible;
        margin-inline: auto; /* keep the image centered within its own column */
    }

        .cc-thumb img {
            width: 100%;
            height: 100%;
            object-fit: contain; /* show full image, no cropping */
            display: block;
        }

    /* Right-side badges (3–4 rows) */
    .cc-badges {
        list-style: none;
        margin: 0;
        padding: 0;
        display: grid;
        gap: 0.5rem;
    }

    .cc-badge {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.975rem;
        line-height: 1.2;
        opacity: 0.95;
        white-space: nowrap;
    }

    .cc-icon {
        width: 28px;
        height: 28px;
        object-fit: contain;
        display: block;
        flex: 0 0 28px;
        filter: drop-shadow(0 1px 2px rgba(0,0,0,.25));
    }

    /* Responsive */
    @@media (max-width: 900px) {
        .cc-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .cc-card-title {
            font-size: 1.15rem;
        }

        .cc-card-subtitle {
            font-size: .95rem;
        }
    }

    @@media (max-width: 700px) {
        /* Stack medal above badges on small screens */
        .cc-card-media {
            grid-template-columns: 1fr;
            text-align: center;
        }

        .cc-badges {
            justify-items: center;
        }

        .cc-badge {
            justify-content: center;
            text-align: center;
            white-space: normal;
        }
    }

    @@media (max-width: 600px) {
        .cc-grid {
            grid-template-columns: 1fr;
        }

        .cc-thumb {
            width: 140px;
        }

        .cc-card-title {
            font-size: 1.05rem;
        }

        .cc-card-subtitle {
            font-size: .9rem;
        }
    }
</style>
