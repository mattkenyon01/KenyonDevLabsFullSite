<style>
    /* ===== About the App ===== */
    .about-app {
        width: min(var(--page-max, 1200px), 95vw);
        margin: 2rem auto 0;
        color: white;
    }

        .about-app #about-title {
            margin: 0 0 1rem 0;
            font-size: clamp(1.25rem, 2.5vw, 1.75rem);
            font-weight: 800;
            color: #fff;
        }

    .feature {
        display: grid;
        grid-template-columns: 1.2fr 1fr;
