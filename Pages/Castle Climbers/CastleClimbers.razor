            display: block;
        }

    .feature-body {
        text-align: center; /* center titles, text, lists */
    }

        .feature-body h3 {
            margin: 0 0 .35rem 0;
            font-size: 1.35rem;
            font-weight: 800;
        }

        .feature-body p {
            margin: 0 0 .5rem 0;
            color: white;
            line-height: 1.4;
            font-size: 1.05rem;
        }

    .feature-list {
        margin: 0 auto 1rem;
        padding-left: 1.1rem;
        display: inline-block; /* keeps list centered */
