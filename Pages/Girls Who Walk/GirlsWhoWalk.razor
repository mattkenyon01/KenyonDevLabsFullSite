@code {
    private List<NewsItem> GirlsWhoConnectNotes = new();

    protected override async Task OnInitializedAsync()
    {
        if (Http.BaseAddress is null)
            Http.BaseAddress = new Uri(Nav.BaseUri);

        var items = await NewsData.GetNewsAsync("GirlsWhoConnectPatchNotes.json");
        GirlsWhoConnectNotes = items
            .Where(n => n.Tags?.Contains("Girls Who Connect") == true)
            .OrderByDescending(n => n.Date)
            .Take(3)
            .ToList();
    }

    private static string TruncateSummary(string? summary, int maxLength = 220)
    {
        if (string.IsNullOrWhiteSpace(summary))
            return string.Empty;

        var plain = System.Text.RegularExpressions.Regex.Replace(summary, "<.*?>", string.Empty);
        return plain.Length <= maxLength ? summary! : $"{plain[..maxLength].TrimEnd()}…";
    }

    private static string GetNewsTop(NewsItem item)
        => !string.IsNullOrWhiteSpace(item.TopColour) ? item.TopColour : "#efb2c4";

    private static string GetNewsBottom(NewsItem item)
        => !string.IsNullOrWhiteSpace(item.BottomColour) ? item.BottomColour : "#d495a8";

    private static string GetNewsDateText(NewsItem item)
        => !string.IsNullOrWhiteSpace(item.DateTextColour) ? item.DateTextColour : "#1a1a1a";
}
