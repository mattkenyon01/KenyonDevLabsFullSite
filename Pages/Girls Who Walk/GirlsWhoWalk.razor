    }

    /* ===== Content (Right) ===== */
    .pdf-content {
        flex: 1;
        text-align: left;
    }

        .pdf-content h3 {
            margin: 0 0 .5rem 0;
            font-size: 1.15rem;
            font-weight: 800;
        }

        .pdf-content p {
            margin: 0 0 1rem 0;
            color: #333;
            line-height: 1.5;
            max-width: 52ch;
        }

    .pdf-meta {
        display: flex;
        flex-wrap: wrap;
        gap: .75rem 1.25rem;
        padding: 0;
        margin: 0 0 1.2rem 0;
        list-style: none;
        color: #444;
    }

        .pdf-meta li {
            background: rgba(239,178,196,.18);
            border: 1px solid rgba(239,178,196,.45);
