<!-- ===== Google Play Testing Section ===== -->
<section class="testing-section" aria-labelledby="testing-title">
    <img src="images/Google Play Icon.png" alt="" class="testing-icon" />
    <h2 id="testing-title">Join Our Google Play Testing Program</h2>
    <p>
        We are looking for at least 12 users to take part in the closed testing of Girls Who Walk on the google play store. Please enter your email below to take part in the testing. 
        The email will only be used to authenticate the google account used to test the application.
    </p>

    <form class="testing-form" @onsubmit="HandleSubmit" @onsubmit:preventDefault>
        <input @bind="testerEmail" type="email" placeholder="Enter your email" required>
        <!-- Honeypot anti-bot -->
        <input type="text" class="hp" tabindex="-1" autocomplete="off" @bind="honeypot">
        <button type="submit" disabled="@submitting">@((submitting ? "Joining…" : "Join"))</button>
    </form>

    @if (!string.IsNullOrEmpty(message))
    {
        <p style="margin-top:.75rem; color:@(error ? "#b00020" : "#0a7a39");">@message</p>
    }
</section>

