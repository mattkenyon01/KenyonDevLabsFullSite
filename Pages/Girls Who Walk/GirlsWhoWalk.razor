        text-align: center;
        font-size: clamp(1.4rem, 3vw, 2rem);
        font-weight: 800;
    }

    /* ===== Card Layout ===== */
    .pdf-card.landscape {
        display: flex;
        flex-direction: row; /* ✅ side-by-side layout */
        align-items: center;
        justify-content: space-between;
        flex-wrap: nowrap;
        gap: 2rem;
        background: #fff;
        border-radius: var(--radius, 16px);
        box-shadow: 0 12px 28px rgba(0,0,0,.12);
        padding: 2rem;
        overflow: hidden;
    }

    /* ===== Landscape Preview (Left) ===== */
    .pdf-preview-landscape {
        position: relative;
        flex: 0 0 50%;
        background: linear-gradient(145deg, rgba(239,178,196,.25), rgba(239,178,196,.1));
        border: 1px solid rgba(239,178,196,.5);
