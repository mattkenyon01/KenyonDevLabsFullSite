@code {
    // Email form state
    private string testerEmail = string.Empty;
    private string honeypot = string.Empty;
    private bool submitting = false;
    private string? message = null;
    private bool error = false;

    private async Task HandleSubmit()
    {
        if (submitting) return;
        message = null; error = false;

        // Bot trap
        if (!string.IsNullOrWhiteSpace(honeypot))
        {
            message = "Thanks!";
            return;
        }

        submitting = true;
        try
        {
            var payload = new { email = testerEmail };
            var resp = await Http.PostAsJsonAsync("/api/testers", payload);

            if (resp.IsSuccessStatusCode)
            {
                message = "You're in!";
                testerEmail = string.Empty;
            }
            else
            {
                var body = await resp.Content.ReadAsStringAsync();
                message = string.IsNullOrWhiteSpace(body) ? "Something went wrong." : body;
                error = true;
            }
        }
        catch
        {
            message = "Network error. Please try again.";
            error = true;
        }
        finally
        {
            submitting = false;
            StateHasChanged();
        }
    }
}

<script>
    (function () {
        const cards = Array.from(document.querySelectorAll('.rectangle-row .card'));
        if (!cards.length) return;
        const duration = parseInt(getComputedStyle(document.documentElement)
                          .getPropertyValue('--timer-ms')) || 5000;
        const hero = document.getElementById('hero');
        hero.src = cards[0].querySelector('img').src;
        hero.onload = () => { hero.style.opacity = 1; };
        let index = 0, currentFillEndHandler = null;
        function setHeroFromCard(i) {
            const src = cards[i].querySelector('img').src;
            hero.style.opacity = 0;
            const apply = () => { hero.style.opacity = 1; };
            if (hero.src === src) { requestAnimationFrame(apply); return; }
            hero.onload = apply;
            hero.src = src;
        }
        function clearAnimations() {
            cards.forEach(c => {
                const f = c.querySelector('.progress-fill');
                f.style.animation = 'none';
                void f.offsetWidth;
                f.style.animation = '';
                c.classList.remove('active');
            });
            if (currentFillEndHandler) {
                currentFillEndHandler.target?.removeEventListener('animationend', currentFillEndHandler);
                currentFillEndHandler = null;
            }
        }
        function activate(i) {
            clearAnimations();
            const card = cards[i];
            const fill = card.querySelector('.progress-fill');
            card.classList.add('active');
            setHeroFromCard(i);
            fill.style.animation = `load ${duration}ms linear forwards`;
            const onEnd = () => {
                currentFillEndHandler = null;
                index = (i + 1) % cards.length;
                activate(index);
            };
            currentFillEndHandler = onEnd;
            fill.addEventListener('animationend', onEnd, { once: true });
        }
        cards.forEach((card) => {
            const fill = card.querySelector('.progress-fill');
            card.addEventListener('mouseenter', () => {
                if (fill.style.animation) fill.style.animationPlayState = 'paused';
            });
            card.addEventListener('mouseleave', () => {
                if (fill.style.animation) fill.style.animationPlayState = 'running';
            });
            card.addEventListener('click', () => {
                index = cards.indexOf(card);
                activate(index);
            });
        });
        activate(index);
    })();
</script>

<!-- ===== News & Updates ===== -->
<section class="news-section" aria-labelledby="news-title">
    <div class="news-header">
        <h2 id="news-title">
            Patch Notes
            <NavLink href="/GirlsWhoWalk/PatchNotes">
                <svg class="news-arrow" xmlns="http://www.w3.org/2000/svg"
                     viewBox="0 0 24 24" width="18" height="18"
                     fill="none" stroke="black" stroke-width="4"
                     stroke-linecap="round" stroke-linejoin="round">
                    <path d="M8 5l8 7-8 7" />
                </svg>
            </NavLink>



        </h2>

    </div>

    <div class="news-grid">
        
        @foreach (var item in GirlsWhoWalkNotes)
        {
            <article class="news-card">
                <div class="news-date" style="background: linear-gradient(180deg, @item.TopColour, @item.BottomColour); color: @item.DateTextColour;">
                    <span class="day">@item.Date.ToString("dd")</span>
                    <span class="mon">@item.Date.ToString("MMM", CultureInfo.InvariantCulture)</span>
                    <span class="yr">@item.Date.ToString("yyyy")</span>
                </div>
                <div class="news-body">
                    <h3>@item.Title</h3>
                    <p>@((MarkupString)item.Summary)</p>

                    @if (!string.IsNullOrEmpty(item.Summary) && item.Summary.Length > 200)
                    {
                        <a class="news-link" href="/GirlsWhoWalk/PatchNotes">Read more</a>
                    }
                </div>
            </article>
        }

    </div>

</section>

