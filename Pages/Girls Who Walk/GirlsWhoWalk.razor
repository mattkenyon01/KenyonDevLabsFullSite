@page "/GirlsWhoConnect"
@using System.Globalization
@using KenyonDevLabs.Models
@using KenyonDevLabs.Services
@inject HttpClient Http
@inject NewsFileService NewsData
@inject NavigationManager Nav

<PageTitle>Girls Who Connect</PageTitle>

<GirlsWhoWalkHeader />

<div class="gwc-page">

    <!-- HERO -->
    <section class="gwc-section gwc-hero">
        <div class="gwc-container gwc-hero-grid">
            <div class="gwc-hero-copy">
                <span class="gwc-eyebrow gwc-eyebrow-hero">Community walks app</span>
                <h1>Welcome to Girls Who Connect</h1>
                <p>
                    Stay up to date with walking groups in your area - discover upcoming walks,
                    connect with local members, and see everything happening in your community.
                </p>
                <a href="https://apps.apple.com/gb/app/girls-who-walk/id6477972997"
                   target="_blank"
                   rel="noopener noreferrer"
                   class="gwc-appstore-btn">
                    <img src="images/App Store Button.png" alt="Download on the App Store" />
                </a>
            </div>
            <div class="gwc-hero-visual">
                <img src="images/Girls Who Connect/3 phones graphic.png" alt="Girls Who Connect app preview" />
            </div>
        </div>
    </section>

    <!-- MISSION -->
    <section class="gwc-section gwc-section-white" aria-labelledby="info-title">
        <div class="gwc-container">
            <header class="gwc-section-head">
                <span class="gwc-eyebrow">Our mission</span>
                <h2 id="info-title">Built for community walks</h2>
                <p class="gwc-section-lead">
                    A supportive space for women to organise walks, plan routes, and stay connected locally.
                </p>
            </header>

            <div class="gwc-split">
                <div class="gwc-split-body">
                    <p>
                        Girls Who Connect helps women discover local walking groups, make new friends,
                        and explore their area safely. The app was created to give communities their
                        space to organise walks, plan routes, and stay in touch within a supportive
                        environment designed just for them.
                    </p>
                    <p>
                        It's not only a way to get active and meet people, but also a platform shaped by its users.
                        Feedback goes directly to the developer, helping the app evolve into the kind
                        of social, stylish experience the community wants it to be.
                    </p>
                </div>
                <div class="gwc-split-media">
                    <img src="images/Girls Who Connect/Connect Graphic.png"
                         alt="Girls Who Connect community group"
                         loading="lazy" />
                </div>
            </div>
        </div>
    </section>

    <!-- FEATURES -->
    <section class="gwc-section gwc-section-muted" aria-labelledby="features-title">
        <div class="gwc-container">
            <header class="gwc-section-head">
                <span class="gwc-eyebrow">At a glance</span>
                <h2 id="features-title">App functionality</h2>
            </header>

            <div class="gwc-icon-grid">
                <article class="gwc-icon-card">
                    <div class="gwc-icon-circle" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                             stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M12 22s7-6.2 7-12a7 7 0 1 0-14 0c0 5.8 7 12 7 12Z" />
                            <circle cx="12" cy="10" r="3" />
                        </svg>
                    </div>
                    <h3>Find local walks</h3>
                    <p>Discover nearby walking groups and events - complete with time, location, capacity, and walk leaders at a glance.</p>
                </article>

                <article class="gwc-icon-card">
                    <div class="gwc-icon-circle" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                             stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.6l-1-1a5.5 5.5 0 0 0-7.8 7.8l1 1L12 22l7.8-8.6 1-1a5.5 5.5 0 0 0 0-7.8Z" />
                        </svg>
                    </div>
                    <h3>Meet new people</h3>
                    <p>Connect with friendly walkers, grow your social circle, and chat with new friends right in the app.</p>
                </article>

                <article class="gwc-icon-card">
                    <div class="gwc-icon-circle" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                             stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="8" r="4" />
                            <path d="M4 20c0-4 4-6 8-6s8 2 8 6" />
                        </svg>
                    </div>
                    <h3>Personalise your space</h3>
                    <p>Customise your profile, adjust preferences, and create a space that reflects your personality.</p>
                </article>
            </div>
        </div>
    </section>

    <!-- PDF / SIGN UP -->
    <section class="gwc-section gwc-section-white" aria-labelledby="pdf-title">
        <div class="gwc-container">
            <header class="gwc-section-head">
                <span class="gwc-eyebrow">Get started</span>
                <h2 id="pdf-title">Want to sign up?</h2>
                <p class="gwc-section-lead">
                    Everything your group needs to get set up on Girls Who Connect - in one pitch deck.
                </p>
            </header>

            <article class="gwc-split-card">
                <div class="gwc-split-card-media">
                    <img src="images/Girls Who Connect/PDF_Cover.png"
                         alt="Girls Who Connect overview preview"
                         loading="lazy" />
                    <span class="gwc-pdf-badge">PDF</span>
                </div>
                <div class="gwc-split-card-body">
                    <h3>Pitch deck</h3>
                    <p>
                        It's easy to become a part of the Girls Who Connect app. To get your group involved,
                        encourage the admin to view the website or get in contact with matt@kenyondevlabs.com.
                        All the details of the app are presented in this document, along with how to get
                        set up and how to get the most out of the app.
                    </p>
                    <div class="gwc-split-card-actions">
                        <a class="gwc-btn"
                           href="Files/Girls_Who_Connect_Details.pdf"
                           target="_blank"
                           rel="noopener">
                            View PDF
                        </a>
                        <a class="gwc-btn gwc-btn-outline"
                           href="Files/Girls_Who_Connect_Details.pdf"
                           download>
                            Download
                        </a>
                    </div>
                </div>
            </article>
        </div>
    </section>

    <!-- POLICIES -->
    <section class="gwc-section gwc-section-muted gwc-policies-section" aria-labelledby="policy-cta-title">
        <div class="gwc-container">
            <header class="gwc-section-head">
                <span class="gwc-eyebrow">Legal</span>
                <h2 id="policy-cta-title">Important policies</h2>
                <p class="gwc-section-lead">
                    We're committed to privacy and safety across the Girls Who Connect community.
                    Read how we protect your data and the standards we follow to keep young users safe.
                </p>
            </header>

            <div class="gwc-policy-grid">
                <article class="gwc-policy-card">
                    <span class="gwc-policy-label">Privacy</span>
                    <h3>Privacy Policy</h3>
                    <p>
                        See what data we collect, how we use it, and the controls you have to manage your privacy.
                    </p>
                    <NavLink class="gwc-btn" href="/girlswhoconnect/PrivacyPolicy" aria-label="Read our Privacy Policy">
                        Read Privacy Policy
                    </NavLink>
                </article>

                <article class="gwc-policy-card">
                    <span class="gwc-policy-label">Safety</span>
                    <h3>Child Safety Standards</h3>
                    <p>
                        Review our safety-by-design standards, moderation practices, and reporting tools for young users.
                    </p>
                    <NavLink class="gwc-btn" href="/girlswhoconnect/ChildSafetyStandards" aria-label="Read our Child Safety Standards">
                        View Safety Standards
                    </NavLink>
                </article>
            </div>
        </div>
    </section>

    <!-- PATCH NOTES -->
    <section class="gwc-section gwc-section-white gwc-news-section" aria-labelledby="news-title">
        <div class="gwc-container">
            <header class="gwc-section-head">
                <span class="gwc-eyebrow">Updates</span>
                <h2 id="news-title">Patch notes</h2>
                <p class="gwc-section-lead">Recent releases and fixes for Girls Who Connect.</p>
            </header>

            @if (GirlsWhoConnectNotes.Count == 0)
            {
                <p class="gwc-news-empty">No patch notes yet - check back soon.</p>
            }
            else
            {
                <div class="gwc-news-list">
                    @foreach (var item in GirlsWhoConnectNotes)
                    {
                        <article class="gwc-news-card">
                            <div class="gwc-news-date"
                                 style="background: linear-gradient(180deg, @GetNewsTop(item), @GetNewsBottom(item)); color: @GetNewsDateText(item);">
                                <span class="day">@item.Date.ToString("dd")</span>
                                <span class="mon">@item.Date.ToString("MMM", CultureInfo.InvariantCulture)</span>
                            </div>
                            <div class="gwc-news-body">
                                <div class="gwc-news-title-row">
                                    @if (!string.IsNullOrWhiteSpace(item.IconUrl))
                                    {
                                        <img class="gwc-news-icon" src="@item.IconUrl" alt="" />
                                    }
                                    <h3>@item.Title</h3>
                                </div>
                                <p>@((MarkupString)TruncateSummary(item.Summary))</p>
                            </div>
                        </article>
                    }
                </div>

                <div class="gwc-news-actions">
                    <NavLink href="/GirlsWhoConnect/PatchNotes" class="gwc-btn gwc-btn-outline">View all patch notes</NavLink>
                </div>
            }
        </div>
    </section>

    <footer class="gwc-footer">
        <div class="gwc-container gwc-footer-inner">
            <nav aria-label="Legal">
                <h3>Legal</h3>
                <ul class="gwc-footer-links">
                    <li><NavLink href="/GirlsWhoConnect/PrivacyPolicy">Privacy Policy</NavLink></li>
                    <li><NavLink href="/GirlsWhoConnect/ChildSafetyStandards">Child Safety Standards</NavLink></li>
                </ul>
            </nav>
            <p class="gwc-footer-copy">&copy; @DateTime.Now.Year Kenyon Dev Labs</p>
        </div>
    </footer>

</div>

<style>
    :root {
        --gwc-brand: #efb2c4;
        --gwc-brand-dark: #d495a8;
        --gwc-brand-deep: #b14c66;
        --gwc-muted: #fff5f8;
        --gwc-text: #1a1a1a;
        --gwc-text-soft: #4a4a4a;
        --gwc-max: 1080px;
        --gwc-radius: 1rem;
        --gwc-shadow: 0 8px 28px rgba(212, 149, 168, 0.18);
    }

    html, body {
        overflow-x: clip;
        font-family: var(--font-sans, 'Plus Jakarta Sans', system-ui, sans-serif);
    }

    body {
        background: #fff;
        color: var(--gwc-text);
    }

    .gwc-page {
        overflow-x: clip;
    }

    .gwc-section {
        width: 100vw;
        margin-left: calc(50% - 50vw);
        margin-right: calc(50% - 50vw);
        padding: 4rem 1.5rem;
        box-sizing: border-box;
        border-top: 1px solid rgba(239, 178, 196, 0.35);
    }

    .gwc-section-white {
        background: #fff;
    }

    .gwc-section-muted {
        background: var(--gwc-muted);
    }

    .gwc-container {
        max-width: var(--gwc-max);
        margin: 0 auto;
    }

    .gwc-section-head {
        max-width: 42rem;
        margin: 0 auto 2.5rem;
        text-align: center;
    }

    .gwc-eyebrow {
        display: inline-block;
        margin-bottom: 0.75rem;
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: #c45f7a;
    }

    .gwc-section-head h2 {
        margin: 0;
        font-size: clamp(1.6rem, 3vw, 2.1rem);
        font-weight: 800;
        letter-spacing: -0.02em;
        line-height: 1.15;
        color: var(--gwc-text);
    }

        .gwc-section-head h2::after {
            content: "";
            display: block;
            width: 3rem;
            height: 3px;
            margin: 1rem auto 0;
            background: var(--gwc-brand-dark);
            border-radius: 999px;
        }

    .gwc-section-lead {
        margin: 1.15rem 0 0;
        color: var(--gwc-text-soft);
        font-size: 1.05rem;
        line-height: 1.65;
    }

    /* Hero */
    .gwc-hero {
        border-top: none;
        padding: 3rem 1.5rem 5.5rem;
        background: linear-gradient(160deg, var(--gwc-brand) 0%, var(--gwc-brand-dark) 100%);
        position: relative;
    }

        .gwc-hero::after {
            content: "";
            position: absolute;
            left: 0;
            right: 0;
            bottom: -1px;
            height: 64px;
            background: #fff;
            clip-path: ellipse(55% 100% at 50% 100%);
        }

    .gwc-hero-grid {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 2.5rem;
        flex-wrap: wrap;
        position: relative;
        z-index: 1;
    }

    .gwc-hero-copy {
        flex: 1 1 360px;
        color: var(--gwc-text);
    }

    .gwc-eyebrow-hero {
        color: var(--gwc-brand-deep);
    }

    .gwc-hero-copy h1 {
        margin: 0 0 1.15rem;
        font-size: clamp(2rem, 4.5vw, 2.85rem);
        font-weight: 800;
        letter-spacing: -0.03em;
        line-height: 1.1;
    }

    .gwc-hero-copy p {
        margin: 0 0 1.5rem;
        max-width: 32rem;
        font-size: 1.08rem;
        line-height: 1.65;
        color: var(--gwc-text-soft);
    }

    .gwc-appstore-btn {
        display: inline-block;
        transition: transform 0.2s ease;
    }

        .gwc-appstore-btn:hover {
            transform: translateY(-2px);
        }

        .gwc-appstore-btn img {
            height: 48px;
            width: auto;
            display: block;
        }

    .gwc-hero-visual {
        flex: 1 1 360px;
        display: flex;
        justify-content: center;
    }

        .gwc-hero-visual img {
            width: 100%;
            max-width: 440px;
            filter: drop-shadow(0 20px 40px rgba(0, 0, 0, 0.15));
        }

    /* Split content (mission) */
    .gwc-split {
        display: flex;
        align-items: center;
        gap: 2.5rem;
        flex-wrap: wrap;
    }

    .gwc-split-body {
        flex: 1 1 420px;
        min-width: 0;
        color: var(--gwc-text-soft);
        font-size: 1.05rem;
        line-height: 1.7;
    }

        .gwc-split-body p {
            margin: 0 0 1rem;
        }

            .gwc-split-body p:last-child {
                margin-bottom: 0;
            }

    .gwc-split-media {
        flex: 1 1 380px;
        display: flex;
        justify-content: center;
        min-width: 0;
    }

        .gwc-split-media img {
            width: 100%;
            max-width: 440px;
            border-radius: var(--gwc-radius);
            box-shadow: var(--gwc-shadow);
        }

    /* Icon feature grid */
    .gwc-icon-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1.25rem;
    }

    .gwc-icon-card {
        text-align: center;
        padding: 1.5rem 1.25rem;
        background: #fff;
        border: 1px solid rgba(239, 178, 196, 0.4);
        border-radius: var(--gwc-radius);
        box-shadow: 0 4px 16px rgba(212, 149, 168, 0.1);
        transition: transform 0.18s ease, box-shadow 0.18s ease;
    }

        .gwc-icon-card:hover {
            transform: translateY(-3px);
            box-shadow: var(--gwc-shadow);
        }

    .gwc-icon-circle {
        width: 72px;
        height: 72px;
        margin: 0 auto 0.85rem;
        border-radius: 50%;
        background: rgba(239, 178, 196, 0.25);
        border: 2px solid rgba(239, 178, 196, 0.55);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--gwc-brand-deep);
    }

        .gwc-icon-circle svg {
            width: 32px;
            height: 32px;
        }

    .gwc-icon-card h3 {
        margin: 0 0 0.45rem;
        font-size: 1.05rem;
        font-weight: 800;
    }

    .gwc-icon-card p {
        margin: 0;
        color: var(--gwc-text-soft);
        font-size: 0.95rem;
        line-height: 1.55;
    }

    /* PDF split card */
    .gwc-split-card {
        display: grid;
        grid-template-columns: 1fr 1fr;
        align-items: stretch;
        background: #fff;
        border: 1px solid rgba(239, 178, 196, 0.45);
        border-radius: var(--gwc-radius);
        box-shadow: var(--gwc-shadow);
        overflow: hidden;
    }

    .gwc-split-card-media {
        position: relative;
        background: linear-gradient(145deg, rgba(239, 178, 196, 0.3), rgba(239, 178, 196, 0.12));
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1.5rem;
        min-height: 16rem;
    }

        .gwc-split-card-media img {
            width: 100%;
            max-width: 360px;
            border-radius: 0.65rem;
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
        }

    .gwc-pdf-badge {
        position: absolute;
        top: 1rem;
        left: 1rem;
        padding: 0.25rem 0.55rem;
        border-radius: 0.45rem;
        background: var(--gwc-text);
        color: #fff;
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.06em;
    }

    .gwc-split-card-body {
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 0.75rem;
        padding: 2rem;
    }

        .gwc-split-card-body h3 {
            margin: 0;
            font-size: 1.2rem;
            font-weight: 800;
        }

        .gwc-split-card-body p {
            margin: 0;
            color: var(--gwc-text-soft);
            line-height: 1.65;
            font-size: 0.98rem;
        }

    .gwc-split-card-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.65rem;
        margin-top: 0.35rem;
    }

    /* Shared buttons */
    .gwc-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.7rem 1.25rem;
        border-radius: 999px;
        background: var(--gwc-brand);
        color: #111;
        font-weight: 700;
        font-size: 0.95rem;
        text-decoration: none;
        border: 2px solid transparent;
        transition: background 0.18s ease, transform 0.15s ease;
    }

        .gwc-btn:hover {
            background: var(--gwc-brand-dark);
            transform: translateY(-1px);
        }

    .gwc-btn-outline {
        background: transparent;
        border-color: var(--gwc-brand-dark);
        color: var(--gwc-text);
    }

        .gwc-btn-outline:hover {
            background: var(--gwc-brand);
            border-color: var(--gwc-brand);
        }

    .gwc-policy-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1.25rem;
    }

    .gwc-policy-card {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 0.65rem;
        padding: 1.5rem;
        background: #fff;
        border: 1px solid rgba(239, 178, 196, 0.45);
        border-radius: var(--gwc-radius);
        box-shadow: 0 4px 18px rgba(0, 0, 0, 0.06);
        transition: transform 0.18s ease, box-shadow 0.18s ease;
    }

        .gwc-policy-card:hover {
            transform: translateY(-3px);
            box-shadow: var(--gwc-shadow);
        }

    .gwc-policy-label {
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #c45f7a;
    }

    .gwc-policy-card h3 {
        margin: 0;
        font-size: 1.2rem;
        font-weight: 800;
    }

    .gwc-policy-card p {
        margin: 0;
        flex: 1;
        color: var(--gwc-text-soft);
        line-height: 1.6;
        font-size: 0.98rem;
    }

    .gwc-policy-card .gwc-btn {
        margin-top: 0.35rem;
    }

    .gwc-news-empty {
        text-align: center;
        color: var(--gwc-text-soft);
        margin: 0;
    }

    .gwc-news-list {
        max-width: 52rem;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .gwc-news-card {
        display: grid;
        grid-template-columns: 5.5rem 1fr;
        align-items: stretch;
        background: #fff;
        border: 1px solid rgba(239, 178, 196, 0.35);
        border-radius: var(--gwc-radius);
        box-shadow: 0 4px 16px rgba(212, 149, 168, 0.1);
        overflow: hidden;
        transition: transform 0.18s ease, box-shadow 0.18s ease;
    }

        .gwc-news-card:hover {
            transform: translateY(-2px);
            box-shadow: var(--gwc-shadow);
        }

    .gwc-news-date {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 0.85rem 0.5rem;
        font-weight: 800;
        text-align: center;
    }

        .gwc-news-date .day {
            font-size: 1.5rem;
            line-height: 1;
        }

        .gwc-news-date .mon {
            font-size: 0.8rem;
            letter-spacing: 0.06em;
            text-transform: uppercase;
            margin-top: 0.15rem;
        }

    .gwc-news-body {
        padding: 1rem 1.25rem 1.1rem 1.25rem;
    }

    .gwc-news-title-row {
        display: flex;
        align-items: center;
        gap: 0.65rem;
        margin-bottom: 0.45rem;
    }

    .gwc-news-icon {
        width: 1.75rem;
        height: 1.75rem;
        object-fit: contain;
        flex-shrink: 0;
        border-radius: 22%;
    }

    .gwc-news-title-row h3 {
        margin: 0;
        font-size: 1.05rem;
        font-weight: 800;
        line-height: 1.3;
    }

    .gwc-news-body p {
        margin: 0;
        color: var(--gwc-text-soft);
        font-size: 0.95rem;
        line-height: 1.6;
    }

    .gwc-news-actions {
        margin-top: 1.75rem;
        text-align: center;
    }

    /* Footer */
    .gwc-footer {
        width: 100vw;
        margin-left: calc(50% - 50vw);
        margin-right: calc(50% - 50vw);
        padding: 3rem 1.5rem;
        background: var(--gwc-muted);
        border-top: 1px solid rgba(239, 178, 196, 0.35);
        text-align: center;
    }

    .gwc-footer-inner h3 {
        margin: 0 0 0.75rem;
        font-size: 1rem;
        font-weight: 800;
    }

    .gwc-footer-links {
        list-style: none;
        margin: 0 0 1.5rem;
        padding: 0;
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 0.75rem 1.25rem;
    }

        .gwc-footer-links a {
            color: var(--gwc-text);
            text-decoration: none;
            font-weight: 600;
            font-size: 0.95rem;
        }

            .gwc-footer-links a:hover {
                color: var(--gwc-brand-deep);
            }

