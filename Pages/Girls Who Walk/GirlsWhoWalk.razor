@code {
    private List<NewsItem> GirlsWhoWalkNotes = new();

    protected override async Task OnInitializedAsync()
    {
        if (Http.BaseAddress is null)
            Http.BaseAddress = new Uri(Nav.BaseUri);

        var items = await NewsData.GetNewsAsync("GirlsWhoWalkPatchNotes.json");
        GirlsWhoWalkNotes = items
    .Where(n => n.Tags?.Contains("Girls Who Walk") == true)
    .OrderByDescending(n => n.Date)
    .Take(3) // ✅ only the 3 most recent
    .ToList();
    }
}

