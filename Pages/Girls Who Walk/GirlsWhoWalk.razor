    .pdf-preview-landscape,
    .pdf-content {
        flex: none;
        width: 100%;
        max-width: 580px;
        margin: 0 auto;
    }

    .pdf-image {
        width: 100%;
        max-width: 520px;
        height: auto;
    }

    .pdf-content {
        text-align: center;
    }

    .pdf-actions {
        justify-content: center;
    }

    }
</style>


<!-- ===== Policies ===== -->
<section class="policy-cta" aria-labelledby="policy-cta-title">
    <div class="policy-cta-inner">
        <h2 id="policy-cta-title">Important Policies</h2>
        <p class="policy-cta-desc">
            We’re committed to privacy and safety across the Girls Who Connect community.
            Learn how we protect your data and the standards we follow to keep young users safe.
        </p>

        <div class="policy-card-grid">
            <!-- Privacy Policy -->
            <article class="policy-card">
                <h3>Privacy Policy</h3>
                <p>
                    See what data we collect, how we use it, and the controls you have to manage your privacy.
                </p>
                <NavLink class="btn" href="/girlswhoconnect/PrivacyPolicy" aria-label="Read our Privacy Policy">
                    Read Privacy Policy
                </NavLink>
            </article>

            <!-- Child Safety Standards -->
            <article class="policy-card">
                <h3>Child Safety Standards</h3>
                <p>
                    Review our safety-by-design standards, moderation practices, and reporting tools for young users.
                </p>
                <NavLink class="btn" href="/girlswhoconnect/ChildSafetyStandards" aria-label="Read our Child Safety Standards">
                    View Safety Standards
                </NavLink>
            </article>
        </div>
    </div>
</section>

<hr class="section-divider" />

<style>
    .policy-cta {
        background: #ffffff;
        color: #111;
        padding: 2.75rem 1rem 2rem;
        box-sizing: border-box;
    }

    .policy-cta-inner {
        width: min(var(--page-max, 1100px), 100%); /* ✅ prevent overflow in padded parent */
        margin: 0 auto;
        text-align: center;
    }

    .policy-cta h2 {
        margin: 0 0 .6rem 0;
        font-size: clamp(1.3rem, 3vw, 1.8rem);
        font-weight: 800;
    }

    .policy-cta-desc {
        margin: 0 auto 1.5rem;
        max-width: 60ch;
        color: #333;
        line-height: 1.55;
    }

    /* Layout */
    .policy-card-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: var(--gap, 1.25rem);
        align-items: stretch;
        justify-items: stretch;
    }

    .policy-card {
        text-align: left;
        background: #fff;
        border-radius: var(--radius, 16px);
        border: 1px solid rgba(239,178,196,.45);
        box-shadow: 0 10px 24px rgba(0,0,0,.08);
        padding: 1.25rem 1.25rem 1.35rem;
        display: grid;
        align-content: start;
        gap: .65rem;
        transition: transform .18s ease, box-shadow .18s ease;
    }

        .policy-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 14px 28px rgba(0,0,0,.12);
        }

        .policy-card h3 {
            margin: 0;
            font-size: 1.1rem;
            font-weight: 800;
        }

        .policy-card p {
            margin: 0;
            color: #333;
            line-height: 1.5;
        }

        /* Buttons (pink background, black text) */
        .policy-card .btn {
            margin-top: .6rem;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: #efb2c4;
            color: #000;
            border: none;
            border-radius: 999px;
            padding: 0.65rem 1.1rem;
            font-weight: 700;
            text-decoration: none;
            transition: background 0.2s ease, transform 0.15s ease;
        }

            .policy-card .btn:hover {
                background: #d495a8;
                transform: translateY(-2px);
            }

    /* Mobile */
    @@media (max-width: 760px) {
        .policy-card-grid {
            grid-template-columns: 1fr; /* stack */
            justify-items: center; /* ✅ center the cards themselves */
        }

        .policy-card {
            text-align: center; /* ✅ center text */
            width: 100%;
            max-width: 520px; /* ✅ avoid edge-to-edge look */
        }

            .policy-card .btn {
                width: 100%; /* ✅ full-width button centered */
                justify-content: center;
            }
    }
</style>



<!-- ===== News & Updates ===== -->
<section class="news-section" aria-labelledby="news-title">
    <div class="news-header">
        <h2 id="news-title">
            Patch Notes
            <NavLink href="/GirlsWhoConnect/PatchNotes">
                <svg class="news-arrow" xmlns="http://www.w3.org/2000/svg"
                     viewBox="0 0 24 24" width="18" height="18"
                     fill="none" stroke="black" stroke-width="4"
                     stroke-linecap="round" stroke-linejoin="round">
                    <path d="M8 5l8 7-8 7" />
                </svg>
            </NavLink>
        </h2>
    </div>

    <div class="news-grid">
        @foreach (var item in GirlsWhoConnectNotes)
        {
            <article class="news-card">
                <!-- Gradient header with title -->
                <div class="news-header-bar"
                     style="background: linear-gradient(180deg, @item.TopColour, @item.BottomColour);">
                    <h3>@item.Title</h3>
                </div>

                <!-- Body content -->
                <div class="news-body">
                    <p>@((MarkupString)item.Summary)</p>

                    @if (!string.IsNullOrEmpty(item.Summary) && item.Summary.Length > 200)
                    {
                        <a class="news-link" href="/GirlsWhoConnect/PatchNotes">Read more</a>
                    }
                </div>

                <!-- Date badge -->
                <div class="news-date"
                     style="background: linear-gradient(180deg, @item.TopColour, @item.BottomColour); color: @item.DateTextColour;">
                    <span class="day">@item.Date.ToString("dd")</span>
                    <span class="mon">@item.Date.ToString("MMM", CultureInfo.InvariantCulture)</span>
                    <span class="yr">@item.Date.ToString("yyyy")</span>
                </div>
            </article>
        }
    </div>
</section>

<style>
