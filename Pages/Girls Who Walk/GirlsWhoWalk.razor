@page "/GirlsWhoConnect"
@using System.Globalization
@using KenyonDevLabs.Models
@using KenyonDevLabs.Services
@inject HttpClient Http
@inject NewsFileService NewsData
@inject NavigationManager Nav
<PageTitle>Girls Who Connect</PageTitle>

<GirlsWhoWalkHeader />
<section class="hero-section">
    <div class="hero-inner">
        <div class="hero-content">
            <div class="hero-image">
                <img src="images/Girls Who Connect/3 phones graphic.png" alt="Girls Who Connect" />
            </div>

            <div class="hero-text">
                <h1>Welcome to Girls Who Connect</h1>
                <p>
                    Stay up to date with Girls Who Connect in your area - discover upcoming walks, 
                    connect with local members, and see everything happening in your community.
                </p>

                <!-- ✅ App Store Button -->
                <a href="https://apps.apple.com/gb/app/girls-who-walk/id6477972997"
                   target="_blank"
                   rel="noopener noreferrer"
                   class="appstore-btn">
                    <img src="images/App Store Button.png" alt="Download on the App Store" />
                </a>
            </div>
        </div>
    </div>
</section>

<style>
    :root {
        --brand: #efb2c4;
    }

    html, body {
        overflow-x: clip;
    }

    .hero-section {
        position: relative;
        display: flex;
        justify-content: center;
        align-items: flex-start;
        width: 200%;
        left: 50%;
        transform: translateX(-50%);
        height: 150%;
        padding-top: calc((var(--hero-extra, 20%) / 2));
        padding-bottom: 100px;
        box-sizing: border-box;
        z-index: 1;
        overflow: hidden;
        background: var(--brand);
        margin-top: -6rem;
    }

    .hero-inner {
        padding-top: 5vh;
        margin: 0 auto;
        width: min(var(--page-max, 1100px), 50%);
    }

    .hero-section::after {
        content: "";
        position: absolute;
        left: 0;
        right: 0;
        bottom: -65px;
        height: 140px;
        pointer-events: none;
        z-index: 0;
        background-repeat: no-repeat;
        background-position: bottom center;
        background-size: 100% 100%;
        transform: translateY(-16px);
        background-image: url('data:image/svg+xml;utf8,<svg viewBox="0 0 1440 120" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none"><path d="M0,32 C240,96 480,0 720,48 C960,96 1200,32 1440,64 L1440,120 L0,120 Z" fill="%23ffffff"/></svg>');
    }

    .hero-content {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 2rem;
        flex-wrap: wrap;
        flex-direction: row;
    }

    .hero-text {
        flex: 1 1 400px;
        color: #111;
        text-align: left;
        order: 1;
    }

        .hero-text h1 {
            font-size: clamp(1.8rem, 3vw, 2.4rem);
            font-weight: 800;
            margin-bottom: 1rem;
            color: #111;
        }

        .hero-text p {
            font-size: 1.05rem;
            line-height: 1.5;
            color: #333;
            margin-bottom: 1.5rem;
            max-width: 500px;
        }

    /* ✅ App Store Button */
    .appstore-btn img {
        width: 120px;
        height: auto;
        transition: transform 0.2s ease;
    }

    .appstore-btn:hover img {
        transform: scale(1.05);
    }

    .hero-image {
        flex: 1 1 400px;
        display: flex;
        justify-content: center;
        align-items: center;
        order: 2;
    }

        .hero-image img {
            display: block;
            width: 100%;
            max-width: 500px;
            height: auto;
            object-fit: contain;
            border-radius: 16px;
            transition: transform 0.3s ease;
        }

    /* ===== Responsive ===== */
    @@media (max-width: 800px) {
        .hero-section {
            flex-direction: column;
            text-align: center;
            padding-bottom: 95px;
        }

            .hero-section::after {
                height: 120px;
                transform: translateY(-12px);
            }

        .hero-text {
            text-align: center;
            order: 2;
        }

        .appstore-btn img {
            width: 160px;
        }

        .hero-image img {
            max-width: 340px;
            order: 1;
        }
    }

    @@media (max-width: 400px) {
        .hero-content {
            margin-top: 2rem;
        }
    }
</style>



<!-- ===== About / Info Section ===== -->
<section class="info-section" aria-labelledby="info-title">
    <div class="info-inner">
        <h2 id="info-title">Our Mission</h2>

        <div class="info-content">
            <div class="info-text">
                <p>
                    Girls Who Connect helps women discover local walking groups, make new friends,
                    and explore their area safely. The app was created to give communities their
                    space to organise walks, plan routes, and stay in touch within a supportive
                    environment designed just for them. 
                </p>
                <p>
                    It’s not only a way to get active and meet people, 
                    but also a platform shaped by its users. Feedback goes 
                    directly to the developer, helping the app evolve into the kind 
                    of social, stylish experience the community wants it to be.
                </p>
            </div>

            <div class="info-image">
                <img src="images/Girls Who Connect/Connect Graphic.png"
                     alt="Girls Who Connect community group"
                     loading="lazy" />
            </div>
        </div>
    </div>
</section>
<hr class="section-divider" />
<style>
    /* ===== Info Section (Text + Image) ===== */
    .info-section {
        color: #111;
        padding: 3rem 1rem; /* padding stays */
        box-sizing: border-box;
    }

    .info-inner {
        width: min(var(--page-max, 1100px), 100%); /* ✅ no overflow in padded parent */
        margin: 0 auto;
    }

    .info-section h2 {
        text-align: center;
        font-size: clamp(1.4rem, 3vw, 2rem);
        font-weight: 800;
        margin: 0 0 1.5rem 0;
    }

    .info-content {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 2rem;
        flex-wrap: wrap;
    }

    .info-text {
        flex: 1 1 480px;
        color: #333;
        line-height: 1.6;
        font-size: 1.05rem;
        min-width: 0;
    }

        .info-text p {
            margin-bottom: 1rem;
        }

    .info-image {
        flex: 1 1 420px;
        display: flex;
        justify-content: center;
        min-width: 0;
    }

        .info-image img {
            display: block;
            width: 100%;
            max-width: 480px;
            height: auto;
            margin: 0 auto;
            border-radius: var(--radius, 16px);
            box-shadow: 0 10px 24px rgba(0,0,0,.1);
        }

    /* ===== Responsive Stack ===== */
    @@media (max-width: 800px) {
        .info-inner

    {
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .info-content {
        flex-direction: column-reverse;
        align-items: center;
        justify-content: center;
        text-align: center;
        gap: 1.5rem;
    }

    .info-text,
    .info-image {
        flex: 0 0 auto;
        width: 100%;
        max-width: 480px;
        margin: 0 auto;
    }

        .info-image img {
            width: 100%;
            max-width: 360px;
            height: auto;
        }

    }
</style>



<!-- ===== Feature Icons ===== -->
<section class="features-section" aria-labelledby="features-title">
    <div class="features-inner">
        <h2 id="features-title">App Functionality</h2>

        <div class="feature-grid">
            <!-- 1) Find Local Walks -->
            <article class="feature-card">
                <div class="icon-circle" aria-hidden="true">
                    <!-- Map Pin -->
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                         aria-hidden="true">
                        <path d="M12 22s7-6.2 7-12a7 7 0 1 0-14 0c0 5.8 7 12 7 12Z" />
                        <circle cx="12" cy="10" r="3" />
                    </svg>
                </div>
                <h3>Find Local Walks</h3>
                <p>Easily discover nearby walking groups and events - complete with time, location, capacity, and walk leaders at a glance.</p>
            </article>

            <!-- 2) Meet New People -->
            <article class="feature-card">
                <div class="icon-circle" aria-hidden="true">
                    <!-- Heart -->
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                         aria-hidden="true">
                        <path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.6l-1-1a5.5 5.5 0 0 0-7.8 7.8l1 1L12 22l7.8-8.6 1-1a5.5 5.5 0 0 0 0-7.8Z" />
                    </svg>
                </div>
                <h3>Meet New People</h3>
                <p>Connect with friendly walkers, grow your social circle, and chat with new friends right in the app.</p>
            </article>

            <!-- 3) Personalise Your Space -->
            <article class="feature-card">
                <div class="icon-circle" aria-hidden="true">
                    <!-- User / Customisation Icon -->
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                         aria-hidden="true">
                        <circle cx="12" cy="8" r="4" />
                        <path d="M4 20c0-4 4-6 8-6s8 2 8 6" />
                    </svg>
                </div>
                <h3>Personalise Your Space</h3>
                <p>
                    Make the app your own by customising your profile, adjusting preferences,
                    and creating a space that reflects your personality.
                </p>
            </article>

        </div>
    </div>
</section>

<hr class="section-divider" />

<style>
    /* ===== Feature Icons ===== */
    :root {
        --brand-dark: #b14c66; /* darker accent for icons */
        --circle-bg: rgba(239,178,196,.22); /* soft brand tint */
        --circle-border: rgba(239,178,196,.55);
    }

    .features-section {
        color: #111;
        padding: 2.75rem 1rem;
        box-sizing: border-box;
    }

    .features-inner {
        width: min(var(--page-max, 1100px), 100%); /* ✅ prevent overflow in padded parent */
        margin: 0 auto; /* ✅ keep perfectly centered */
    }

    .features-section h2 {
        margin: 0 0 1.25rem 0;
        text-align: center;
        font-size: clamp(1.4rem, 3vw, 2rem);
        font-weight: 800;
    }

    .feature-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: var(--gap, 1.25rem);
        align-items: stretch;
        justify-items: stretch;
    }

    .feature-card {
        text-align: center;
        padding: 1.25rem 1rem 1.4rem;
        border-radius: var(--radius, 12px);
        background: #fff;
        box-shadow: 0 6px 16px rgba(0,0,0,.08);
        transition: transform .18s ease, box-shadow .18s ease;
    }

        .feature-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 22px rgba(0,0,0,.12);
        }

    .icon-circle {
        width: 84px;
        height: 84px;
        margin: 0 auto .75rem;
        border-radius: 50%;
        background: var(--circle-bg);
        border: 2px solid var(--circle-border);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--brand-dark);
    }

        .icon-circle svg {
            width: 36px;
            height: 36px;
            display: block;
        }

    .feature-card h3 {
        margin: .25rem 0 .35rem 0;
        font-size: 1.05rem;
        font-weight: 800;
    }

    .feature-card p {
        margin: 0;
        color: #333;
        line-height: 1.45;
        max-width: 28ch;
        display: inline-block;
    }

    /* Responsive stack */
    @@media (max-width: 900px) {
        .feature-grid {
            grid-template-columns: repeat(2, 1fr);
            justify-items: stretch;
        }
    }

    @@media (max-width: 620px) {
        .feature-grid {
            grid-template-columns: 1fr; /* single column */
            justify-items: center; /* ✅ center cards in the column */
        }

        .feature-card {
            width: 100%;
            max-width: 520px; /* ✅ avoid edge-to-edge look on tiny screens */
        }

        .icon-circle {
            width: 78px;
            height: 78px;
        }

            .icon-circle svg {
                width: 32px;
                height: 32px;
            }
    }

    /* Divider between sections */
    hr.section-divider {
        border: none;
        height: 4px;
        width: 100%;
        max-width: 1000px;
        margin: 10px auto;
        background: #efb2c4;
        border-radius: 0;
        padding-inline: 10px;
        box-sizing: border-box;
    }
</style>

<!-- ===== PDF Overview ===== -->
<section class="pdf-section" aria-labelledby="pdf-title">
    <div class="pdf-inner">
        <h2 id="pdf-title">Want to sign up?</h2>

        <article class="pdf-card landscape">
            <!-- Left side: PDF image preview -->
            <div class="pdf-preview-landscape" aria-hidden="true">
                <div class="pdf-page-landscape">
                    <img src="/images/Girls Who Connect/PDF_Cover.png"
                         alt="Girls Who Connect Overview Preview"
                         class="pdf-image" />
                </div>
                <div class="pdf-ribbon">PDF</div>
            </div>

            <!-- Right side: PDF description and actions -->
            <div class="pdf-content">
                <h3>Pitch Deck</h3>
                <p>
                    It's easy to become a part of the Girls Who Connect App. To get your group involved,
                    encourage the admin to view the website or get in contact with matt@kenyondevlabs.com.
                    All the details of the app are presented in this document, along with how to get
                    set up and how to get the most out of the app.
                </p>

                <div class="pdf-actions">

                    <a class="btn view"
                       href="Files/Girls_Who_Connect_Details.pdf"
                       target="_blank" rel="noopener">
                        View PDF
                    </a>
                    <a class="btn ghost"
                       href="Files/Girls_Who_Connect_Details.pdf"
                       download>
                        Download
                    </a>
                </div>
            </div>
        </article>
    </div>
</section>

<hr class="section-divider" />

<style>
    /* ===== PDF Overview Section ===== */
    .pdf-section {
        background: #ffffff;
        color: #111;
        padding: 3rem 1rem;
        box-sizing: border-box;
    }

    .pdf-inner {
        width: min(var(--page-max, 1100px), 100%);
        margin: 0 auto;
    }

    .pdf-section h2 {
