@page "/GirlsWhoConnect/PrivacyPolicy"

<PageTitle>Privacy Policy - Girls Who Connect</PageTitle>

<GirlsWhoWalkHeader />

<div class="gwc-page">

    <section class="gwc-section gwc-hero gwc-hero-compact">
        <div class="gwc-container gwc-hero-grid">
            <div class="gwc-hero-copy">
                <span class="gwc-eyebrow gwc-eyebrow-hero">Legal</span>
                <h1>Privacy Policy</h1>
                <p>
                    How Girls Who Connect collects, uses, and protects your personal information.
                </p>
                <p class="gwc-effective-date">Effective 27 October 2025</p>
            </div>
            <div class="gwc-hero-visual">
                <img src="/images/Girls Who Connect/Lock.png" alt="" aria-hidden="true" />
            </div>
        </div>
    </section>

    <section class="gwc-section gwc-section-muted gwc-legal-section" aria-labelledby="policy-title">
        <div class="gwc-container">
            <header class="gwc-section-head">
                <span class="gwc-eyebrow">Legal</span>
                <h2 id="policy-title">Privacy policy</h2>
                <p class="gwc-section-lead">@SectionCount section@(SectionCount == 1 ? "" : "s") covered.</p>
            </header>

            <div class="gwc-policy-blocks">

                <article class="gwc-policy-block" id="consent">
                    <h2>Consent</h2>
                    <p>By using Girls Who Connect, you consent to the terms outlined in this Privacy Policy.</p>
                </article>

                <article class="gwc-policy-block" id="disclaimer">
                    <h2>Disclaimer</h2>
                    <p>
                        Girls Who Connect is an independent community app created by Kenyon Dev Labs.
                        It is not affiliated with, endorsed by, or officially connected to
                        any “Girls Who Walk” groups, organisations, or trademarks. Any references to “Girls
                        Who Walk” are made solely to describe the type of community experience this app supports.
                    </p>
                </article>

                <article class="gwc-policy-block" id="image-sharing">
                    <h2>Image sharing</h2>
                    <p>
                        Users can upload images from their camera roll to use as profile pictures.
                        Profile images are public and visible to other users. Admins can also upload
                        images to be used as covers for events, which are public and visible to all
                        users. Users are able to edit and remove their uploaded images at any time
                        through the app.
                    </p>
                    <p>
                        Please ensure any images uploaded are appropriate and suitable for viewing
                        by others. Inappropriate content includes, but is not limited to, images
                        that are offensive, sexually explicit, violent, defamatory, or violate the
                        rights of others. We reserve the right to remove any image that violates these
                        guidelines.
                    </p>
                </article>

                <article class="gwc-policy-block" id="advertisements">
                    <h2>Advertisements</h2>
                    <p>
                        When you use Girls Who Connect, we may collect information through services such
                        as Google AdMob, including:
                    </p>
                    <ul>
                        <li><strong>Personal information:</strong> Includes data that can identify you, such as your device ID, IP address, and other device-specific details.</li>
                        <li><strong>Non-personal information:</strong> Includes aggregated or anonymised data such as device type, operating system, general location, and usage statistics.</li>
                    </ul>
                    <p>
                        Advertisements help support the ongoing development and maintenance of the app.
                        Revenue generated from ads allows us to fund backend infrastructure and invest
                        more time and resources into improving the overall experience for our community.
                    </p>
                </article>

                <article class="gwc-policy-block" id="collected-information">
                    <h2>How we use collected information</h2>
                    <p>
                        Girls Who Connect collects and stores certain information to enable core features
                        and personalise your experience. This includes:
                    </p>
                    <ul>
                        <li>Username - used to identify you within the app and display on your profile</li>
                        <li>Email address - used for account management and communication</li>
                        <li>Walking location - used to show events and chat groups relevant to your area</li>
                        <li>Language - used to display content in your preferred language</li>
                        <li>Role (user, admin, or developer) - used to manage access to admin and moderation features</li>
                    </ul>
                    <p>
                        This data is stored securely and is only accessible to authorised members of the
                        Girls Who Connect team where necessary.
                    </p>
                </article>

                <article class="gwc-policy-block" id="advertisements-use">
                    <h2>How advertisements use information</h2>
                    <p>
                        Information collected by third-party services such as Google AdMob may be used for:
                    </p>
                    <ul>
                        <li>Serving personalised advertisements relevant to your interests and behaviour</li>
                        <li>Measuring the effectiveness of adverts displayed in the app</li>
                        <li>Providing aggregated reporting to help us understand user engagement with ads</li>
                        <li>Improving ad quality, frequency, and relevance based on user data</li>
                    </ul>
                    <p>
                        For more details on how Google uses this data, you may review Google's advertising
                        privacy policies directly.
                    </p>
                </article>

                <article class="gwc-policy-block" id="data-security">
                    <h2>Data security</h2>
                    <p>
                        We use reasonable administrative, technical, and physical safeguards to protect your
                        data from unauthorised access or misuse. However, please be aware that no system can
                        guarantee absolute security over the internet.
                    </p>
                </article>

                <article class="gwc-policy-block" id="account-deletion">
                    <h2>Account deletion</h2>
                    <p>
                        To delete your account and remove your personal data, go to the account settings
                        and tap the "Delete Account" button.
                    </p>
                </article>

                <article class="gwc-policy-block" id="updates">
                    <h2>Updates to this policy</h2>
                    <p>
                        We may update this Privacy Policy from time to time. Any changes will be reflected
                        with a new effective date listed at the top of this page.
                    </p>
                </article>

                <article class="gwc-policy-block" id="contact">
                    <h2>Contact</h2>
                    <p>
                        If you have any questions or concerns about this Privacy Policy, please contact us at
                        <a href="mailto:matt@kenyondevlabs.com">matt@kenyondevlabs.com</a>.
                    </p>
                    <p>
                        By using Girls Who Connect, you acknowledge that you have read, understood, and agree to
                        the terms outlined in this Privacy Policy. If you have any questions, suggestions, or
                        concerns, you can send feedback or report issues directly within the app using the
                        built-in feedback and reporting features.
                    </p>
                </article>

            </div>
        </div>
    </section>

    <footer class="gwc-footer">
        <div class="gwc-container gwc-footer-inner">
            <nav aria-label="Legal">
                <h3>Legal</h3>
                <ul class="gwc-footer-links">
                    <li><NavLink href="/GirlsWhoConnect/PrivacyPolicy">Privacy Policy</NavLink></li>
                    <li><NavLink href="/GirlsWhoConnect/ChildSafetyStandards">Child Safety Standards</NavLink></li>
                </ul>
            </nav>
            <p class="gwc-footer-copy">&copy; @DateTime.Now.Year Kenyon Dev Labs</p>
        </div>
    </footer>

</div>

<style>
    :root {
        --gwc-brand: #efb2c4;
        --gwc-brand-dark: #d495a8;
        --gwc-brand-deep: #b14c66;
        --gwc-muted: #fff5f8;
        --gwc-text: #1a1a1a;
        --gwc-text-soft: #4a4a4a;
        --gwc-max: 1080px;
        --gwc-radius: 1rem;
    }

    html, body {
        overflow-x: clip;
        font-family: var(--font-sans, 'Plus Jakarta Sans', system-ui, sans-serif);
    }

    body {
        background: #fff;
        color: var(--gwc-text);
    }

    .gwc-page { overflow-x: clip; }

    .gwc-section {
        width: 100vw;
        margin-left: calc(50% - 50vw);
        margin-right: calc(50% - 50vw);
        padding: 4rem 1.5rem;
        box-sizing: border-box;
        border-top: 1px solid rgba(239, 178, 196, 0.35);
    }

    .gwc-section-muted { background: var(--gwc-muted); }

    .gwc-container {
        max-width: var(--gwc-max);
        margin: 0 auto;
    }

    .gwc-section-head {
        max-width: 42rem;
        margin: 0 auto 2.5rem;
        text-align: center;
    }

    .gwc-section-head h2 {
        margin: 0;
        font-size: clamp(1.6rem, 3vw, 2.1rem);
        font-weight: 800;
        letter-spacing: -0.02em;
        line-height: 1.15;
    }

        .gwc-section-head h2::after {
            content: "";
            display: block;
            width: 3rem;
            height: 3px;
            margin: 1rem auto 0;
            background: var(--gwc-brand-dark);
            border-radius: 999px;
        }

    .gwc-section-lead {
        margin: 1.15rem 0 0;
        color: var(--gwc-text-soft);
        font-size: 1.05rem;
        line-height: 1.65;
    }

    .gwc-hero {
        border-top: none;
        padding: 3rem 1.5rem 5rem;
        background: linear-gradient(160deg, var(--gwc-brand) 0%, var(--gwc-brand-dark) 100%);
        position: relative;
    }

        .gwc-hero::after {
            content: "";
            position: absolute;
            left: 0; right: 0; bottom: -1px;
            height: 64px;
            background: var(--gwc-muted);
            clip-path: ellipse(55% 100% at 50% 100%);
        }

    .gwc-hero-compact { padding-bottom: 4.5rem; }

    .gwc-hero-grid {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 2.5rem;
        flex-wrap: wrap;
        position: relative;
        z-index: 1;
    }

    .gwc-hero-copy { flex: 1 1 360px; }

    .gwc-eyebrow {
        display: inline-block;
        margin-bottom: 0.75rem;
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: #c45f7a;
    }

    .gwc-eyebrow-hero { color: var(--gwc-brand-deep); }

    .gwc-hero-copy h1 {
        margin: 0 0 0.85rem;
        font-size: clamp(2rem, 4.5vw, 2.75rem);
        font-weight: 800;
        letter-spacing: -0.03em;
        line-height: 1.1;
    }

    .gwc-hero-copy p {
        margin: 0;
        max-width: 32rem;
        font-size: 1.08rem;
        line-height: 1.65;
        color: var(--gwc-text-soft);
    }

    .gwc-effective-date {
        display: inline-block;
        margin-top: 1.15rem !important;
        padding: 0.35rem 0.85rem;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.55);
        font-size: 0.88rem !important;
        font-weight: 700;
        color: var(--gwc-brand-deep) !important;
    }

    .gwc-hero-visual {
        flex: 1 1 240px;
        display: flex;
        justify-content: center;
    }

        .gwc-hero-visual img {
            width: 100%;
            max-width: 200px;
            filter: drop-shadow(0 16px 32px rgba(0, 0, 0, 0.12));
        }

    .gwc-policy-blocks {
        max-width: 48rem;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        gap: 1.15rem;
    }

    .gwc-policy-block {
        padding: 1.5rem 1.75rem;
        background: #fff;
        border: 1px solid rgba(239, 178, 196, 0.4);
        border-radius: var(--gwc-radius);
        box-shadow: 0 4px 16px rgba(212, 149, 168, 0.08);
    }

        .gwc-policy-block h2 {
            margin: 0 0 0.85rem;
            font-size: 1.15rem;
            font-weight: 800;
            padding-bottom: 0.65rem;
            border-bottom: 2px solid rgba(239, 178, 196, 0.35);
        }

        .gwc-policy-block p {
            margin: 0 0 0.85rem;
            color: var(--gwc-text-soft);
            line-height: 1.7;
            font-size: 1rem;
        }

            .gwc-policy-block p:last-child { margin-bottom: 0; }

        .gwc-policy-block ul {
            margin: 0 0 0.85rem;
            padding-left: 1.25rem;
            color: var(--gwc-text-soft);
            line-height: 1.65;
        }

        .gwc-policy-block li { margin-bottom: 0.4rem; }

        .gwc-policy-block a {
            color: var(--gwc-brand-deep);
            font-weight: 600;
        }

    .gwc-footer {
        width: 100vw;
        margin-left: calc(50% - 50vw);
        margin-right: calc(50% - 50vw);
        padding: 3rem 1.5rem;
        background: var(--gwc-muted);
        border-top: 1px solid rgba(239, 178, 196, 0.35);
        text-align: center;
    }

    .gwc-footer-inner h3 {
        margin: 0 0 0.75rem;
        font-size: 1rem;
        font-weight: 800;
    }

    .gwc-footer-links {
        list-style: none;
        margin: 0 0 1.5rem;
        padding: 0;
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 0.75rem 1.25rem;
    }

        .gwc-footer-links a {
            color: var(--gwc-text);
            text-decoration: none;
            font-weight: 600;
        }

            .gwc-footer-links a:hover { color: var(--gwc-brand-deep); }

    .gwc-footer-copy {
        margin: 0;
        color: var(--gwc-text-soft);
        font-size: 0.92rem;
    }

    @@media (max-width: 760px) {
        .gwc-section { padding: 3rem 1.25rem; }
        .gwc-hero-grid { flex-direction: column; text-align: center; }
        .gwc-hero-copy p { margin-left: auto; margin-right: auto; }
        .gwc-policy-block { padding: 1.25rem 1.35rem; }
    }
</style>

@code {
    private const int SectionCount = 10;
}
