@page "/GirlsWhoConnect/PatchNotes"
@using System.Globalization
@using KenyonDevLabs.Models
@using KenyonDevLabs.Services
@inject NewsFileService NewsData

<PageTitle>Patch Notes - Girls Who Connect</PageTitle>

<GirlsWhoWalkHeader />

<div class="gwc-page">

    <section class="gwc-section gwc-hero gwc-hero-compact">
        <div class="gwc-container gwc-hero-grid">
            <div class="gwc-hero-copy">
                <span class="gwc-eyebrow gwc-eyebrow-hero">Girls Who Connect</span>
                <h1>Patch notes</h1>
                <p>
                    Every release, improvement, and fix for the Girls Who Connect app -
                    from the original launch through the latest update.
                </p>
            </div>
            <div class="gwc-hero-visual">
                <img src="/images/Girls Who Connect/icons/1.0 GWW.png" alt="Girls Who Connect app icon" />
            </div>
        </div>
    </section>

    <section class="gwc-section gwc-section-white gwc-news-section" aria-labelledby="news-title">
        <div class="gwc-container">
            <header class="gwc-section-head">
                <span class="gwc-eyebrow">Updates</span>
                <h2 id="news-title">All patch notes</h2>
                <p class="gwc-section-lead">@Items.Count release@(Items.Count == 1 ? "" : "s") published.</p>
            </header>

            @if (Items.Count == 0)
            {
                <p class="gwc-news-empty">No patch notes yet - check back soon.</p>
            }
            else
            {
                <div class="gwc-news-list">
                    @{
                        var lastYear = (int?)null;
                    }
                    @foreach (var item in Items)
                    {
                        var year = item.Date.Year;
                        if (lastYear != year)
                        {
                            <div class="gwc-year-divider @(lastYear is null ? "gwc-year-divider-first" : "")">
                                <span>@year</span>
                            </div>
                            lastYear = year;
                        }

                        <article class="gwc-news-card">
                            <div class="gwc-news-body">
                                <div class="gwc-news-title-row">
                                    <div class="gwc-news-title-left">
                                        @if (!string.IsNullOrWhiteSpace(item.IconUrl))
                                        {
                                            <img class="gwc-news-icon" src="@item.IconUrl" alt="" />
                                        }
                                        <h3>@item.Title</h3>
                                    </div>
                                    <div class="gwc-news-date"
                                         style="background: linear-gradient(135deg, @GetTop(item), @GetBottom(item)); color: @GetDateText(item);">
                                        <span class="day">@item.Date.ToString("dd")</span>
                                        <span class="mon">@item.Date.ToString("MMM", CultureInfo.InvariantCulture)</span>
                                        <span class="yr">@item.Date.ToString("yyyy")</span>
                                    </div>
                                </div>
                                <p>@((MarkupString)item.Summary)</p>
                            </div>
                        </article>
                    }
                </div>
            }
        </div>
    </section>

    <footer class="gwc-footer">
        <div class="gwc-container gwc-footer-inner">
            <nav aria-label="Legal">
                <h3>Legal</h3>
                <ul class="gwc-footer-links">
                    <li><NavLink href="/GirlsWhoConnect/PrivacyPolicy">Privacy Policy</NavLink></li>
                    <li><NavLink href="/GirlsWhoConnect/ChildSafetyStandards">Child Safety Standards</NavLink></li>
                </ul>
            </nav>
            <p class="gwc-footer-copy">&copy; @DateTime.Now.Year Kenyon Dev Labs</p>
        </div>
    </footer>

</div>

<style>
    :root {
        --gwc-brand: #efb2c4;
        --gwc-brand-dark: #d495a8;
        --gwc-brand-deep: #b14c66;
        --gwc-muted: #fff5f8;
        --gwc-text: #1a1a1a;
        --gwc-text-soft: #4a4a4a;
        --gwc-max: 1080px;
        --gwc-radius: 1rem;
        --gwc-shadow: 0 8px 28px rgba(212, 149, 168, 0.18);
    }

    html, body {
        overflow-x: clip;
        font-family: var(--font-sans, 'Plus Jakarta Sans', system-ui, sans-serif);
    }

    body {
        background: #fff;
        color: var(--gwc-text);
    }

    .gwc-page {
        overflow-x: clip;
    }

    .gwc-section {
        width: 100vw;
        margin-left: calc(50% - 50vw);
        margin-right: calc(50% - 50vw);
        padding: 4rem 1.5rem;
        box-sizing: border-box;
        border-top: 1px solid rgba(239, 178, 196, 0.35);
    }

    .gwc-section-white {
        background: #fff;
    }

    .gwc-container {
        max-width: var(--gwc-max);
        margin: 0 auto;
    }

    .gwc-section-head {
        max-width: 42rem;
        margin: 0 auto 2.5rem;
        text-align: center;
    }

    .gwc-eyebrow {
        display: inline-block;
        margin-bottom: 0.75rem;
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: #c45f7a;
    }

    .gwc-section-head h2 {
        margin: 0;
        font-size: clamp(1.6rem, 3vw, 2.1rem);
        font-weight: 800;
        letter-spacing: -0.02em;
        line-height: 1.15;
        color: var(--gwc-text);
    }

        .gwc-section-head h2::after {
            content: "";
            display: block;
            width: 3rem;
            height: 3px;
            margin: 1rem auto 0;
            background: var(--gwc-brand-dark);
            border-radius: 999px;
        }

    .gwc-section-lead {
        margin: 1.15rem 0 0;
        color: var(--gwc-text-soft);
        font-size: 1.05rem;
        line-height: 1.65;
    }

    .gwc-hero {
        border-top: none;
        padding: 3rem 1.5rem 5.5rem;
        background: linear-gradient(160deg, var(--gwc-brand) 0%, var(--gwc-brand-dark) 100%);
        position: relative;
    }

        .gwc-hero::after {
            content: "";
            position: absolute;
            left: 0;
            right: 0;
            bottom: -1px;
            height: 64px;
            background: #fff;
            clip-path: ellipse(55% 100% at 50% 100%);
        }

    .gwc-hero-compact {
        padding-bottom: 4.5rem;
    }

    .gwc-hero-grid {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 2.5rem;
        flex-wrap: wrap;
        position: relative;
        z-index: 1;
    }

    .gwc-hero-copy {
        flex: 1 1 360px;
        color: var(--gwc-text);
    }

    .gwc-eyebrow-hero {
        color: var(--gwc-brand-deep);
    }

    .gwc-hero-copy h1 {
        margin: 0 0 1rem;
        font-size: clamp(2rem, 4.5vw, 2.75rem);
        font-weight: 800;
        letter-spacing: -0.03em;
        line-height: 1.1;
    }

    .gwc-hero-copy p {
        margin: 0 0 1.35rem;
        max-width: 32rem;
        font-size: 1.08rem;
        line-height: 1.65;
        color: var(--gwc-text-soft);
    }

    .gwc-hero-visual {
        flex: 1 1 280px;
        display: flex;
        justify-content: center;
    }

        .gwc-hero-visual img {
            width: 100%;
            max-width: 220px;
            border-radius: 22%;
            filter: drop-shadow(0 16px 32px rgba(0, 0, 0, 0.15));
        }

    .gwc-news-empty {
        text-align: center;
        color: var(--gwc-text-soft);
        margin: 0;
    }

    .gwc-news-list {
        max-width: 52rem;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .gwc-year-divider {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin: 0.75rem 0 0.25rem;
        font-size: 1.35rem;
        font-weight: 700;
        letter-spacing: 0.04em;
    }

        .gwc-year-divider-first {
            margin-top: 0;
        }

        .gwc-year-divider::before,
        .gwc-year-divider::after {
            content: "";
            flex: 1;
            height: 2px;
            background: rgba(239, 178, 196, 0.65);
            border-radius: 999px;
        }

        .gwc-year-divider span {
            flex-shrink: 0;
            padding: 0 0.25rem;
            color: #c45f7a;
        }

    .gwc-news-card {
        display: block;
        background: #fff;
        border: 1px solid rgba(239, 178, 196, 0.35);
        border-radius: var(--gwc-radius);
        box-shadow: 0 4px 16px rgba(212, 149, 168, 0.1);
        overflow: hidden;
        transition: transform 0.18s ease, box-shadow 0.18s ease;
    }

        .gwc-news-card:hover {
            transform: translateY(-2px);
            box-shadow: var(--gwc-shadow);
        }

    .gwc-news-body {
        padding: 1.1rem 1.25rem 1.15rem;
    }

    .gwc-news-title-row {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 0.85rem;
        margin-bottom: 0.55rem;
    }

    .gwc-news-title-left {
        display: flex;
        align-items: center;
        gap: 0.65rem;
        min-width: 0;
        flex: 1;
    }

    .gwc-news-date {
        display: flex;
        flex-direction: row;
        align-items: baseline;
        justify-content: center;
        gap: 0.35rem;
        flex-shrink: 0;
        padding: 0.35rem 0.65rem;
        border-radius: 999px;
        font-weight: 800;
        text-align: center;
        line-height: 1;
    }

        .gwc-news-date .day {
            font-size: 0.95rem;
        }

        .gwc-news-date .mon {
            font-size: 0.72rem;
            letter-spacing: 0.06em;
            text-transform: uppercase;
        }

        .gwc-news-date .yr {
            font-size: 0.72rem;
            opacity: 0.9;
        }

    .gwc-news-icon {
        width: 1.75rem;
        height: 1.75rem;
        object-fit: contain;
        flex-shrink: 0;
        border-radius: 22%;
    }

    .gwc-news-title-row h3 {
        margin: 0;
        font-size: 1.05rem;
        font-weight: 800;
        line-height: 1.3;
    }

    .gwc-news-body p {
        margin: 0;
        color: var(--gwc-text-soft);
        font-size: 0.95rem;
        line-height: 1.6;
    }

    .gwc-footer {
        width: 100vw;
        margin-left: calc(50% - 50vw);
        margin-right: calc(50% - 50vw);
        padding: 3rem 1.5rem;
        background: var(--gwc-muted);
        border-top: 1px solid rgba(239, 178, 196, 0.35);
        text-align: center;
    }

    .gwc-footer-inner h3 {
        margin: 0 0 0.75rem;
        font-size: 1rem;
        font-weight: 800;
    }

    .gwc-footer-links {
        list-style: none;
        margin: 0 0 1.5rem;
        padding: 0;
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 0.75rem 1.25rem;
    }

        .gwc-footer-links a {
            color: var(--gwc-text);
            text-decoration: none;
            font-weight: 600;
            font-size: 0.95rem;
        }

            .gwc-footer-links a:hover {
                color: var(--gwc-brand-deep);
            }

    .gwc-footer-copy {
        margin: 0;
        color: var(--gwc-text-soft);
        font-size: 0.92rem;
    }

    @@media (max-width: 760px) {
        .gwc-section {
            padding: 3rem 1.25rem;
        }

        .gwc-hero {
            padding-bottom: 4rem;
        }

        .gwc-hero-grid {
            flex-direction: column;
            text-align: center;
        }

        .gwc-hero-copy p {
            margin-left: auto;
            margin-right: auto;
        }
    }
</style>

@code {
    private List<NewsItem> Items = new();

    protected override async Task OnInitializedAsync()
    {
        const string file = "GirlsWhoConnectPatchNotes.json";

        try
        {
            var items = await NewsData.GetNewsAsync(file);
            Items = (items ?? new List<NewsItem>())
                .Where(n => n.Tags?.Contains("Girls Who Connect") == true)
                .OrderByDescending(i => i.Date)
                .ToList();
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"[News] ERROR reading {file}: {ex.Message}");
            Items = new();
        }
    }

    private static string GetTop(NewsItem n)
        => !string.IsNullOrWhiteSpace(n.TopColour) ? n.TopColour! : "#efb2c4";

    private static string GetBottom(NewsItem n)
        => !string.IsNullOrWhiteSpace(n.BottomColour) ? n.BottomColour! : "#d495a8";

    private static string GetDateText(NewsItem n)
        => !string.IsNullOrWhiteSpace(n.DateTextColour) ? n.DateTextColour! : "#1a1a1a";
}
