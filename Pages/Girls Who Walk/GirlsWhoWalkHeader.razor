@* Shared/Header.razor *@

<HeadContent>
    <link rel="icon" href="/images/Girls Who Connect/icons/Girls Who Connect Logo NB.png" />
</HeadContent>

<header class="site-header" role="banner">
    <div class="logo">
        <img src="/images/Girls Who Connect/icons/Girls Who Connect Logo NB.png"
             alt="Girls Who Connect logo"
             class="logo-img" />
        <span class="app-name">Girls Who Connect</span>
    </div>

    <button class="nav-toggle"
            @onclick="ToggleMenu"
            aria-label="Toggle menu"
            aria-controls="primary-nav"
            aria-expanded="@menuOpen.ToString().ToLower()">
        @if (!menuOpen)
        {
            <span class="bar"></span>
            <span class="bar"></span>
            <span class="bar"></span>
        }
        else
        {
            <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true">
                <path d="M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none" />
            </svg>
        }
    </button>

    <nav id="primary-nav" class=@($"nav-links {(menuOpen ? "open" : "")}") aria-label="Primary">
        <ul>
            <li><a href="/GirlsWhoConnect">Home</a></li>
            <li><a href="/GirlsWhoConnect/PatchNotes">Patch Notes</a></li>
            <li><a href="/GirlsWhoConnect/PrivacyPolicy">Privacy Policy</a></li>
            <li><a href="/GirlsWhoConnect/ChildSafetyStandards">Child Safety Standards</a></li>
        </ul>
    </nav>
</header>

@code {
    private bool menuOpen = false;
    private void ToggleMenu() => menuOpen = !menuOpen;
}

<style>
    .site-header {
        position: sticky;
        top: 0;
        z-index: 1000;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem 1.5rem;
        background: #d495a8;
        font-family: var(--font-sans, 'Plus Jakarta Sans', system-ui, sans-serif);
        box-sizing: border-box;
        border-bottom: 1px solid rgba(255, 255, 255, 0.2);
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.12);
    }

    .logo {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .logo-img {
        height: 32px;
        width: auto;
    }

    .app-name {
        font-size: 1.25rem;
        font-weight: 700;
        color: #fff;
    }

    .nav-toggle {
        display: none;
        background: none;
        border: 0;
        padding: .25rem;
        cursor: pointer;
        line-height: 0;
        color: #fff;
    }

        .nav-toggle .bar {
            display: block;
            width: 22px;
            height: 2px;
            background: #fff;
            margin: 4px 0;
            border-radius: 2px;
        }

        .nav-toggle svg {
            display: block;
        }

    .nav-links {
        display: flex;
        align-items: center;
    }

        .nav-links > ul {
            display: flex;
            align-items: center;
            gap: 1rem;
            list-style: none;
            margin: 0;
            padding: 0;
        }

        .nav-links a {
            text-decoration: none;
            font-weight: 600;
            color: #fff;
            padding: .4rem .6rem;
            border-radius: 6px;
            transition: color .2s ease, background .2s ease;
        }

            .nav-links a:hover {
                background: rgba(255, 255, 255, 0.15);
            }

    @@keyframes slidePanel {
        from {
            opacity: 0;
            transform: translateY(-6px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@media (max-width: 900px) {
        .nav-toggle {
            display: inline-block;
            position: relative;
            z-index: 1200;
        }

        .nav-links {
            position: absolute;
            top: 100%;
            right: 1.5rem;
            left: auto;
            width: min(280px, 90vw);
            background: #fff;
            border: 1px solid rgba(239, 178, 196, 0.45);
            border-radius: 12px;
            box-shadow: 0 10px 28px rgba(0, 0, 0, 0.14);
            overflow: hidden;
            display: none;
            animation: slidePanel .18s ease;
            z-index: 1100;
        }

            .nav-links.open {
                display: block;
            }

            .nav-links > ul {
                flex-direction: column;
                align-items: stretch;
                gap: 0.2rem;
                padding: .35rem .35rem .6rem .35rem;
                margin: 0;
            }

            .nav-links a {
                padding: .75rem .75rem;
                border-radius: 8px;
                color: #1a1a1a;
                background: transparent;
            }

                .nav-links a:hover {
                    background: rgba(239, 178, 196, 0.25);
                }

            .nav-links li + li a {
                margin-top: .3rem;
            }
    }
</style>
