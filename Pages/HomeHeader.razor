@* Shared/Header.razor *@

<HeadContent>
    <link rel="icon" href="~/Kenyon Dev Labs NB.png" />
</HeadContent>

<header class="site-header" role="banner">
    <div class="logo">
        <img src="images/Kenyon Dev Labs NB.png"
             alt="Kenyon Dev Labs logo"
             class="logo-img" />
        <span class="app-name">Kenyon Dev Labs</span>
    </div>

    <button class="nav-toggle"
            @onclick="ToggleMenu"
            aria-label="Toggle menu"
            aria-controls="primary-nav"
            aria-expanded="@menuOpen.ToString().ToLower()">
        @if (!menuOpen)
        {
            <span class="bar"></span>
            <span class="bar"></span>
            <span class="bar"></span>
        }
        else
        {
            <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true">
                <path d="M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none" />
            </svg>
        }
    </button>

    <nav id="primary-nav" class=@($"nav-links {(menuOpen ? "open" : "")}") aria-label="Primary">
        <ul>
            <li><a href="">Home</a></li>
            <li><a href="/News">News</a></li>
            <li><a href="/GirlsWhoConnect">Girls Who Connect</a></li>
            <li><a href="/BucketConnect">Bucket Connect</a></li>
        </ul>
    </nav>
</header>
<div class="site-header-spacer" aria-hidden="true"></div>

@code {
    private bool menuOpen = false;
    private void ToggleMenu() => menuOpen = !menuOpen;
}

<style>
    .site-header {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 1000;
        display: flex;
        align-items: center;
        justify-content: space-between;
        width: 100%;
        padding: 1rem 1.5rem;
        background: #280a16;
        font-family: var(--font-sans, 'Plus Jakarta Sans', system-ui, sans-serif);
        box-sizing: border-box;
        border-bottom: 1px solid rgba(255, 255, 255, 0.12);
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.15);
    }

    .site-header-spacer {
        height: 4.25rem;
        pointer-events: none;
        background: #280a16;
    }

    .logo {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .logo-img {
        height: 32px;
        width: auto;
    }

    .app-name {
        font-size: 1.2rem;
        font-weight: 700;
        letter-spacing: -0.02em;
        color: #fff;
    }

    .nav-toggle {
        display: none;
        background: none;
        border: 0;
        padding: 0.25rem;
        cursor: pointer;
        line-height: 0;
        color: #fff;
    }

        .nav-toggle .bar {
            display: block;
            width: 22px;
            height: 2px;
            background: #fff;
            margin: 4px 0;
            border-radius: 2px;
        }

        .nav-toggle svg {
            display: block;
            stroke: #fff;
        }

    .nav-links {
        display: flex;
        align-items: center;
        background: #280a16;
    }

        .nav-links > ul {
            display: flex;
            align-items: center;
            gap: 1rem;
            list-style: none;
            margin: 0;
            padding: 0;
        }

        .nav-links a {
            text-decoration: none;
            font-weight: 600;
            font-size: 0.95rem;
            letter-spacing: 0.01em;
            color: #fff;
            padding: 0.45rem 0.75rem;
            border-radius: 6px;
            transition: color 0.2s ease, background 0.2s ease;
        }

            .nav-links a:hover {
                background: rgba(255, 255, 255, 0.12);
            }

    @@media (max-width: 900px) {
        .nav-toggle {
            display: inline-block;
            position: relative;
            z-index: 1200;
        }

        .nav-links {
            position: absolute;
            top: 100%;
            right: 1.5rem;
            width: min(280px, 90vw);
            background: #280a16 !important;
            border-radius: 12px;
            box-shadow: 0 10px 28px rgba(0, 0, 0, 0.14);
            overflow: hidden;
            display: none;
            z-index: 1100;
        }

            .nav-links.open {
                display: block;
            }

            .nav-links > ul {
                flex-direction: column;
                align-items: stretch;
                gap: 0.8rem;
                padding: 0.75rem;
            }

            .nav-links a {
                padding: 0.75rem;
                border-radius: 8px;
            }
    }
</style>
