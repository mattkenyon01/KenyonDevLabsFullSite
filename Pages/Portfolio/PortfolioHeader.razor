@* Shared/Header.razor *@

<HeadContent>
    <link rel="icon" href="Girls Who Walk Logo NB.png" />
</HeadContent>

<header class="site-header" role="banner">
    <!-- Left side: Logo + App name -->
    <div class="logo">

        <span class="app-name">Matthew Kenyon</span>
    </div>

    <!-- Mobile menu toggle -->
    <button class="nav-toggle"
            @onclick="ToggleMenu"
            aria-label="Toggle menu"
            aria-controls="primary-nav"
            aria-expanded="@menuOpen.ToString().ToLower()">
        @if (!menuOpen)
        {
            <!-- hamburger -->
            <span class="bar"></span>
            <span class="bar"></span>
            <span class="bar"></span>
        }
        else
        {
            <!-- minus -->
            <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true">
                <path d="M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none" />
            </svg>
        }
    </button>

    <!-- Right side: Nav links -->
    <nav id="primary-nav" class=@($"nav-links {(menuOpen ? "open" : "")}") aria-label="Primary">
        <ul>
            <li><a href="/GirlsWhoWalk">Home</a></li>
            <li><a href="/GirlsWhoWalk/PatchNotes">Games</a></li>
            <li><a href="/GirlsWhoWalk/PrivacyPolicy">Applications</a></li>
            <li><a href="/GirlsWhoWalk/ChildSafetyStandards">Technologies</a></li>
        </ul>
    </nav>
</header>

@code {
    private bool menuOpen = false;
    private void ToggleMenu() => menuOpen = !menuOpen;
}

<style>
    .site-header {
        position: sticky;
        top: 0;
        z-index: 1000;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem 2rem;
        background: #420f22;
        color: #fff;
    }

    /* Logo */
    .logo {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: #fff;
    }

    .logo-img {
        height: 32px;
        width: auto;
    }

    .app-name {
        font-size: 1.25rem;
        font-weight: 700;
        color: #fff;
    }

    /* Toggle */
    .nav-toggle {
        display: none;
        background: none;
        border: 0;
        padding: .25rem;
        cursor: pointer;
        line-height: 0;
        color: #fff; /* icon color */
    }

        .nav-toggle .bar {
            display: block;
            width: 22px;
            height: 2px;
            background: #fff;
            margin: 4px 0;
            border-radius: 2px;
        }

        .nav-toggle svg {
            display: block;
            color: #fff;
        }

    /* Nav links (desktop) */
    .nav-links {
        display: flex;
        align-items: center;
    }

        .nav-links > ul {
            display: flex;
            align-items: center;
            gap: 1rem;
            list-style: none;
            margin: 0;
            padding: 0;
        }

        .nav-links a {
            text-decoration: none;
            font-weight: 600;
            color: #fff;
            padding: .4rem .6rem;
            border-radius: 6px;
            transition: color .2s ease, background .2s ease;
        }

            .nav-links a:hover {
                background: rgba(255,255,255,0.15);
            }

    /* Dropdowns (optional stubs) */
    .has-dropdown {
        position: relative;
    }

    .dropdown {
        position: absolute;
        top: 100%;
        left: 0;
        display: none;
        min-width: 200px;
        background: #420f22;
        border-radius: 10px;
        padding: .5rem 0;
        box-shadow: 0 8px 20px rgba(0,0,0,0.12);
        animation: fadeDown .15s ease;
    }

        .dropdown li {
            list-style: none;
        }

        .dropdown a {
            display: block;
            padding: .6rem 1rem;
            color: #fff;
        }

    @@keyframes fadeDown {
        from {
            opacity: 0;
            transform: translateY(-5px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes slidePanel {
        from {
            opacity: 0;
            transform: translateY(-6px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Mobile */
    @@media (max-width: 900px) {
        .nav-toggle {
            display: inline-block;
            position: relative;
            z-index: 1200;
        }

        .nav-links {
            position: absolute;
            top: 0;
            right: 2rem;
            left: auto;
            width: min(280px, 90vw);
            background: #420f22;
            border: 1px solid rgba(255,255,255,0.15);
            border-radius: 12px;
            box-shadow: 0 10px 28px rgba(0,0,0,.25);
            overflow: hidden;
            display: none;
            animation: slidePanel .18s ease;
            z-index: 1100;
        }

            .nav-links.open {
                display: block;
            }

            .nav-links > ul {
                flex-direction: column;
                align-items: stretch;
                gap: 0.8rem;
                padding: .6rem;
                margin: 0;
            }

            .nav-links a {
                padding: .75rem;
                border-radius: 8px;
                color: #fff;
                background: transparent;
            }

            .nav-links li + li a {
                margin-top: .3rem;
            }
    }
</style>
