@page "/Bille/PrivacyPolicy"
@using System.Globalization
@using KenyonDevLabs.Models
@using KenyonDevLabs.Services
@inject HttpClient Http
@inject NewsFileService NewsData
@inject NavigationManager Nav

<PageTitle>Bill E</PageTitle>

<BilleHeader />
<!-- ===== HERO SECTION ===== -->
<section class="hero-section">
    <div class="hero-inner">
        <div class="hero-content">
            <div class="hero-image">
                <img src="/images/Lock.png" alt="Girls Who Connect" />
            </div>

            <div class="hero-text">
                <h1>Privacy Policy</h1>
                <p>
                    Bill E values your privacy and is committed to protecting your personal
                    information. This page outlines how we handle your data and ensure it’s used safely
                    and responsibly.
                    <br /><br />
                    Effective Date: 14th April 2026
                </p>
            </div>
        </div>
    </div>
</section>

<style>
    :root {
        --brand: #6a54e8;
    }

    html, body {
        overflow-x: clip;
    }

    .hero-section {
        position: relative;
        display: flex;
        justify-content: center;
        align-items: flex-start;
        width: 200%;
        left: 50%;
        transform: translateX(-50%);
        height: 150%;
        padding-top: calc((var(--hero-extra, 20%) / 2));
        padding-bottom: 100px;
        box-sizing: border-box;
        z-index: 1;
        overflow: hidden;
        background: var(--brand);
        margin-top: -6rem; /* ⬅️ moves the whole section upward */
    }

    /* Content wrapper stays centered horizontally */
    .hero-inner {
        padding-top: 5vh;
        margin: 0 auto;
        width: min(var(--page-max, 1100px), 50%);
    }

    /* Wave as BACKGROUND (behind content) */
    .hero-section::after {
        content: "";
        position: absolute;
        left: 0;
        right: 0;
        bottom: -20px; /* moves it 20px lower */
        height: 140px; /* wave height */
        pointer-events: none;
        z-index: 0; /* behind content */
        background-repeat: no-repeat;
        background-position: bottom center;
        background-size: 100% 100%;
        transform: translateY(-16px); /* ✅ lifts wave upward slightly */
        /* White wave so it fades into the white section below */
        background-image: url('data:image/svg+xml;utf8,<svg viewBox="0 0 1440 120" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none"><path d="M0,32 C240,96 480,0 720,48 C960,96 1200,32 1440,64 L1440,120 L0,120 Z" fill="%23ffffff"/></svg>');
    }

    .hero-content {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 2rem;
        flex-wrap: wrap;
        flex-direction: row; /* ✅ ensures side-by-side on desktop */
    }

    .hero-text {
        flex: 1 1 400px;
        color: #fff;
        text-align: left;
        order: 1; /* ✅ text first */
    }

        .hero-text h1 {
            font-size: clamp(1.8rem, 3vw, 2.4rem);
            font-weight: 800;
            margin-bottom: 1rem;
            color: #fff;
        }

        .hero-text p {
            font-size: 1.05rem;
            line-height: 1.5;
            color: #fff;
            margin-bottom: 1.5rem;
            max-width: 500px;
        }

    .hero-image {
        flex: 1 1 400px;
        display: flex;
        justify-content: center;
        align-items: center;
        order: 2; /* ✅ image second (on the right) */
    }

        .hero-image img {
            display: block;
            width: 100%;
            max-width: 500px;
            height: auto;
            object-fit: contain;
            border-radius: 16px;
            transition: transform 0.3s ease;
        }

    /* ===== Responsive ===== */
    @@media (max-width: 800px) {
        .hero-section {
            flex-direction: column;
            text-align: center;
            padding-bottom: 95px; /* keep good spacing */
        }

            .hero-section::after {
                height: 120px;
                transform: translateY(-12px); /* less lift for small screens */
            }

        .hero-image img {
            max-width: 340px;
            order: 1;
        }

        .hero-text {
            text-align: center;
            order: 2;
        }
    }

    @@media (max-width: 400px) {
        .hero-content {
            margin-top: 2rem; /* adjust as needed */
        }
    }
</style>

<!-- ===== INFO SECTION ===== -->
<section class="info-section" aria-labelledby="info-title">
    <div class="info-inner">
        <h2 id="info-title">Consent</h2>
        <div class="info-content">
            <div class="info-text">
                <p>
                    By using Bill E, you consent to the terms outlined in this Privacy Policy.
                </p>
            </div>
        </div>
    </div>

    <div class="info-inner">
        <h2 id="info-title">Advertisements</h2>
        <div class="info-content">
            <div class="info-text">
                <p>
                    When you use BillE, we may collect information through services such
                    as Google AdMob, including:
                </p>

                <ul>
                    <li><strong>Personal Information:</strong> Includes data that can identify you, such as your device ID, IP address, and other device-specific details.</li>
                    <li><strong>Non-Personal Information:</strong> Includes aggregated or anonymised data such as device type, operating system, general location, and usage statistics.</li>
                </ul>

                <p>
                    Advertisements help support the ongoing development and maintenance of the app.
                    Revenue generated from ads allows us to fund backend infrastructure and invest
                    more time and resources into improving the overall experience for our community.
                </p>
            </div>
        </div>
    </div>

    @*
