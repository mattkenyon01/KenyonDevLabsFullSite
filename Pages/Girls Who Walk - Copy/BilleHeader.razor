
@* Shared/Header.razor *@

<HeadContent>
    <link rel="icon" href="Girls Who Connect Logo NB.png" />
</HeadContent>

<header class="site-header" role="banner">
    <div class="header-inner">
        <!-- Left side: Logo + App name -->
        <div class="logo">
            <img src="/images/Bille/Bille_NB.png"
                 alt="Girls Who Connect Logo"
                 class="logo-img" />
            <span class="app-name">Bill-E</span>
        </div>

        <!-- Mobile menu toggle -->
        <button class="nav-toggle"
                @onclick="ToggleMenu"
                aria-label="Toggle menu"
                aria-controls="primary-nav"
                aria-expanded="@menuOpen.ToString().ToLower()">
            @if (!menuOpen)
            {
                <!-- hamburger -->
                <span class="bar"></span>
                <span class="bar"></span>
                <span class="bar"></span>
            }
            else
            {
                <!-- minus -->
                <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true">
                    <path d="M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none" />
                </svg>
            }
        </button>

        <!-- Right side: Nav links -->
        <nav id="primary-nav" class=@($"nav-links {(menuOpen ? "open" : "")}") aria-label="Primary">
            <ul>
                <li><a href="/girlswhoconnect">Home</a></li>
                <li><a href="/girlswhoconnect/PatchNotes">Patch Notes</a></li>
                <li><a href="/girlswhoconnect/PrivacyPolicy">Privacy Policy</a></li>
                <li><a href="/girlswhoconnect/ChildSafetyStandards">Child Safety Standards</a></li>
            </ul>
        </nav>
    </div>
</header>

@code {
    private bool menuOpen = false;
    private void ToggleMenu() => menuOpen = !menuOpen;
}

<style>
    .site-header {
        position: sticky;
        top: 0;
        z-index: 1000;
        background: #6a54e8; /* ✅ purple */
        margin-left: -35px;
        margin-right: -35px;
    }

    .header-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        width: min(var(--page-max, 1200px), 100%);
        margin: 0 auto;
        padding: 1rem 2rem;
        box-sizing: border-box;
        position: relative;
    }

    /* Logo */
    .logo {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .logo-img {
        height: 32px;
        width: auto;
    }

    .app-name {
        font-size: 1.25rem;
        font-weight: 700;
        color: #fff; /* ✅ white text */
    }

    /* Toggle */
    .nav-toggle {
        display: none;
        background: none;
        border: 0;
        padding: .25rem;
        cursor: pointer;
        line-height: 0;
        color: #fff; /* ✅ white icon */
    }

        .nav-toggle .bar {
            display: block;
            width: 22px;
            height: 2px;
            background: #fff; /* ✅ white */
            margin: 4px 0;
            border-radius: 2px;
        }

    /* Nav links (desktop) */
    .nav-links {
        display: flex;
        align-items: center;
    }

        .nav-links > ul {
            display: flex;
            align-items: center;
            gap: 1rem;
            list-style: none;
            margin: 0;
            padding: 0;
        }

        .nav-links a {
            text-decoration: none;
            font-weight: 600;
            color: #fff; /* ✅ white text */
            padding: .4rem .6rem;
            border-radius: 6px;
            transition: background .2s ease, transform .15s ease;
        }

            .nav-links a:hover {
                background: rgba(255,255,255,0.15); /* subtle hover */
                transform: translateY(-1px);
            }

    /* Animations */
    @@keyframes fadeDown {
        from {
            opacity: 0;
            transform: translateY(-5px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes slidePanel {
        from {
            opacity: 0;
            transform: translateY(-6px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Mobile */
    @@media (max-width: 900px) {
        .nav-toggle {
            display: inline-block;
            position: relative;
            z-index: 1200;
        }

        .nav-links {
            position: absolute;
            top: 0;
            right: 2rem;
            width: min(280px, 90vw);
            background: #fff; /* keep white panel for contrast */
            border-radius: 12px;
            box-shadow: 0 10px 28px rgba(0,0,0,.14);
            overflow: hidden;
            display: none;
            animation: slidePanel .18s ease;
            z-index: 1100;
        }

            .nav-links.open {
                display: block;
            }

            .nav-links > ul {
                flex-direction: column;
                align-items: stretch;
                gap: 0.2rem;
                padding: .35rem .35rem .6rem .35rem;
                margin: 0;
            }

            .nav-links a {
                padding: .75rem .75rem;
                border-radius: 8px;
                color: #111; /* readable on white panel */
            }

                .nav-links a:hover {
                    background: rgba(106,84,232,0.1); /* purple tint hover */
                }
    }
</style>
