        .feature-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 22px rgba(0,0,0,.12);
        }

    .icon-circle {
        width: 84px;
        height: 84px;
        margin: 0 auto .75rem;
        border-radius: 50%;
        background: var(--circle-bg);
        border: 2px solid var(--circle-border);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--brand-dark);
    }

        .icon-circle svg {
            width: 36px;
            height: 36px;
            display: block;
        }

    .feature-card h3 {
        margin: .25rem 0 .35rem 0;
        font-size: 1.05rem;
