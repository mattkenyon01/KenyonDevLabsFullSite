<style>
    .pricing-section {
        padding: 3rem 1rem;
        box-sizing: border-box;
    }

    .pricing-inner {
        width: min(1100px, 100%);
        margin: 0 auto;
    }

    .pricing-section h2 {
        text-align: center;
        font-size: clamp(1.4rem, 3vw, 2rem);
        font-weight: 800;
        margin-bottom: 2rem;
        color: #111;
    }

    /* ===== GRID TABLE ===== */
    .pricing-table {
        display: grid;
        grid-template-columns: 1.2fr 1fr 1fr 1fr; /* Feature names + 3 plans */
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 10px 24px rgba(0,0,0,.08);
    }

    /* ===== HEADER ===== */
    .pricing-header {
        padding: 1.5rem 1rem;
        text-align: center;
        background: #fff;
        border-bottom: 1px solid #eee;
    }

        .pricing-header.plan {
            position: relative;
        }

        .pricing-header.featured {
            background: #f6f4ff;
        }

    /* ===== PRICE CIRCLE ===== */
    .price-circle {
        width: 90px;
        height: 90px;
        margin: 0 auto 0.75rem;
        border-radius: 50%;
        background: #6a54e8;
        color: #fff;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        box-shadow: 0 6px 16px rgba(106,84,232,.35);
    }

        .price-circle .price {
            font-size: 1.4rem;
            font-weight: 800;
            line-height: 1;
        }

        .price-circle .period {
            font-size: 0.8rem;
            opacity: 0.9;
        }

    /* ===== FEATURE ROWS ===== */
    .feature-name {
        padding: 1rem;
        background: #fafafa;
        font-weight: 600;
        border-bottom: 1px solid #eee;
        color: #333;
    }

    .feature {
        text-align: center;
        padding: 1rem;
        border-bottom: 1px solid #eee;
        font-size: 1.1rem;
        font-weight: 700;
    }

        /* ===== OPTIONAL: COLOURED STATES ===== */
        .feature:contains("✓") {
            color: #22c55e; /* green */
        }

        .feature:contains("✕") {
            color: #aaa;
        }

    /* ===== BADGE ===== */
    .badge {
        position: absolute;
        top: -10px;
        right: 10px;
        background: #6a54e8;
        color: #fff;
        font-size: 0.7rem;
        padding: 4px 8px;
        border-radius: 999px;
        font-weight: 700;
        box-shadow: 0 4px 10px rgba(0,0,0,.15);
    }

    /* ===== HOVER EFFECT ===== */
    .pricing-header.plan:hover {
        transform: translateY(-3px);
        transition: transform 0.2s ease;
    }

    /* ===== MOBILE ===== */
    @@media (max-width: 700px) {
        .pricing-table

    {
        grid-template-columns: 1fr;
    }

    .pricing-header {
        border-bottom: none;
    }

    .feature-name {
        text-align: center;
        background: transparent;
        font-weight: 800;
    }

    .feature {
        border-bottom: none;
    }

    }
</style>

<!-- ===== Policies ===== -->
<section class="policy-cta" aria-labelledby="policy-cta-title">
    <div class="policy-cta-inner">
        <h2 id="policy-cta-title">Important Policies</h2>
        <p class="policy-cta-desc">
            We’re committed to privacy and safety across the Girls Who Connect community.
            Learn how we protect your data and the standards we follow.
        </p>

        <div class="policy-card-grid">
            <article class="policy-card">
                <h3>Privacy Policy</h3>
                <p>
                    See what data we collect, how we use it, and the controls you have to manage your privacy.
                </p>
                <NavLink class="btn" href="/bille/privacypolicy" aria-label="Read our Privacy Policy">
                    Read Privacy Policy
                </NavLink>
            </article>
        </div>
    </div>
</section>

<hr class="section-divider" />

<style>
    .policy-cta {
        background: #ffffff;
        color: #111;
        padding: 2.75rem 1rem 2rem;
        box-sizing: border-box;
    }

    .policy-cta-inner {
        width: min(var(--page-max, 1100px), 100%);
        margin: 0 auto;
        text-align: center;
    }

    .policy-cta h2 {
        margin: 0 0 .6rem 0;
        font-size: clamp(1.3rem, 3vw, 1.8rem);
        font-weight: 800;
    }

    .policy-cta-desc {
        margin: 0 auto 1.5rem;
        max-width: 60ch;
        color: #333;
        line-height: 1.55;
    }

    .policy-card-grid {
        display: grid;
        grid-template-columns: 1fr;
        justify-items: center;
        gap: var(--gap, 1.25rem);
        max-width: 550px;
        margin: 0 auto;
    }

    .policy-card {
        text-align: center;
        background: #fff;
        border-radius: var(--radius, 16px);
        border: 1px solid rgba(106,84,232,.45);
        box-shadow: 0 10px 24px rgba(0,0,0,.08);
        padding: 1.25rem 1.25rem 1.35rem;
        display: grid;
        align-content: start;
        justify-items: center; /* 👈 centers inner content */
        gap: .65rem;
        transition: transform .18s ease, box-shadow .18s ease;
    }

        .policy-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 14px 28px rgba(0,0,0,.12);
        }

        .policy-card h3 {
            margin: 0;
            font-size: 1.1rem;
            font-weight: 800;
        }

        .policy-card p {
            margin: 0;
            color: #333;
            line-height: 1.5;
        }

        .policy-card .btn {
            margin-top: .6rem;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: #6a54e8;
            color: #fff;
            border: none;
            border-radius: 999px;
            padding: 0.65rem 1.1rem;
            font-weight: 700;
            text-decoration: none;
            transition: background 0.2s ease, transform 0.15s ease;
        }

            .policy-card .btn:hover {
                background: #5643c9;
                transform: translateY(-2px);
            }

    @@media (max-width: 760px) {
        .policy-card-grid {
            grid-template-columns: 1fr;
            justify-items: center;
        }

        .policy-card {
            text-align: center;
            width: 100%;
            max-width: 520px;
        }

            .policy-card .btn {
                width: 100%;
                justify-content: center;
            }
    }
</style>

<!-- ===== News & Updates ===== -->
<section class="news-section" aria-labelledby="news-title">
    <div class="news-header">
        <h2 id="news-title">
            Patch Notes
            <NavLink href="/GirlsWhoConnect/PatchNotes">
                <svg class="news-arrow" xmlns="http://www.w3.org/2000/svg"
                     viewBox="0 0 24 24" width="18" height="18"
                     fill="none" stroke="black" stroke-width="4"
                     stroke-linecap="round" stroke-linejoin="round">
                    <path d="M8 5l8 7-8 7" />
                </svg>
            </NavLink>
        </h2>
    </div>

    <div class="news-grid">
        @foreach (var item in BillENotes)
        {
            <article class="news-card">
                <div class="news-header-bar"
                     style="background: linear-gradient(180deg, @item.TopColour, @item.BottomColour);">
                    <h3>@item.Title</h3>
                </div>

                <div class="news-body">
                    <p>@((MarkupString)item.Summary)</p>

                    @if (!string.IsNullOrEmpty(item.Summary) && item.Summary.Length > 200)
                    {
                        <a class="news-link" href="/GirlsWhoConnect/PatchNotes">Read more</a>
                    }
                </div>

                <div class="news-date"
                     style="background: linear-gradient(180deg, @item.TopColour, @item.BottomColour); color: @item.DateTextColour;">
                    <span class="day">@item.Date.ToString("dd")</span>
                    <span class="mon">@item.Date.ToString("MMM", CultureInfo.InvariantCulture)</span>
                    <span class="yr">@item.Date.ToString("yyyy")</span>
                </div>
            </article>
        }
    </div>
</section>

<style>
    .news-section {
        width: min(var(--page-max, 1125px), 100%);
        margin: 0 auto;
        padding: 2.75rem 1rem;
        color: #111;
        box-sizing: border-box;
        text-align: left;
    }

        .news-section #news-title {
            margin: 0 0 1.25rem 0;
            font-size: clamp(1.25rem, 2.5vw, 1.75rem);
