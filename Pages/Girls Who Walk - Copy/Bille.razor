@code {
    private List<NewsItem> BillENotes = new();

    protected override async Task OnInitializedAsync()
    {
        if (Http.BaseAddress is null)
            Http.BaseAddress = new Uri(Nav.BaseUri);

        var items = await NewsData.GetNewsAsync("BillEPatchNotes.json");
        BillENotes = items
            .Where(n => n.Tags?.Contains("Bill E") == true)
            .OrderByDescending(n => n.Date)
            .Take(3)
            .ToList();
    }
}

