@page "/Bille"
@using System.Globalization
@using KenyonDevLabs.Models
@using KenyonDevLabs.Services
@inject HttpClient Http
@inject NewsFileService NewsData
@inject NavigationManager Nav
<PageTitle>Girls Who Connect</PageTitle>

<BilleHeader />
<section class="hero-section">
    <div class="hero-inner">
        <div class="hero-content">
            <div class="hero-image">
                <img src="images/Girls Who Connect/3 phones graphic.png" alt="Girls Who Connect" />
            </div>

            <div class="hero-text">
                <h1>Welcome to Bill-E</h1>
                <p>
                    Stay up to date with Girls Who Connect in your area - discover upcoming walks,
                    connect with local members, and see everything happening in your community.
                </p>

                <!-- ✅ App Store Button -->
                <a href="https://apps.apple.com/gb/app/girls-who-walk/id6477972997"
                   target="_blank"
                   rel="noopener noreferrer"
                   class="appstore-btn">
                    <img src="images/App Store Button.png" alt="Download on the App Store" />
                </a>
            </div>
        </div>
    </div>
</section>

<style>
    :root {
        --brand: #6a54e8;
    }

    html, body {
        overflow-x: clip;
    }

    .hero-section {
        position: relative;
        display: flex;
        justify-content: center;
        align-items: flex-start;
        width: 200%;
        left: 50%;
        transform: translateX(-50%);
        height: 150%;
        padding-top: calc((var(--hero-extra, 20%) / 2));
        padding-bottom: 100px;
        box-sizing: border-box;
        z-index: 1;
        overflow: hidden;
        background: var(--brand);
        margin-top: -6rem;
    }

    .hero-inner {
        padding-top: 5vh;
        margin: 0 auto;
        width: min(var(--page-max, 1100px), 50%);
    }

    .hero-section::after {
        content: "";
        position: absolute;
        left: 0;
        right: 0;
        bottom: -65px;
        height: 140px;
        pointer-events: none;
        z-index: 0;
        background-repeat: no-repeat;
        background-position: bottom center;
        background-size: 100% 100%;
        transform: translateY(-16px);
        background-image: url('data:image/svg+xml;utf8,<svg viewBox="0 0 1440 120" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none"><path d="M0,32 C240,96 480,0 720,48 C960,96 1200,32 1440,64 L1440,120 L0,120 Z" fill="%23ffffff"/></svg>');
    }

    .hero-content {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 2rem;
        flex-wrap: wrap;
        flex-direction: row;
    }

    .hero-text {
        flex: 1 1 400px;
        color: #fff;
        text-align: left;
        order: 1;
    }

        .hero-text h1 {
            font-size: clamp(1.8rem, 3vw, 2.4rem);
            font-weight: 800;
            margin-bottom: 1rem;
            color: #fff;
        }

        .hero-text p {
            font-size: 1.05rem;
            line-height: 1.5;
            color: rgba(255, 255, 255, 0.92);
            margin-bottom: 1.5rem;
            max-width: 500px;
        }

    .appstore-btn img {
        width: 120px;
        height: auto;
        transition: transform 0.2s ease;
    }

    .appstore-btn:hover img {
        transform: scale(1.05);
    }

    .hero-image {
        flex: 1 1 400px;
        display: flex;
        justify-content: center;
        align-items: center;
        order: 2;
    }

        .hero-image img {
            display: block;
            width: 100%;
            max-width: 500px;
            height: auto;
            object-fit: contain;
            border-radius: 16px;
            transition: transform 0.3s ease;
        }

    @@media (max-width: 800px) {
        .hero-section {
            flex-direction: column;
            text-align: center;
            padding-bottom: 95px;
        }

            .hero-section::after {
                height: 120px;
                transform: translateY(-12px);
            }

        .hero-text {
            text-align: center;
            order: 2;
        }

        .appstore-btn img {
            width: 160px;
        }

        .hero-image img {
            max-width: 340px;
            order: 1;
        }
    }

    @@media (max-width: 400px) {
        .hero-content {
            margin-top: 2rem;
        }
    }
</style>

<!-- ===== About / Info Section ===== -->
<section class="info-section" aria-labelledby="info-title">
    <div class="info-inner">
        <h2 id="info-title">Our Mission</h2>

        <div class="info-content">
            <div class="info-text">
                <p>
                    Girls Who Connect helps women discover local walking groups, make new friends,
                    and explore their area safely. The app was created to give communities their
                    space to organise walks, plan routes, and stay in touch within a supportive
                    environment designed just for them.
                </p>
                <p>
                    It’s not only a way to get active and meet people,
                    but also a platform shaped by its users. Feedback goes
                    directly to the developer, helping the app evolve into the kind
                    of social, stylish experience the community wants it to be.
                </p>
            </div>

            <div class="info-image">
                <img src="images/Girls Who Connect/Connect Graphic.png"
                     alt="Girls Who Connect community group"
                     loading="lazy" />
            </div>
        </div>
    </div>
</section>
<hr class="section-divider" />
<style>
    .info-section {
        color: #111;
        padding: 3rem 1rem;
        box-sizing: border-box;
    }

    .info-inner {
        width: min(var(--page-max, 1100px), 100%);
        margin: 0 auto;
    }

    .info-section h2 {
        text-align: center;
        font-size: clamp(1.4rem, 3vw, 2rem);
        font-weight: 800;
        margin: 0 0 1.5rem 0;
    }

    .info-content {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 2rem;
        flex-wrap: wrap;
    }

    .info-text {
        flex: 1 1 480px;
        color: #333;
        line-height: 1.6;
        font-size: 1.05rem;
        min-width: 0;
    }

        .info-text p {
            margin-bottom: 1rem;
        }

    .info-image {
        flex: 1 1 420px;
        display: flex;
        justify-content: center;
        min-width: 0;
    }

        .info-image img {
            display: block;
            width: 100%;
            max-width: 480px;
            height: auto;
            margin: 0 auto;
            border-radius: var(--radius, 16px);
            box-shadow: 0 10px 24px rgba(0,0,0,.1);
        }

    @@media (max-width: 800px) {
        .info-inner {
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .info-content {
            flex-direction: column-reverse;
            align-items: center;
            justify-content: center;
            text-align: center;
            gap: 1.5rem;
        }

        .info-text,
        .info-image {
            flex: 0 0 auto;
            width: 100%;
            max-width: 480px;
            margin: 0 auto;
        }

            .info-image img {
                width: 100%;
                max-width: 360px;
                height: auto;
            }
    }
</style>

<!-- ===== Feature Icons ===== -->
<section class="features-section" aria-labelledby="features-title">
    <div class="features-inner">
        <h2 id="features-title">App Functionality</h2>

        <div class="feature-grid">
            <article class="feature-card">
                <div class="icon-circle" aria-hidden="true">
                    <!-- Receipt -->
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                         aria-hidden="true">
                        <path d="M6 2h12v20l-2-1.5L14 22l-2-1.5L10 22l-2-1.5L6 22V2Z" />
                        <path d="M9 7h6" />
                        <path d="M9 11h6" />
                        <path d="M9 15h4" />
                    </svg>
                </div>
                <h3>Scan Receipts Instantly</h3>
                <p>
                    Take a photo or upload an image of your receipt to quickly pull in totals,
                    items, and key payment details without typing everything manually.
                </p>
            </article>

            <article class="feature-card">
                <div class="icon-circle" aria-hidden="true">
                    <!-- Split / Users -->
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                         aria-hidden="true">
                        <path d="M16 3h5v5" />
                        <path d="M8 21H3v-5" />
                        <path d="M21 3l-7 7" />
                        <path d="M3 21l7-7" />
                        <circle cx="8" cy="8" r="2.5" />
                        <circle cx="16" cy="16" r="2.5" />
                    </svg>
                </div>
                <h3>Split Bills Fairly</h3>
                <p>
                    Assign items to different people, divide shared items, and make sure everyone
                    only pays for what they actually had.
                </p>
            </article>

            <article class="feature-card">
                <div class="icon-circle" aria-hidden="true">
                    <!-- Calculator / Money -->
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                         aria-hidden="true">
                        <rect x="5" y="2" width="14" height="20" rx="2" />
                        <path d="M8 6h8" />
                        <path d="M8 10h2" />
                        <path d="M14 10h2" />
                        <path d="M8 14h2" />
                        <path d="M14 14h2" />
                        <path d="M8 18h8" />
                    </svg>
                </div>
                <h3>Calculate Totals Clearly</h3>
                <p>
                    Add tip, include tax, and see exactly what each person owes with a clean,
                    simple breakdown before anyone pays.
                </p>
            </article>
        </div>
    </div>
</section>

<hr class="section-divider" />



<style>
    :root {
        --brand-dark: #4f3cc4;
        --circle-bg: rgba(106,84,232,.22);
        --circle-border: rgba(106,84,232,.55);
    }

    .features-section {
        color: #111;
        padding: 2.75rem 1rem;
        box-sizing: border-box;
    }

    .features-inner {
        width: min(var(--page-max, 1100px), 100%);
        margin: 0 auto;
    }

    .features-section h2 {
