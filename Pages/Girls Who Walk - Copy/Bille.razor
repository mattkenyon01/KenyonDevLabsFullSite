    }

    .feature-card p {
        margin: 0;
        color: #333;
        line-height: 1.45;
        max-width: 28ch;
        display: inline-block;
    }

    @@media (max-width: 900px) {
        .feature-grid {
            grid-template-columns: repeat(2, 1fr);
            justify-items: stretch;
        }
    }

    @@media (max-width: 620px) {
        .feature-grid {
            grid-template-columns: 1fr;
            justify-items: center;
        }

        .feature-card {
            width: 100%;
            max-width: 520px;
        }

        .icon-circle {
            width: 78px;
            height: 78px;
        }

            .icon-circle svg {
                width: 32px;
                height: 32px;
            }
    }

    hr.section-divider {
        border: none;
        height: 4px;
        width: 100%;
        max-width: 1000px;
        margin: 10px auto;
        background: #6a54e8;
        border-radius: 0;
        padding-inline: 10px;
        box-sizing: border-box;
    }
</style>

